  "verses": [
    {
      "id": 5272,
      "verseKey": "68:1",
      "verseNumber": 1,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": " نٓ ۚ وَٱلْقَلَمِ وَمَا يَسْطُرُونَ"
    },
    {
      "id": 5273,
      "verseKey": "68:2",
      "verseNumber": 2,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ"
    },
    {
      "id": 5274,
      "verseKey": "68:3",
      "verseNumber": 3,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ"
    },
    {
      "id": 5275,
      "verseKey": "68:4",
      "verseNumber": 4,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٍ"
    },
    {
      "id": 5276,
      "verseKey": "68:5",
      "verseNumber": 5,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَسَتُبْصِرُ وَيُبْصِرُونَ"
    },
    {
      "id": 5277,
      "verseKey": "68:6",
      "verseNumber": 6,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "بِأَييِّكُمُ ٱلْمَفْتُونُ"
    },
    {
      "id": 5278,
      "verseKey": "68:7",
      "verseNumber": 7,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ"
    },
    {
      "id": 5279,
      "verseKey": "68:8",
      "verseNumber": 8,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَلَا تُطِعِ ٱلْمُكَذِّبِينَ"
    },
    {
      "id": 5280,
      "verseKey": "68:9",
      "verseNumber": 9,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "وَدُّوا۟ لَوْ تُدْهِنُ فَيُدْهِنُونَ"
    },
    {
      "id": 5281,
      "verseKey": "68:10",
      "verseNumber": 10,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "وَلَا تُطِعْ كُلَّ حَلَّافٍ مَّهِينٍ"
    },
    {
      "id": 5282,
      "verseKey": "68:11",
      "verseNumber": 11,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "هَمَّازٍ مَّشَّآءٍۭ بِنَمِيمٍ"
    },
    {
      "id": 5283,
      "verseKey": "68:12",
      "verseNumber": 12,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "مَّنَّاعٍ لِّلْخَيْرِ مُعْتَدٍ أَثِيمٍ"
    },
    {
      "id": 5284,
      "verseKey": "68:13",
      "verseNumber": 13,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "عُتُلٍّۭ بَعْدَ ذَٰلِكَ زَنِيمٍ"
    },
    {
      "id": 5285,
      "verseKey": "68:14",
      "verseNumber": 14,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "أَن كَانَ ذَا مَالٍ وَبَنِينَ"
    },
    {
      "id": 5286,
      "verseKey": "68:15",
      "verseNumber": 15,
      "pageNumber": 564,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ"
    },
    {
      "id": 5287,
      "verseKey": "68:16",
      "verseNumber": 16,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "سَنَسِمُهُۥ عَلَى ٱلْخُرْطُومِ"
    },
    {
      "id": 5288,
      "verseKey": "68:17",
      "verseNumber": 17,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "إِنَّا بَلَوْنَـٰهُمْ كَمَا بَلَوْنَآ أَصْحَـٰبَ ٱلْجَنَّةِ إِذْ أَقْسَمُوا۟ لَيَصْرِمُنَّهَا مُصْبِحِينَ"
    },
    {
      "id": 5289,
      "verseKey": "68:18",
      "verseNumber": 18,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "وَلَا يَسْتَثْنُونَ"
    },
    {
      "id": 5290,
      "verseKey": "68:19",
      "verseNumber": 19,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَطَافَ عَلَيْهَا طَآئِفٌ مِّن رَّبِّكَ وَهُمْ نَآئِمُونَ"
    },
    {
      "id": 5291,
      "verseKey": "68:20",
      "verseNumber": 20,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَأَصْبَحَتْ كَٱلصَّرِيمِ"
    },
    {
      "id": 5292,
      "verseKey": "68:21",
      "verseNumber": 21,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَتَنَادَوْا۟ مُصْبِحِينَ"
    },
    {
      "id": 5293,
      "verseKey": "68:22",
      "verseNumber": 22,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "أَنِ ٱغْدُوا۟ عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَـٰرِمِينَ"
    },
    {
      "id": 5294,
      "verseKey": "68:23",
      "verseNumber": 23,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَٱنطَلَقُوا۟ وَهُمْ يَتَخَـٰفَتُونَ"
    },
    {
      "id": 5295,
      "verseKey": "68:24",
      "verseNumber": 24,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "أَن لَّا يَدْخُلَنَّهَا ٱلْيَوْمَ عَلَيْكُم مِّسْكِينٌ"
    },
    {
      "id": 5296,
      "verseKey": "68:25",
      "verseNumber": 25,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "وَغَدَوْا۟ عَلَىٰ حَرْدٍ قَـٰدِرِينَ"
    },
    {
      "id": 5297,
      "verseKey": "68:26",
      "verseNumber": 26,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَلَمَّا رَأَوْهَا قَالُوٓا۟ إِنَّا لَضَآلُّونَ"
    },
    {
      "id": 5298,
      "verseKey": "68:27",
      "verseNumber": 27,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "بَلْ نَحْنُ مَحْرُومُونَ"
    },
    {
      "id": 5299,
      "verseKey": "68:28",
      "verseNumber": 28,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَ"
    },
    {
      "id": 5300,
      "verseKey": "68:29",
      "verseNumber": 29,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "قَالُوا۟ سُبْحَـٰنَ رَبِّنَآ إِنَّا كُنَّا ظَـٰلِمِينَ"
    },
    {
      "id": 5301,
      "verseKey": "68:30",
      "verseNumber": 30,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَلَـٰوَمُونَ"
    },
    {
      "id": 5302,
      "verseKey": "68:31",
      "verseNumber": 31,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "قَالُوا۟ يَـٰوَيْلَنَآ إِنَّا كُنَّا طَـٰغِينَ"
    },
    {
      "id": 5303,
      "verseKey": "68:32",
      "verseNumber": 32,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ"
    },
    {
      "id": 5304,
      "verseKey": "68:33",
      "verseNumber": 33,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 500,
      "manzilNumber": 7,
      "text": "كَذَٰلِكَ ٱلْعَذَابُ ۖ وَلَعَذَابُ ٱلْـَٔاخِرَةِ أَكْبَرُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ"
    },
    {
      "id": 5305,
      "verseKey": "68:34",
      "verseNumber": 34,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّـٰتِ ٱلنَّعِيمِ"
    },
    {
      "id": 5306,
      "verseKey": "68:35",
      "verseNumber": 35,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "أَفَنَجْعَلُ ٱلْمُسْلِمِينَ كَٱلْمُجْرِمِينَ"
    },
    {
      "id": 5307,
      "verseKey": "68:36",
      "verseNumber": 36,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "مَا لَكُمْ كَيْفَ تَحْكُمُونَ"
    },
    {
      "id": 5308,
      "verseKey": "68:37",
      "verseNumber": 37,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "أَمْ لَكُمْ كِتَـٰبٌ فِيهِ تَدْرُسُونَ"
    },
    {
      "id": 5309,
      "verseKey": "68:38",
      "verseNumber": 38,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ"
    },
    {
      "id": 5310,
      "verseKey": "68:39",
      "verseNumber": 39,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "أَمْ لَكُمْ أَيْمَـٰنٌ عَلَيْنَا بَـٰلِغَةٌ إِلَىٰ يَوْمِ ٱلْقِيَـٰمَةِ ۙ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ"
    },
    {
      "id": 5311,
      "verseKey": "68:40",
      "verseNumber": 40,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "سَلْهُمْ أَيُّهُم بِذَٰلِكَ زَعِيمٌ"
    },
    {
      "id": 5312,
      "verseKey": "68:41",
      "verseNumber": 41,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "أَمْ لَهُمْ شُرَكَآءُ فَلْيَأْتُوا۟ بِشُرَكَآئِهِمْ إِن كَانُوا۟ صَـٰدِقِينَ"
    },
    {
      "id": 5313,
      "verseKey": "68:42",
      "verseNumber": 42,
      "pageNumber": 565,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "يَوْمَ يُكْشَفُ عَن سَاقٍ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ"
    },
    {
      "id": 5314,
      "verseKey": "68:43",
      "verseNumber": 43,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "خَـٰشِعَةً أَبْصَـٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ۖ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَـٰلِمُونَ"
    },
    {
      "id": 5315,
      "verseKey": "68:44",
      "verseNumber": 44,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "فَذَرْنِى وَمَن يُكَذِّبُ بِهَـٰذَا ٱلْحَدِيثِ ۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ"
    },
    {
      "id": 5316,
      "verseKey": "68:45",
      "verseNumber": 45,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "وَأُمْلِى لَهُمْ ۚ إِنَّ كَيْدِى مَتِينٌ"
    },
    {
      "id": 5317,
      "verseKey": "68:46",
      "verseNumber": 46,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ"
    },
    {
      "id": 5318,
      "verseKey": "68:47",
      "verseNumber": 47,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
      "text": "أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ"
    },
    {
      "id": 5319,
      "verseKey": "68:48",
      "verseNumber": 48,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 226,
      "rukuNumber": 501,
      "manzilNumber": 7,
