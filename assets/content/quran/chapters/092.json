      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": " وَٱلَّيْلِ إِذَا يَغْشَىٰ"
    },
    {
      "id": 6060,
      "verseKey": "92:2",
      "verseNumber": 2,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ"
    },
    {
      "id": 6061,
      "verseKey": "92:3",
      "verseNumber": 3,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ"
    },
    {
      "id": 6062,
      "verseKey": "92:4",
      "verseNumber": 4,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ"
    },
    {
      "id": 6063,
      "verseKey": "92:5",
      "verseNumber": 5,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ"
    },
    {
      "id": 6064,
      "verseKey": "92:6",
      "verseNumber": 6,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَصَدَّقَ بِٱلْحُسْنَىٰ"
    },
    {
      "id": 6065,
      "verseKey": "92:7",
      "verseNumber": 7,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ"
    },
    {
      "id": 6066,
      "verseKey": "92:8",
      "verseNumber": 8,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ"
    },
    {
      "id": 6067,
      "verseKey": "92:9",
      "verseNumber": 9,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَكَذَّبَ بِٱلْحُسْنَىٰ"
    },
    {
      "id": 6068,
      "verseKey": "92:10",
      "verseNumber": 10,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ"
    },
    {
      "id": 6069,
      "verseKey": "92:11",
      "verseNumber": 11,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ"
    },
    {
      "id": 6070,
      "verseKey": "92:12",
      "verseNumber": 12,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "إِنَّ عَلَيْنَا لَلْهُدَىٰ"
    },
    {
      "id": 6071,
      "verseKey": "92:13",
      "verseNumber": 13,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ"
    },
    {
      "id": 6072,
      "verseKey": "92:14",
      "verseNumber": 14,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ"
    },
    {
      "id": 6073,
      "verseKey": "92:15",
      "verseNumber": 15,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى"
    },
    {
      "id": 6074,
      "verseKey": "92:16",
      "verseNumber": 16,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ"
    },
    {
      "id": 6075,
      "verseKey": "92:17",
      "verseNumber": 17,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى"
    },
    {
      "id": 6076,
      "verseKey": "92:18",
      "verseNumber": 18,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ"
    },
    {
      "id": 6077,
      "verseKey": "92:19",
      "verseNumber": 19,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ"
    },
    {
      "id": 6078,
      "verseKey": "92:20",
      "verseNumber": 20,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ"
    },
    {
      "id": 6079,
      "verseKey": "92:21",
      "verseNumber": 21,
      "pageNumber": 596,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 536,
      "manzilNumber": 7,
      "text": "وَلَسَوْفَ يَرْضَىٰ"
    }
  ]
