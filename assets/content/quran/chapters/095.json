      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "text": "وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ"
    },
    {
      "id": 6102,
      "verseKey": "95:4",
