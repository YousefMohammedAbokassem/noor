      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 539,
      "manzilNumber": 7,
      "text": "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ"
    },
