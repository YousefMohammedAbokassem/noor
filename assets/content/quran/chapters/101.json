    },
    {
      "id": 6160,
      "verseKey": "101:3",
      "verseNumber": 3,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ"
    },
    {
      "id": 6161,
      "verseKey": "101:4",
      "verseNumber": 4,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ"
    },
    {
      "id": 6162,
      "verseKey": "101:5",
      "verseNumber": 5,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ"
    },
    {
      "id": 6163,
      "verseKey": "101:6",
      "verseNumber": 6,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ"
    },
    {
      "id": 6164,
      "verseKey": "101:7",
      "verseNumber": 7,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ"
    },
    {
      "id": 6165,
      "verseKey": "101:8",
      "verseNumber": 8,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ"
    },
    {
      "id": 6166,
      "verseKey": "101:9",
      "verseNumber": 9,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "فَأُمُّهُۥ هَاوِيَةٌ"
    },
    {
      "id": 6167,
      "verseKey": "101:10",
      "verseNumber": 10,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ"
    },
    {
      "id": 6168,
      "verseKey": "101:11",
      "verseNumber": 11,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 545,
      "manzilNumber": 7,
      "text": "نَارٌ حَامِيَةٌۢ"
    }
  ]
