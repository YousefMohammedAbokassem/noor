  "verses": [
    {
      "id": 4415,
      "verseKey": "44:1",
      "verseNumber": 1,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": " حمٓ"
    },
    {
      "id": 4416,
      "verseKey": "44:2",
      "verseNumber": 2,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَٱلْكِتَـٰبِ ٱلْمُبِينِ"
    },
    {
      "id": 4417,
      "verseKey": "44:3",
      "verseNumber": 3,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "إِنَّآ أَنزَلْنَـٰهُ فِى لَيْلَةٍ مُّبَـٰرَكَةٍ ۚ إِنَّا كُنَّا مُنذِرِينَ"
    },
    {
      "id": 4418,
      "verseKey": "44:4",
      "verseNumber": 4,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "فِيهَا يُفْرَقُ كُلُّ أَمْرٍ حَكِيمٍ"
    },
    {
      "id": 4419,
      "verseKey": "44:5",
      "verseNumber": 5,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "أَمْرًا مِّنْ عِندِنَآ ۚ إِنَّا كُنَّا مُرْسِلِينَ"
    },
    {
      "id": 4420,
      "verseKey": "44:6",
      "verseNumber": 6,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "رَحْمَةً مِّن رَّبِّكَ ۚ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ"
    },
    {
      "id": 4421,
      "verseKey": "44:7",
      "verseNumber": 7,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "رَبِّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَآ ۖ إِن كُنتُم مُّوقِنِينَ"
    },
    {
      "id": 4422,
      "verseKey": "44:8",
      "verseNumber": 8,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "لَآ إِلَـٰهَ إِلَّا هُوَ يُحْىِۦ وَيُمِيتُ ۖ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ"
    },
    {
      "id": 4423,
      "verseKey": "44:9",
      "verseNumber": 9,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "بَلْ هُمْ فِى شَكٍّ يَلْعَبُونَ"
    },
    {
      "id": 4424,
      "verseKey": "44:10",
      "verseNumber": 10,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "فَٱرْتَقِبْ يَوْمَ تَأْتِى ٱلسَّمَآءُ بِدُخَانٍ مُّبِينٍ"
    },
    {
      "id": 4425,
      "verseKey": "44:11",
      "verseNumber": 11,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "يَغْشَى ٱلنَّاسَ ۖ هَـٰذَا عَذَابٌ أَلِيمٌ"
    },
    {
      "id": 4426,
      "verseKey": "44:12",
      "verseNumber": 12,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "رَّبَّنَا ٱكْشِفْ عَنَّا ٱلْعَذَابَ إِنَّا مُؤْمِنُونَ"
    },
    {
      "id": 4427,
      "verseKey": "44:13",
      "verseNumber": 13,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "أَنَّىٰ لَهُمُ ٱلذِّكْرَىٰ وَقَدْ جَآءَهُمْ رَسُولٌ مُّبِينٌ"
    },
    {
      "id": 4428,
      "verseKey": "44:14",
      "verseNumber": 14,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "ثُمَّ تَوَلَّوْا۟ عَنْهُ وَقَالُوا۟ مُعَلَّمٌ مَّجْنُونٌ"
    },
    {
      "id": 4429,
      "verseKey": "44:15",
      "verseNumber": 15,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "إِنَّا كَاشِفُوا۟ ٱلْعَذَابِ قَلِيلًا ۚ إِنَّكُمْ عَآئِدُونَ"
    },
    {
      "id": 4430,
      "verseKey": "44:16",
      "verseNumber": 16,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 198,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "يَوْمَ نَبْطِشُ ٱلْبَطْشَةَ ٱلْكُبْرَىٰٓ إِنَّا مُنتَقِمُونَ"
    },
    {
      "id": 4431,
      "verseKey": "44:17",
      "verseNumber": 17,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "۞ وَلَقَدْ فَتَنَّا قَبْلَهُمْ قَوْمَ فِرْعَوْنَ وَجَآءَهُمْ رَسُولٌ كَرِيمٌ"
    },
    {
      "id": 4432,
      "verseKey": "44:18",
      "verseNumber": 18,
      "pageNumber": 496,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "أَنْ أَدُّوٓا۟ إِلَىَّ عِبَادَ ٱللَّهِ ۖ إِنِّى لَكُمْ رَسُولٌ أَمِينٌ"
    },
    {
      "id": 4433,
      "verseKey": "44:19",
      "verseNumber": 19,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَأَن لَّا تَعْلُوا۟ عَلَى ٱللَّهِ ۖ إِنِّىٓ ءَاتِيكُم بِسُلْطَـٰنٍ مُّبِينٍ"
    },
    {
      "id": 4434,
      "verseKey": "44:20",
      "verseNumber": 20,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَإِنِّى عُذْتُ بِرَبِّى وَرَبِّكُمْ أَن تَرْجُمُونِ"
    },
    {
      "id": 4435,
      "verseKey": "44:21",
      "verseNumber": 21,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَإِن لَّمْ تُؤْمِنُوا۟ لِى فَٱعْتَزِلُونِ"
    },
    {
      "id": 4436,
      "verseKey": "44:22",
      "verseNumber": 22,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "فَدَعَا رَبَّهُۥٓ أَنَّ هَـٰٓؤُلَآءِ قَوْمٌ مُّجْرِمُونَ"
    },
    {
      "id": 4437,
      "verseKey": "44:23",
      "verseNumber": 23,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "فَأَسْرِ بِعِبَادِى لَيْلًا إِنَّكُم مُّتَّبَعُونَ"
    },
    {
      "id": 4438,
      "verseKey": "44:24",
      "verseNumber": 24,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَٱتْرُكِ ٱلْبَحْرَ رَهْوًا ۖ إِنَّهُمْ جُندٌ مُّغْرَقُونَ"
    },
    {
      "id": 4439,
      "verseKey": "44:25",
      "verseNumber": 25,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "كَمْ تَرَكُوا۟ مِن جَنَّـٰتٍ وَعُيُونٍ"
    },
    {
      "id": 4440,
      "verseKey": "44:26",
      "verseNumber": 26,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَزُرُوعٍ وَمَقَامٍ كَرِيمٍ"
    },
    {
      "id": 4441,
      "verseKey": "44:27",
      "verseNumber": 27,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "وَنَعْمَةٍ كَانُوا۟ فِيهَا فَـٰكِهِينَ"
    },
    {
      "id": 4442,
      "verseKey": "44:28",
      "verseNumber": 28,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "كَذَٰلِكَ ۖ وَأَوْرَثْنَـٰهَا قَوْمًا ءَاخَرِينَ"
    },
    {
      "id": 4443,
      "verseKey": "44:29",
      "verseNumber": 29,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 433,
      "manzilNumber": 6,
      "text": "فَمَا بَكَتْ عَلَيْهِمُ ٱلسَّمَآءُ وَٱلْأَرْضُ وَمَا كَانُوا۟ مُنظَرِينَ"
    },
    {
      "id": 4444,
      "verseKey": "44:30",
      "verseNumber": 30,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "وَلَقَدْ نَجَّيْنَا بَنِىٓ إِسْرَٰٓءِيلَ مِنَ ٱلْعَذَابِ ٱلْمُهِينِ"
    },
    {
      "id": 4445,
      "verseKey": "44:31",
      "verseNumber": 31,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "مِن فِرْعَوْنَ ۚ إِنَّهُۥ كَانَ عَالِيًا مِّنَ ٱلْمُسْرِفِينَ"
    },
    {
      "id": 4446,
      "verseKey": "44:32",
      "verseNumber": 32,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "وَلَقَدِ ٱخْتَرْنَـٰهُمْ عَلَىٰ عِلْمٍ عَلَى ٱلْعَـٰلَمِينَ"
    },
    {
      "id": 4447,
      "verseKey": "44:33",
      "verseNumber": 33,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "وَءَاتَيْنَـٰهُم مِّنَ ٱلْـَٔايَـٰتِ مَا فِيهِ بَلَـٰٓؤٌا۟ مُّبِينٌ"
    },
    {
      "id": 4448,
      "verseKey": "44:34",
      "verseNumber": 34,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "إِنَّ هَـٰٓؤُلَآءِ لَيَقُولُونَ"
    },
    {
      "id": 4449,
      "verseKey": "44:35",
      "verseNumber": 35,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "إِنْ هِىَ إِلَّا مَوْتَتُنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُنشَرِينَ"
    },
    {
      "id": 4450,
      "verseKey": "44:36",
      "verseNumber": 36,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "فَأْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَـٰدِقِينَ"
    },
    {
      "id": 4451,
      "verseKey": "44:37",
      "verseNumber": 37,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "أَهُمْ خَيْرٌ أَمْ قَوْمُ تُبَّعٍ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ أَهْلَكْنَـٰهُمْ ۖ إِنَّهُمْ كَانُوا۟ مُجْرِمِينَ"
    },
    {
      "id": 4452,
      "verseKey": "44:38",
      "verseNumber": 38,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "وَمَا خَلَقْنَا ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا لَـٰعِبِينَ"
    },
    {
      "id": 4453,
      "verseKey": "44:39",
      "verseNumber": 39,
      "pageNumber": 497,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "مَا خَلَقْنَـٰهُمَآ إِلَّا بِٱلْحَقِّ وَلَـٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ"
    },
    {
      "id": 4454,
      "verseKey": "44:40",
      "verseNumber": 40,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "إِنَّ يَوْمَ ٱلْفَصْلِ مِيقَـٰتُهُمْ أَجْمَعِينَ"
    },
    {
      "id": 4455,
      "verseKey": "44:41",
      "verseNumber": 41,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "يَوْمَ لَا يُغْنِى مَوْلًى عَن مَّوْلًى شَيْـًٔا وَلَا هُمْ يُنصَرُونَ"
    },
    {
      "id": 4456,
      "verseKey": "44:42",
      "verseNumber": 42,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 434,
      "manzilNumber": 6,
      "text": "إِلَّا مَن رَّحِمَ ٱللَّهُ ۚ إِنَّهُۥ هُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"
    },
    {
      "id": 4457,
      "verseKey": "44:43",
      "verseNumber": 43,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "إِنَّ شَجَرَتَ ٱلزَّقُّومِ"
    },
    {
      "id": 4458,
      "verseKey": "44:44",
      "verseNumber": 44,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "طَعَامُ ٱلْأَثِيمِ"
    },
    {
      "id": 4459,
      "verseKey": "44:45",
      "verseNumber": 45,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "كَٱلْمُهْلِ يَغْلِى فِى ٱلْبُطُونِ"
    },
    {
      "id": 4460,
      "verseKey": "44:46",
      "verseNumber": 46,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "كَغَلْىِ ٱلْحَمِيمِ"
    },
    {
      "id": 4461,
      "verseKey": "44:47",
      "verseNumber": 47,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "خُذُوهُ فَٱعْتِلُوهُ إِلَىٰ سَوَآءِ ٱلْجَحِيمِ"
    },
    {
      "id": 4462,
      "verseKey": "44:48",
      "verseNumber": 48,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "ثُمَّ صُبُّوا۟ فَوْقَ رَأْسِهِۦ مِنْ عَذَابِ ٱلْحَمِيمِ"
    },
    {
      "id": 4463,
      "verseKey": "44:49",
      "verseNumber": 49,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "ذُقْ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْكَرِيمُ"
    },
    {
      "id": 4464,
      "verseKey": "44:50",
      "verseNumber": 50,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمْتَرُونَ"
    },
    {
      "id": 4465,
      "verseKey": "44:51",
      "verseNumber": 51,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "إِنَّ ٱلْمُتَّقِينَ فِى مَقَامٍ أَمِينٍ"
    },
    {
      "id": 4466,
      "verseKey": "44:52",
      "verseNumber": 52,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "فِى جَنَّـٰتٍ وَعُيُونٍ"
    },
    {
      "id": 4467,
      "verseKey": "44:53",
      "verseNumber": 53,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "يَلْبَسُونَ مِن سُندُسٍ وَإِسْتَبْرَقٍ مُّتَقَـٰبِلِينَ"
    },
    {
      "id": 4468,
      "verseKey": "44:54",
      "verseNumber": 54,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "كَذَٰلِكَ وَزَوَّجْنَـٰهُم بِحُورٍ عِينٍ"
    },
    {
      "id": 4469,
      "verseKey": "44:55",
      "verseNumber": 55,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "يَدْعُونَ فِيهَا بِكُلِّ فَـٰكِهَةٍ ءَامِنِينَ"
    },
    {
      "id": 4470,
      "verseKey": "44:56",
      "verseNumber": 56,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "لَا يَذُوقُونَ فِيهَا ٱلْمَوْتَ إِلَّا ٱلْمَوْتَةَ ٱلْأُولَىٰ ۖ وَوَقَىٰهُمْ عَذَابَ ٱلْجَحِيمِ"
    },
    {
      "id": 4471,
      "verseKey": "44:57",
      "verseNumber": 57,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "فَضْلًا مِّن رَّبِّكَ ۚ ذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْعَظِيمُ"
    },
    {
      "id": 4472,
      "verseKey": "44:58",
      "verseNumber": 58,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "فَإِنَّمَا يَسَّرْنَـٰهُ بِلِسَانِكَ لَعَلَّهُمْ يَتَذَكَّرُونَ"
    },
    {
      "id": 4473,
      "verseKey": "44:59",
      "verseNumber": 59,
      "pageNumber": 498,
      "juzNumber": 25,
      "hizbNumber": 50,
      "rubElHizbNumber": 199,
      "rukuNumber": 435,
      "manzilNumber": 6,
      "text": "فَٱرْتَقِبْ إِنَّهُم مُّرْتَقِبُونَ"
    }
  ]
}
