      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": " وَٱلْعَـٰدِيَـٰتِ ضَبْحًا"
    },
    {
      "id": 6148,
      "verseKey": "100:2",
      "verseNumber": 2,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "فَٱلْمُورِيَـٰتِ قَدْحًا"
    },
    {
      "id": 6149,
      "verseKey": "100:3",
      "verseNumber": 3,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "فَٱلْمُغِيرَٰتِ صُبْحًا"
    },
    {
      "id": 6150,
      "verseKey": "100:4",
      "verseNumber": 4,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "فَأَثَرْنَ بِهِۦ نَقْعًا"
    },
    {
      "id": 6151,
      "verseKey": "100:5",
      "verseNumber": 5,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "فَوَسَطْنَ بِهِۦ جَمْعًا"
    },
    {
      "id": 6152,
      "verseKey": "100:6",
      "verseNumber": 6,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ"
    },
    {
      "id": 6153,
      "verseKey": "100:7",
      "verseNumber": 7,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ"
    },
    {
      "id": 6154,
      "verseKey": "100:8",
      "verseNumber": 8,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ"
    },
    {
      "id": 6155,
      "verseKey": "100:9",
      "verseNumber": 9,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ"
    },
    {
      "id": 6156,
      "verseKey": "100:10",
      "verseNumber": 10,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ"
    },
    {
      "id": 6157,
      "verseKey": "100:11",
      "verseNumber": 11,
      "pageNumber": 600,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 544,
      "manzilNumber": 7,
      "text": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ"
    }
  ]
}
