{
  "id": 83,
  "nameAr": "المطففين",
  "nameSimple": "Al-Mutaffifin",
  "nameComplex": "Al-Muţaffifīn",
  "translatedName": "The Defrauding",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 86,
  "versesCount": 36,
  "bismillahPre": true,
  "startPage": 587,
  "endPage": 589,
  "verses": [
    {
      "id": 5849,
      "verseKey": "83:1",
      "verseNumber": 1,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": " وَيْلٌ لِّلْمُطَفِّفِينَ"
    },
    {
      "id": 5850,
      "verseKey": "83:2",
      "verseNumber": 2,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ"
    },
    {
      "id": 5851,
      "verseKey": "83:3",
      "verseNumber": 3,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ"
    },
    {
      "id": 5852,
      "verseKey": "83:4",
      "verseNumber": 4,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "أَلَا يَظُنُّ أُو۟لَـٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ"
    },
    {
      "id": 5853,
      "verseKey": "83:5",
      "verseNumber": 5,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "لِيَوْمٍ عَظِيمٍ"
    },
    {
      "id": 5854,
      "verseKey": "83:6",
      "verseNumber": 6,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلْعَـٰلَمِينَ"
    },
    {
      "id": 5855,
      "verseKey": "83:7",
      "verseNumber": 7,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْفُجَّارِ لَفِى سِجِّينٍ"
    },
    {
      "id": 5856,
      "verseKey": "83:8",
      "verseNumber": 8,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا سِجِّينٌ"
    },
    {
      "id": 5857,
      "verseKey": "83:9",
      "verseNumber": 9,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "كِتَـٰبٌ مَّرْقُومٌ"
    },
    {
      "id": 5858,
      "verseKey": "83:10",
      "verseNumber": 10,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "id": 5859,
      "verseKey": "83:11",
      "verseNumber": 11,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ"
    },
    {
      "id": 5860,
      "verseKey": "83:12",
      "verseNumber": 12,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ"
    },
    {
      "id": 5861,
      "verseKey": "83:13",
      "verseNumber": 13,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ"
    },
    {
      "id": 5862,
      "verseKey": "83:14",
      "verseNumber": 14,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ"
    },
    {
      "id": 5863,
      "verseKey": "83:15",
      "verseNumber": 15,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ"
    },
    {
      "id": 5864,
      "verseKey": "83:16",
      "verseNumber": 16,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ"
    },
    {
      "id": 5865,
      "verseKey": "83:17",
      "verseNumber": 17,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "ثُمَّ يُقَالُ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ"
    },
    {
      "id": 5866,
      "verseKey": "83:18",
      "verseNumber": 18,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْأَبْرَارِ لَفِى عِلِّيِّينَ"
    },
    {
      "id": 5867,
      "verseKey": "83:19",
      "verseNumber": 19,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا عِلِّيُّونَ"
    },
    {
      "id": 5868,
      "verseKey": "83:20",
      "verseNumber": 20,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "كِتَـٰبٌ مَّرْقُومٌ"
    },
    {
      "id": 5869,
      "verseKey": "83:21",
      "verseNumber": 21,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "يَشْهَدُهُ ٱلْمُقَرَّبُونَ"
    },
    {
      "id": 5870,
      "verseKey": "83:22",
      "verseNumber": 22,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ"
    },
    {
      "id": 5871,
      "verseKey": "83:23",
      "verseNumber": 23,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ"
    },
    {
      "id": 5872,
      "verseKey": "83:24",
      "verseNumber": 24,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ"
    },
    {
      "id": 5873,
      "verseKey": "83:25",
      "verseNumber": 25,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ"
    },
    {
      "id": 5874,
      "verseKey": "83:26",
      "verseNumber": 26,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "خِتَـٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَـٰفِسُونَ"
    },
    {
      "id": 5875,
      "verseKey": "83:27",
      "verseNumber": 27,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَمِزَاجُهُۥ مِن تَسْنِيمٍ"
    },
    {
      "id": 5876,
      "verseKey": "83:28",
      "verseNumber": 28,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ"
    },
    {
      "id": 5877,
      "verseKey": "83:29",
      "verseNumber": 29,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ"
    },
    {
      "id": 5878,
      "verseKey": "83:30",
      "verseNumber": 30,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ"
    },
    {
      "id": 5879,
      "verseKey": "83:31",
      "verseNumber": 31,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ"
    },
    {
      "id": 5880,
      "verseKey": "83:32",
      "verseNumber": 32,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَإِذَا رَأَوْهُمْ قَالُوٓا۟ إِنَّ هَـٰٓؤُلَآءِ لَضَآلُّونَ"
    },
    {
      "id": 5881,
      "verseKey": "83:33",
      "verseNumber": 33,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَـٰفِظِينَ"
    },
    {
      "id": 5882,
      "verseKey": "83:34",
      "verseNumber": 34,
      "pageNumber": 588,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ"
    },
    {
      "id": 5883,
      "verseKey": "83:35",
      "verseNumber": 35,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ"
    },
    {
      "id": 5884,
      "verseKey": "83:36",
      "verseNumber": 36,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 527,
      "manzilNumber": 7,
      "text": "هَلْ ثُوِّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ"
    }
  ]
}
