      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": " إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ"
    },
    {
      "id": 5831,
      "verseKey": "82:2",
      "verseNumber": 2,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ"
    },
    {
      "id": 5832,
      "verseKey": "82:3",
      "verseNumber": 3,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ"
    },
    {
      "id": 5833,
      "verseKey": "82:4",
      "verseNumber": 4,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ"
    },
    {
      "id": 5834,
      "verseKey": "82:5",
      "verseNumber": 5,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ"
    },
    {
      "id": 5835,
      "verseKey": "82:6",
      "verseNumber": 6,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ"
    },
    {
      "id": 5836,
      "verseKey": "82:7",
      "verseNumber": 7,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ"
    },
    {
      "id": 5837,
      "verseKey": "82:8",
      "verseNumber": 8,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "فِىٓ أَىِّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ"
    },
    {
      "id": 5838,
      "verseKey": "82:9",
      "verseNumber": 9,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ"
    },
    {
      "id": 5839,
      "verseKey": "82:10",
      "verseNumber": 10,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَإِنَّ عَلَيْكُمْ لَحَـٰفِظِينَ"
    },
    {
      "id": 5840,
      "verseKey": "82:11",
      "verseNumber": 11,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "كِرَامًا كَـٰتِبِينَ"
    },
    {
      "id": 5841,
      "verseKey": "82:12",
      "verseNumber": 12,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "يَعْلَمُونَ مَا تَفْعَلُونَ"
    },
    {
      "id": 5842,
      "verseKey": "82:13",
      "verseNumber": 13,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ"
    },
    {
      "id": 5843,
      "verseKey": "82:14",
      "verseNumber": 14,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ"
    },
    {
      "id": 5844,
      "verseKey": "82:15",
      "verseNumber": 15,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ"
    },
    {
      "id": 5845,
      "verseKey": "82:16",
      "verseNumber": 16,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ"
    },
    {
      "id": 5846,
      "verseKey": "82:17",
      "verseNumber": 17,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ"
    },
    {
      "id": 5847,
      "verseKey": "82:18",
      "verseNumber": 18,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ"
    },
    {
      "id": 5848,
      "verseKey": "82:19",
      "verseNumber": 19,
      "pageNumber": 587,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 235,
      "rukuNumber": 526,
      "manzilNumber": 7,
      "text": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْـًٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍ لِّلَّهِ"
    }
  ]
