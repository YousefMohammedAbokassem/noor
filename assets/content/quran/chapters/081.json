    {
      "id": 5826,
      "verseKey": "81:26",
      "verseNumber": 26,
      "pageNumber": 586,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 525,
      "manzilNumber": 7,
      "text": "فَأَيْنَ تَذْهَبُونَ"
