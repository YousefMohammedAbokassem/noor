      "verseKey": "81:22",
      "verseNumber": 22,
      "pageNumber": 586,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 525,
      "manzilNumber": 7,
      "text": "وَمَا صَاحِبُكُم بِمَجْنُونٍ"
