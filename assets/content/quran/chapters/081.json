      "pageNumber": 586,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 525,
      "manzilNumber": 7,
      "text": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ"
