      "verseKey": "81:19",
      "verseNumber": 19,
      "pageNumber": 586,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 525,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ"
