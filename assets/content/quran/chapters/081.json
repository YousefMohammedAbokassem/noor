      "id": 5824,
      "verseKey": "81:24",
      "verseNumber": 24,
      "pageNumber": 586,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 525,
      "manzilNumber": 7,
      "text": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ"
