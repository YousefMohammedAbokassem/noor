    {
      "id": 5821,
      "verseKey": "81:21",
      "verseNumber": 21,
      "pageNumber": 586,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 525,
      "manzilNumber": 7,
