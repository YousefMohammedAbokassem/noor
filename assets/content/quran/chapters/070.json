{
  "id": 70,
  "nameAr": "المعارج",
  "nameSimple": "Al-Ma'arij",
  "nameComplex": "Al-Ma`ārij",
  "translatedName": "The Ascending Stairways",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 79,
  "versesCount": 44,
  "bismillahPre": true,
  "startPage": 568,
  "endPage": 570,
  "verses": [
    {
      "id": 5376,
      "verseKey": "70:1",
      "verseNumber": 1,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": " سَأَلَ سَآئِلٌۢ بِعَذَابٍ وَاقِعٍ"
    },
    {
      "id": 5377,
      "verseKey": "70:2",
      "verseNumber": 2,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "لِّلْكَـٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌ"
    },
    {
      "id": 5378,
      "verseKey": "70:3",
      "verseNumber": 3,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "مِّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ"
    },
    {
      "id": 5379,
      "verseKey": "70:4",
      "verseNumber": 4,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "تَعْرُجُ ٱلْمَلَـٰٓئِكَةُ وَٱلرُّوحُ إِلَيْهِ فِى يَوْمٍ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٍ"
    },
    {
      "id": 5380,
      "verseKey": "70:5",
      "verseNumber": 5,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "فَٱصْبِرْ صَبْرًا جَمِيلًا"
    },
    {
      "id": 5381,
      "verseKey": "70:6",
      "verseNumber": 6,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًا"
    },
    {
      "id": 5382,
      "verseKey": "70:7",
      "verseNumber": 7,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَنَرَىٰهُ قَرِيبًا"
    },
    {
      "id": 5383,
      "verseKey": "70:8",
      "verseNumber": 8,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ"
    },
    {
      "id": 5384,
      "verseKey": "70:9",
      "verseNumber": 9,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ"
    },
    {
      "id": 5385,
      "verseKey": "70:10",
      "verseNumber": 10,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيمًا"
    },
    {
      "id": 5386,
      "verseKey": "70:11",
      "verseNumber": 11,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ"
    },
    {
      "id": 5387,
      "verseKey": "70:12",
      "verseNumber": 12,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَصَـٰحِبَتِهِۦ وَأَخِيهِ"
    },
    {
      "id": 5388,
      "verseKey": "70:13",
      "verseNumber": 13,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ"
    },
    {
      "id": 5389,
      "verseKey": "70:14",
      "verseNumber": 14,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَمَن فِى ٱلْأَرْضِ جَمِيعًا ثُمَّ يُنجِيهِ"
    },
    {
      "id": 5390,
      "verseKey": "70:15",
      "verseNumber": 15,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "كَلَّآ ۖ إِنَّهَا لَظَىٰ"
    },
    {
      "id": 5391,
      "verseKey": "70:16",
      "verseNumber": 16,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "نَزَّاعَةً لِّلشَّوَىٰ"
    },
    {
      "id": 5392,
      "verseKey": "70:17",
      "verseNumber": 17,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ"
    },
    {
      "id": 5393,
      "verseKey": "70:18",
      "verseNumber": 18,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَجَمَعَ فَأَوْعَىٰٓ"
    },
    {
      "id": 5394,
      "verseKey": "70:19",
      "verseNumber": 19,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "۞ إِنَّ ٱلْإِنسَـٰنَ خُلِقَ هَلُوعًا"
    },
    {
      "id": 5395,
      "verseKey": "70:20",
      "verseNumber": 20,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًا"
    },
    {
      "id": 5396,
      "verseKey": "70:21",
      "verseNumber": 21,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا"
    },
    {
      "id": 5397,
      "verseKey": "70:22",
      "verseNumber": 22,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "إِلَّا ٱلْمُصَلِّينَ"
    },
    {
      "id": 5398,
      "verseKey": "70:23",
      "verseNumber": 23,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ"
    },
    {
      "id": 5399,
      "verseKey": "70:24",
      "verseNumber": 24,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّ مَّعْلُومٌ"
    },
    {
      "id": 5400,
      "verseKey": "70:25",
      "verseNumber": 25,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "لِّلسَّآئِلِ وَٱلْمَحْرُومِ"
    },
    {
      "id": 5401,
      "verseKey": "70:26",
      "verseNumber": 26,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ"
    },
    {
      "id": 5402,
      "verseKey": "70:27",
      "verseNumber": 27,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ"
    },
    {
      "id": 5403,
      "verseKey": "70:28",
      "verseNumber": 28,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ"
    },
    {
      "id": 5404,
      "verseKey": "70:29",
      "verseNumber": 29,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَـٰفِظُونَ"
    },
    {
      "id": 5405,
      "verseKey": "70:30",
      "verseNumber": 30,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "إِلَّا عَلَىٰٓ أَزْوَٰجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَـٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ"
    },
    {
      "id": 5406,
      "verseKey": "70:31",
      "verseNumber": 31,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَـٰٓئِكَ هُمُ ٱلْعَادُونَ"
    },
    {
      "id": 5407,
      "verseKey": "70:32",
      "verseNumber": 32,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ هُمْ لِأَمَـٰنَـٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ"
    },
    {
      "id": 5408,
      "verseKey": "70:33",
      "verseNumber": 33,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ هُم بِشَهَـٰدَٰتِهِمْ قَآئِمُونَ"
    },
    {
      "id": 5409,
      "verseKey": "70:34",
      "verseNumber": 34,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ"
    },
    {
      "id": 5410,
      "verseKey": "70:35",
      "verseNumber": 35,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 504,
      "manzilNumber": 7,
      "text": "أُو۟لَـٰٓئِكَ فِى جَنَّـٰتٍ مُّكْرَمُونَ"
    },
    {
      "id": 5411,
      "verseKey": "70:36",
      "verseNumber": 36,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "فَمَالِ ٱلَّذِينَ كَفَرُوا۟ قِبَلَكَ مُهْطِعِينَ"
    },
    {
      "id": 5412,
      "verseKey": "70:37",
      "verseNumber": 37,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ"
    },
    {
      "id": 5413,
      "verseKey": "70:38",
      "verseNumber": 38,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "أَيَطْمَعُ كُلُّ ٱمْرِئٍ مِّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍ"
    },
    {
      "id": 5414,
      "verseKey": "70:39",
      "verseNumber": 39,
      "pageNumber": 569,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "كَلَّآ ۖ إِنَّا خَلَقْنَـٰهُم مِّمَّا يَعْلَمُونَ"
    },
    {
      "id": 5415,
      "verseKey": "70:40",
      "verseNumber": 40,
      "pageNumber": 570,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "فَلَآ أُقْسِمُ بِرَبِّ ٱلْمَشَـٰرِقِ وَٱلْمَغَـٰرِبِ إِنَّا لَقَـٰدِرُونَ"
    },
    {
      "id": 5416,
      "verseKey": "70:41",
      "verseNumber": 41,
      "pageNumber": 570,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "عَلَىٰٓ أَن نُّبَدِّلَ خَيْرًا مِّنْهُمْ وَمَا نَحْنُ بِمَسْبُوقِينَ"
    },
    {
      "id": 5417,
      "verseKey": "70:42",
      "verseNumber": 42,
      "pageNumber": 570,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "فَذَرْهُمْ يَخُوضُوا۟ وَيَلْعَبُوا۟ حَتَّىٰ يُلَـٰقُوا۟ يَوْمَهُمُ ٱلَّذِى يُوعَدُونَ"
    },
    {
      "id": 5418,
      "verseKey": "70:43",
      "verseNumber": 43,
      "pageNumber": 570,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "يَوْمَ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ سِرَاعًا كَأَنَّهُمْ إِلَىٰ نُصُبٍ يُوفِضُونَ"
    },
    {
      "id": 5419,
      "verseKey": "70:44",
      "verseNumber": 44,
      "pageNumber": 570,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 228,
      "rukuNumber": 505,
      "manzilNumber": 7,
      "text": "خَـٰشِعَةً أَبْصَـٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ۚ ذَٰلِكَ ٱلْيَوْمُ ٱلَّذِى كَانُوا۟ يُوعَدُونَ"
    }
  ]
}
