      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": " لَآ أُقْسِمُ بِهَـٰذَا ٱلْبَلَدِ"
    },
    {
      "id": 6025,
      "verseKey": "90:2",
      "verseNumber": 2,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "وَأَنتَ حِلٌّۢ بِهَـٰذَا ٱلْبَلَدِ"
    },
    {
      "id": 6026,
      "verseKey": "90:3",
      "verseNumber": 3,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "وَوَالِدٍ وَمَا وَلَدَ"
    },
    {
      "id": 6027,
      "verseKey": "90:4",
      "verseNumber": 4,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِى كَبَدٍ"
    },
    {
      "id": 6028,
      "verseKey": "90:5",
      "verseNumber": 5,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ"
    },
    {
      "id": 6029,
      "verseKey": "90:6",
      "verseNumber": 6,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا"
    },
    {
      "id": 6030,
      "verseKey": "90:7",
      "verseNumber": 7,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ"
    },
    {
      "id": 6031,
      "verseKey": "90:8",
      "verseNumber": 8,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ"
    },
    {
      "id": 6032,
      "verseKey": "90:9",
      "verseNumber": 9,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "وَلِسَانًا وَشَفَتَيْنِ"
    },
    {
      "id": 6033,
      "verseKey": "90:10",
      "verseNumber": 10,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "وَهَدَيْنَـٰهُ ٱلنَّجْدَيْنِ"
    },
    {
      "id": 6034,
      "verseKey": "90:11",
      "verseNumber": 11,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ"
    },
    {
      "id": 6035,
      "verseKey": "90:12",
      "verseNumber": 12,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْعَقَبَةُ"
    },
    {
      "id": 6036,
      "verseKey": "90:13",
      "verseNumber": 13,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "فَكُّ رَقَبَةٍ"
    },
    {
      "id": 6037,
      "verseKey": "90:14",
      "verseNumber": 14,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "أَوْ إِطْعَـٰمٌ فِى يَوْمٍ ذِى مَسْغَبَةٍ"
    },
    {
      "id": 6038,
      "verseKey": "90:15",
      "verseNumber": 15,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "يَتِيمًا ذَا مَقْرَبَةٍ"
    },
    {
      "id": 6039,
      "verseKey": "90:16",
      "verseNumber": 16,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ"
    },
    {
      "id": 6040,
      "verseKey": "90:17",
      "verseNumber": 17,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ"
    },
    {
      "id": 6041,
      "verseKey": "90:18",
      "verseNumber": 18,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "أُو۟لَـٰٓئِكَ أَصْحَـٰبُ ٱلْمَيْمَنَةِ"
    },
    {
      "id": 6042,
      "verseKey": "90:19",
      "verseNumber": 19,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَـٰتِنَا هُمْ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ"
    },
    {
      "id": 6043,
      "verseKey": "90:20",
      "verseNumber": 20,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 534,
      "manzilNumber": 7,
      "text": "عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌۢ"
    }
  ]
}
