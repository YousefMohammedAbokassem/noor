      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": " وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ"
    },
    {
      "id": 6181,
      "verseKey": "104:2",
      "verseNumber": 2,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ"
    },
    {
      "id": 6182,
      "verseKey": "104:3",
      "verseNumber": 3,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ"
    },
    {
      "id": 6183,
      "verseKey": "104:4",
      "verseNumber": 4,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ"
    },
    {
      "id": 6184,
      "verseKey": "104:5",
      "verseNumber": 5,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ"
    },
    {
      "id": 6185,
      "verseKey": "104:6",
      "verseNumber": 6,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ"
    },
    {
      "id": 6186,
      "verseKey": "104:7",
      "verseNumber": 7,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ"
    },
    {
      "id": 6187,
      "verseKey": "104:8",
      "verseNumber": 8,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ"
    },
    {
      "id": 6188,
      "verseKey": "104:9",
      "verseNumber": 9,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 548,
      "manzilNumber": 7,
      "text": "فِى عَمَدٍ مُّمَدَّدَةٍۭ"
    }
  ]
