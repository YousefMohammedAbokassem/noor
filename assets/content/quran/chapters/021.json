{
  "id": 21,
  "nameAr": "الأنبياء",
  "nameSimple": "Al-Anbya",
  "nameComplex": "Al-'Anbyā",
  "translatedName": "The Prophets",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 73,
  "versesCount": 112,
  "bismillahPre": true,
  "startPage": 322,
  "endPage": 331,
  "verses": [
    {
      "id": 2484,
      "verseKey": "21:1",
      "verseNumber": 1,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": " ٱقْتَرَبَ لِلنَّاسِ حِسَابُهُمْ وَهُمْ فِى غَفْلَةٍ مُّعْرِضُونَ"
    },
    {
      "id": 2485,
      "verseKey": "21:2",
      "verseNumber": 2,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "مَا يَأْتِيهِم مِّن ذِكْرٍ مِّن رَّبِّهِم مُّحْدَثٍ إِلَّا ٱسْتَمَعُوهُ وَهُمْ يَلْعَبُونَ"
    },
    {
      "id": 2486,
      "verseKey": "21:3",
      "verseNumber": 3,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "لَاهِيَةً قُلُوبُهُمْ ۗ وَأَسَرُّوا۟ ٱلنَّجْوَى ٱلَّذِينَ ظَلَمُوا۟ هَلْ هَـٰذَآ إِلَّا بَشَرٌ مِّثْلُكُمْ ۖ أَفَتَأْتُونَ ٱلسِّحْرَ وَأَنتُمْ تُبْصِرُونَ"
    },
    {
      "id": 2487,
      "verseKey": "21:4",
      "verseNumber": 4,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "قَالَ رَبِّى يَعْلَمُ ٱلْقَوْلَ فِى ٱلسَّمَآءِ وَٱلْأَرْضِ ۖ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ"
    },
    {
      "id": 2488,
      "verseKey": "21:5",
      "verseNumber": 5,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "بَلْ قَالُوٓا۟ أَضْغَـٰثُ أَحْلَـٰمٍۭ بَلِ ٱفْتَرَىٰهُ بَلْ هُوَ شَاعِرٌ فَلْيَأْتِنَا بِـَٔايَةٍ كَمَآ أُرْسِلَ ٱلْأَوَّلُونَ"
    },
    {
      "id": 2489,
      "verseKey": "21:6",
      "verseNumber": 6,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "مَآ ءَامَنَتْ قَبْلَهُم مِّن قَرْيَةٍ أَهْلَكْنَـٰهَآ ۖ أَفَهُمْ يُؤْمِنُونَ"
    },
    {
      "id": 2490,
      "verseKey": "21:7",
      "verseNumber": 7,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "وَمَآ أَرْسَلْنَا قَبْلَكَ إِلَّا رِجَالًا نُّوحِىٓ إِلَيْهِمْ ۖ فَسْـَٔلُوٓا۟ أَهْلَ ٱلذِّكْرِ إِن كُنتُمْ لَا تَعْلَمُونَ"
    },
    {
      "id": 2491,
      "verseKey": "21:8",
      "verseNumber": 8,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "وَمَا جَعَلْنَـٰهُمْ جَسَدًا لَّا يَأْكُلُونَ ٱلطَّعَامَ وَمَا كَانُوا۟ خَـٰلِدِينَ"
    },
    {
      "id": 2492,
      "verseKey": "21:9",
      "verseNumber": 9,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "ثُمَّ صَدَقْنَـٰهُمُ ٱلْوَعْدَ فَأَنجَيْنَـٰهُمْ وَمَن نَّشَآءُ وَأَهْلَكْنَا ٱلْمُسْرِفِينَ"
    },
    {
      "id": 2493,
      "verseKey": "21:10",
      "verseNumber": 10,
      "pageNumber": 322,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 278,
      "manzilNumber": 4,
      "text": "لَقَدْ أَنزَلْنَآ إِلَيْكُمْ كِتَـٰبًا فِيهِ ذِكْرُكُمْ ۖ أَفَلَا تَعْقِلُونَ"
    },
    {
      "id": 2494,
      "verseKey": "21:11",
      "verseNumber": 11,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "وَكَمْ قَصَمْنَا مِن قَرْيَةٍ كَانَتْ ظَالِمَةً وَأَنشَأْنَا بَعْدَهَا قَوْمًا ءَاخَرِينَ"
    },
    {
      "id": 2495,
      "verseKey": "21:12",
      "verseNumber": 12,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "فَلَمَّآ أَحَسُّوا۟ بَأْسَنَآ إِذَا هُم مِّنْهَا يَرْكُضُونَ"
    },
    {
      "id": 2496,
      "verseKey": "21:13",
      "verseNumber": 13,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "لَا تَرْكُضُوا۟ وَٱرْجِعُوٓا۟ إِلَىٰ مَآ أُتْرِفْتُمْ فِيهِ وَمَسَـٰكِنِكُمْ لَعَلَّكُمْ تُسْـَٔلُونَ"
    },
    {
      "id": 2497,
      "verseKey": "21:14",
      "verseNumber": 14,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "قَالُوا۟ يَـٰوَيْلَنَآ إِنَّا كُنَّا ظَـٰلِمِينَ"
    },
    {
      "id": 2498,
      "verseKey": "21:15",
      "verseNumber": 15,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "فَمَا زَالَت تِّلْكَ دَعْوَىٰهُمْ حَتَّىٰ جَعَلْنَـٰهُمْ حَصِيدًا خَـٰمِدِينَ"
    },
    {
      "id": 2499,
      "verseKey": "21:16",
      "verseNumber": 16,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "وَمَا خَلَقْنَا ٱلسَّمَآءَ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا لَـٰعِبِينَ"
    },
    {
      "id": 2500,
      "verseKey": "21:17",
      "verseNumber": 17,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "لَوْ أَرَدْنَآ أَن نَّتَّخِذَ لَهْوًا لَّٱتَّخَذْنَـٰهُ مِن لَّدُنَّآ إِن كُنَّا فَـٰعِلِينَ"
    },
    {
      "id": 2501,
      "verseKey": "21:18",
      "verseNumber": 18,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "بَلْ نَقْذِفُ بِٱلْحَقِّ عَلَى ٱلْبَـٰطِلِ فَيَدْمَغُهُۥ فَإِذَا هُوَ زَاهِقٌ ۚ وَلَكُمُ ٱلْوَيْلُ مِمَّا تَصِفُونَ"
    },
    {
      "id": 2502,
      "verseKey": "21:19",
      "verseNumber": 19,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "وَلَهُۥ مَن فِى ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَمَنْ عِندَهُۥ لَا يَسْتَكْبِرُونَ عَنْ عِبَادَتِهِۦ وَلَا يَسْتَحْسِرُونَ"
    },
    {
      "id": 2503,
      "verseKey": "21:20",
      "verseNumber": 20,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "يُسَبِّحُونَ ٱلَّيْلَ وَٱلنَّهَارَ لَا يَفْتُرُونَ"
    },
    {
      "id": 2504,
      "verseKey": "21:21",
      "verseNumber": 21,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "أَمِ ٱتَّخَذُوٓا۟ ءَالِهَةً مِّنَ ٱلْأَرْضِ هُمْ يُنشِرُونَ"
    },
    {
      "id": 2505,
      "verseKey": "21:22",
      "verseNumber": 22,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "لَوْ كَانَ فِيهِمَآ ءَالِهَةٌ إِلَّا ٱللَّهُ لَفَسَدَتَا ۚ فَسُبْحَـٰنَ ٱللَّهِ رَبِّ ٱلْعَرْشِ عَمَّا يَصِفُونَ"
    },
    {
      "id": 2506,
      "verseKey": "21:23",
      "verseNumber": 23,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "لَا يُسْـَٔلُ عَمَّا يَفْعَلُ وَهُمْ يُسْـَٔلُونَ"
    },
    {
      "id": 2507,
      "verseKey": "21:24",
      "verseNumber": 24,
      "pageNumber": 323,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "أَمِ ٱتَّخَذُوا۟ مِن دُونِهِۦٓ ءَالِهَةً ۖ قُلْ هَاتُوا۟ بُرْهَـٰنَكُمْ ۖ هَـٰذَا ذِكْرُ مَن مَّعِىَ وَذِكْرُ مَن قَبْلِى ۗ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ ٱلْحَقَّ ۖ فَهُم مُّعْرِضُونَ"
    },
    {
      "id": 2508,
      "verseKey": "21:25",
      "verseNumber": 25,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "وَمَآ أَرْسَلْنَا مِن قَبْلِكَ مِن رَّسُولٍ إِلَّا نُوحِىٓ إِلَيْهِ أَنَّهُۥ لَآ إِلَـٰهَ إِلَّآ أَنَا۠ فَٱعْبُدُونِ"
    },
    {
      "id": 2509,
      "verseKey": "21:26",
      "verseNumber": 26,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "وَقَالُوا۟ ٱتَّخَذَ ٱلرَّحْمَـٰنُ وَلَدًا ۗ سُبْحَـٰنَهُۥ ۚ بَلْ عِبَادٌ مُّكْرَمُونَ"
    },
    {
      "id": 2510,
      "verseKey": "21:27",
      "verseNumber": 27,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "لَا يَسْبِقُونَهُۥ بِٱلْقَوْلِ وَهُم بِأَمْرِهِۦ يَعْمَلُونَ"
    },
    {
      "id": 2511,
      "verseKey": "21:28",
      "verseNumber": 28,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 129,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يَشْفَعُونَ إِلَّا لِمَنِ ٱرْتَضَىٰ وَهُم مِّنْ خَشْيَتِهِۦ مُشْفِقُونَ"
    },
    {
      "id": 2512,
      "verseKey": "21:29",
      "verseNumber": 29,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 279,
      "manzilNumber": 4,
      "text": "۞ وَمَن يَقُلْ مِنْهُمْ إِنِّىٓ إِلَـٰهٌ مِّن دُونِهِۦ فَذَٰلِكَ نَجْزِيهِ جَهَنَّمَ ۚ كَذَٰلِكَ نَجْزِى ٱلظَّـٰلِمِينَ"
    },
    {
      "id": 2513,
      "verseKey": "21:30",
      "verseNumber": 30,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "أَوَلَمْ يَرَ ٱلَّذِينَ كَفَرُوٓا۟ أَنَّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ كَانَتَا رَتْقًا فَفَتَقْنَـٰهُمَا ۖ وَجَعَلْنَا مِنَ ٱلْمَآءِ كُلَّ شَىْءٍ حَىٍّ ۖ أَفَلَا يُؤْمِنُونَ"
    },
    {
      "id": 2514,
      "verseKey": "21:31",
      "verseNumber": 31,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَجَعَلْنَا فِى ٱلْأَرْضِ رَوَٰسِىَ أَن تَمِيدَ بِهِمْ وَجَعَلْنَا فِيهَا فِجَاجًا سُبُلًا لَّعَلَّهُمْ يَهْتَدُونَ"
    },
    {
      "id": 2515,
      "verseKey": "21:32",
      "verseNumber": 32,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَجَعَلْنَا ٱلسَّمَآءَ سَقْفًا مَّحْفُوظًا ۖ وَهُمْ عَنْ ءَايَـٰتِهَا مُعْرِضُونَ"
    },
    {
      "id": 2516,
      "verseKey": "21:33",
      "verseNumber": 33,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَهُوَ ٱلَّذِى خَلَقَ ٱلَّيْلَ وَٱلنَّهَارَ وَٱلشَّمْسَ وَٱلْقَمَرَ ۖ كُلٌّ فِى فَلَكٍ يَسْبَحُونَ"
    },
    {
      "id": 2517,
      "verseKey": "21:34",
      "verseNumber": 34,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَمَا جَعَلْنَا لِبَشَرٍ مِّن قَبْلِكَ ٱلْخُلْدَ ۖ أَفَإِي۟ن مِّتَّ فَهُمُ ٱلْخَـٰلِدُونَ"
    },
    {
      "id": 2518,
      "verseKey": "21:35",
      "verseNumber": 35,
      "pageNumber": 324,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "كُلُّ نَفْسٍ ذَآئِقَةُ ٱلْمَوْتِ ۗ وَنَبْلُوكُم بِٱلشَّرِّ وَٱلْخَيْرِ فِتْنَةً ۖ وَإِلَيْنَا تُرْجَعُونَ"
    },
    {
      "id": 2519,
      "verseKey": "21:36",
      "verseNumber": 36,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَإِذَا رَءَاكَ ٱلَّذِينَ كَفَرُوٓا۟ إِن يَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَـٰذَا ٱلَّذِى يَذْكُرُ ءَالِهَتَكُمْ وَهُم بِذِكْرِ ٱلرَّحْمَـٰنِ هُمْ كَـٰفِرُونَ"
    },
    {
      "id": 2520,
      "verseKey": "21:37",
      "verseNumber": 37,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "خُلِقَ ٱلْإِنسَـٰنُ مِنْ عَجَلٍ ۚ سَأُو۟رِيكُمْ ءَايَـٰتِى فَلَا تَسْتَعْجِلُونِ"
    },
    {
      "id": 2521,
      "verseKey": "21:38",
      "verseNumber": 38,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَيَقُولُونَ مَتَىٰ هَـٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَـٰدِقِينَ"
    },
    {
      "id": 2522,
      "verseKey": "21:39",
      "verseNumber": 39,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "لَوْ يَعْلَمُ ٱلَّذِينَ كَفَرُوا۟ حِينَ لَا يَكُفُّونَ عَن وُجُوهِهِمُ ٱلنَّارَ وَلَا عَن ظُهُورِهِمْ وَلَا هُمْ يُنصَرُونَ"
    },
    {
      "id": 2523,
      "verseKey": "21:40",
      "verseNumber": 40,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "بَلْ تَأْتِيهِم بَغْتَةً فَتَبْهَتُهُمْ فَلَا يَسْتَطِيعُونَ رَدَّهَا وَلَا هُمْ يُنظَرُونَ"
    },
    {
      "id": 2524,
      "verseKey": "21:41",
      "verseNumber": 41,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 280,
      "manzilNumber": 4,
      "text": "وَلَقَدِ ٱسْتُهْزِئَ بِرُسُلٍ مِّن قَبْلِكَ فَحَاقَ بِٱلَّذِينَ سَخِرُوا۟ مِنْهُم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ"
    },
    {
      "id": 2525,
      "verseKey": "21:42",
      "verseNumber": 42,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "قُلْ مَن يَكْلَؤُكُم بِٱلَّيْلِ وَٱلنَّهَارِ مِنَ ٱلرَّحْمَـٰنِ ۗ بَلْ هُمْ عَن ذِكْرِ رَبِّهِم مُّعْرِضُونَ"
    },
    {
      "id": 2526,
      "verseKey": "21:43",
      "verseNumber": 43,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "أَمْ لَهُمْ ءَالِهَةٌ تَمْنَعُهُم مِّن دُونِنَا ۚ لَا يَسْتَطِيعُونَ نَصْرَ أَنفُسِهِمْ وَلَا هُم مِّنَّا يُصْحَبُونَ"
    },
    {
      "id": 2527,
      "verseKey": "21:44",
      "verseNumber": 44,
      "pageNumber": 325,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "بَلْ مَتَّعْنَا هَـٰٓؤُلَآءِ وَءَابَآءَهُمْ حَتَّىٰ طَالَ عَلَيْهِمُ ٱلْعُمُرُ ۗ أَفَلَا يَرَوْنَ أَنَّا نَأْتِى ٱلْأَرْضَ نَنقُصُهَا مِنْ أَطْرَافِهَآ ۚ أَفَهُمُ ٱلْغَـٰلِبُونَ"
    },
    {
      "id": 2528,
      "verseKey": "21:45",
      "verseNumber": 45,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "قُلْ إِنَّمَآ أُنذِرُكُم بِٱلْوَحْىِ ۚ وَلَا يَسْمَعُ ٱلصُّمُّ ٱلدُّعَآءَ إِذَا مَا يُنذَرُونَ"
    },
    {
      "id": 2529,
      "verseKey": "21:46",
      "verseNumber": 46,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "وَلَئِن مَّسَّتْهُمْ نَفْحَةٌ مِّنْ عَذَابِ رَبِّكَ لَيَقُولُنَّ يَـٰوَيْلَنَآ إِنَّا كُنَّا ظَـٰلِمِينَ"
    },
    {
      "id": 2530,
      "verseKey": "21:47",
      "verseNumber": 47,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "وَنَضَعُ ٱلْمَوَٰزِينَ ٱلْقِسْطَ لِيَوْمِ ٱلْقِيَـٰمَةِ فَلَا تُظْلَمُ نَفْسٌ شَيْـًٔا ۖ وَإِن كَانَ مِثْقَالَ حَبَّةٍ مِّنْ خَرْدَلٍ أَتَيْنَا بِهَا ۗ وَكَفَىٰ بِنَا حَـٰسِبِينَ"
    },
    {
      "id": 2531,
      "verseKey": "21:48",
      "verseNumber": 48,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "وَلَقَدْ ءَاتَيْنَا مُوسَىٰ وَهَـٰرُونَ ٱلْفُرْقَانَ وَضِيَآءً وَذِكْرًا لِّلْمُتَّقِينَ"
    },
    {
      "id": 2532,
      "verseKey": "21:49",
      "verseNumber": 49,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "ٱلَّذِينَ يَخْشَوْنَ رَبَّهُم بِٱلْغَيْبِ وَهُم مِّنَ ٱلسَّاعَةِ مُشْفِقُونَ"
    },
    {
      "id": 2533,
      "verseKey": "21:50",
      "verseNumber": 50,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 130,
      "rukuNumber": 281,
      "manzilNumber": 4,
      "text": "وَهَـٰذَا ذِكْرٌ مُّبَارَكٌ أَنزَلْنَـٰهُ ۚ أَفَأَنتُمْ لَهُۥ مُنكِرُونَ"
    },
    {
      "id": 2534,
      "verseKey": "21:51",
      "verseNumber": 51,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "۞ وَلَقَدْ ءَاتَيْنَآ إِبْرَٰهِيمَ رُشْدَهُۥ مِن قَبْلُ وَكُنَّا بِهِۦ عَـٰلِمِينَ"
    },
    {
      "id": 2535,
      "verseKey": "21:52",
      "verseNumber": 52,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا هَـٰذِهِ ٱلتَّمَاثِيلُ ٱلَّتِىٓ أَنتُمْ لَهَا عَـٰكِفُونَ"
    },
    {
      "id": 2536,
      "verseKey": "21:53",
      "verseNumber": 53,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوا۟ وَجَدْنَآ ءَابَآءَنَا لَهَا عَـٰبِدِينَ"
    },
    {
      "id": 2537,
      "verseKey": "21:54",
      "verseNumber": 54,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالَ لَقَدْ كُنتُمْ أَنتُمْ وَءَابَآؤُكُمْ فِى ضَلَـٰلٍ مُّبِينٍ"
    },
    {
      "id": 2538,
      "verseKey": "21:55",
      "verseNumber": 55,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوٓا۟ أَجِئْتَنَا بِٱلْحَقِّ أَمْ أَنتَ مِنَ ٱللَّـٰعِبِينَ"
    },
    {
      "id": 2539,
      "verseKey": "21:56",
      "verseNumber": 56,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالَ بَل رَّبُّكُمْ رَبُّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ٱلَّذِى فَطَرَهُنَّ وَأَنَا۠ عَلَىٰ ذَٰلِكُم مِّنَ ٱلشَّـٰهِدِينَ"
    },
    {
      "id": 2540,
      "verseKey": "21:57",
      "verseNumber": 57,
      "pageNumber": 326,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَتَٱللَّهِ لَأَكِيدَنَّ أَصْنَـٰمَكُم بَعْدَ أَن تُوَلُّوا۟ مُدْبِرِينَ"
    },
    {
      "id": 2541,
      "verseKey": "21:58",
      "verseNumber": 58,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "فَجَعَلَهُمْ جُذَٰذًا إِلَّا كَبِيرًا لَّهُمْ لَعَلَّهُمْ إِلَيْهِ يَرْجِعُونَ"
    },
    {
      "id": 2542,
      "verseKey": "21:59",
      "verseNumber": 59,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوا۟ مَن فَعَلَ هَـٰذَا بِـَٔالِهَتِنَآ إِنَّهُۥ لَمِنَ ٱلظَّـٰلِمِينَ"
    },
    {
      "id": 2543,
      "verseKey": "21:60",
      "verseNumber": 60,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوا۟ سَمِعْنَا فَتًى يَذْكُرُهُمْ يُقَالُ لَهُۥٓ إِبْرَٰهِيمُ"
    },
    {
      "id": 2544,
      "verseKey": "21:61",
      "verseNumber": 61,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوا۟ فَأْتُوا۟ بِهِۦ عَلَىٰٓ أَعْيُنِ ٱلنَّاسِ لَعَلَّهُمْ يَشْهَدُونَ"
    },
    {
      "id": 2545,
      "verseKey": "21:62",
      "verseNumber": 62,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوٓا۟ ءَأَنتَ فَعَلْتَ هَـٰذَا بِـَٔالِهَتِنَا يَـٰٓإِبْرَٰهِيمُ"
    },
    {
      "id": 2546,
      "verseKey": "21:63",
      "verseNumber": 63,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالَ بَلْ فَعَلَهُۥ كَبِيرُهُمْ هَـٰذَا فَسْـَٔلُوهُمْ إِن كَانُوا۟ يَنطِقُونَ"
    },
    {
      "id": 2547,
      "verseKey": "21:64",
      "verseNumber": 64,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "فَرَجَعُوٓا۟ إِلَىٰٓ أَنفُسِهِمْ فَقَالُوٓا۟ إِنَّكُمْ أَنتُمُ ٱلظَّـٰلِمُونَ"
    },
    {
      "id": 2548,
      "verseKey": "21:65",
      "verseNumber": 65,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "ثُمَّ نُكِسُوا۟ عَلَىٰ رُءُوسِهِمْ لَقَدْ عَلِمْتَ مَا هَـٰٓؤُلَآءِ يَنطِقُونَ"
    },
    {
      "id": 2549,
      "verseKey": "21:66",
      "verseNumber": 66,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالَ أَفَتَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَنفَعُكُمْ شَيْـًٔا وَلَا يَضُرُّكُمْ"
    },
    {
      "id": 2550,
      "verseKey": "21:67",
      "verseNumber": 67,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "أُفٍّ لَّكُمْ وَلِمَا تَعْبُدُونَ مِن دُونِ ٱللَّهِ ۖ أَفَلَا تَعْقِلُونَ"
    },
    {
      "id": 2551,
      "verseKey": "21:68",
      "verseNumber": 68,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قَالُوا۟ حَرِّقُوهُ وَٱنصُرُوٓا۟ ءَالِهَتَكُمْ إِن كُنتُمْ فَـٰعِلِينَ"
    },
    {
      "id": 2552,
      "verseKey": "21:69",
      "verseNumber": 69,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "قُلْنَا يَـٰنَارُ كُونِى بَرْدًا وَسَلَـٰمًا عَلَىٰٓ إِبْرَٰهِيمَ"
    },
    {
      "id": 2553,
      "verseKey": "21:70",
      "verseNumber": 70,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَأَرَادُوا۟ بِهِۦ كَيْدًا فَجَعَلْنَـٰهُمُ ٱلْأَخْسَرِينَ"
    },
    {
      "id": 2554,
      "verseKey": "21:71",
      "verseNumber": 71,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَنَجَّيْنَـٰهُ وَلُوطًا إِلَى ٱلْأَرْضِ ٱلَّتِى بَـٰرَكْنَا فِيهَا لِلْعَـٰلَمِينَ"
    },
    {
      "id": 2555,
      "verseKey": "21:72",
      "verseNumber": 72,
      "pageNumber": 327,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَوَهَبْنَا لَهُۥٓ إِسْحَـٰقَ وَيَعْقُوبَ نَافِلَةً ۖ وَكُلًّا جَعَلْنَا صَـٰلِحِينَ"
    },
    {
      "id": 2556,
      "verseKey": "21:73",
      "verseNumber": 73,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَجَعَلْنَـٰهُمْ أَئِمَّةً يَهْدُونَ بِأَمْرِنَا وَأَوْحَيْنَآ إِلَيْهِمْ فِعْلَ ٱلْخَيْرَٰتِ وَإِقَامَ ٱلصَّلَوٰةِ وَإِيتَآءَ ٱلزَّكَوٰةِ ۖ وَكَانُوا۟ لَنَا عَـٰبِدِينَ"
    },
    {
      "id": 2557,
      "verseKey": "21:74",
      "verseNumber": 74,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَلُوطًا ءَاتَيْنَـٰهُ حُكْمًا وَعِلْمًا وَنَجَّيْنَـٰهُ مِنَ ٱلْقَرْيَةِ ٱلَّتِى كَانَت تَّعْمَلُ ٱلْخَبَـٰٓئِثَ ۗ إِنَّهُمْ كَانُوا۟ قَوْمَ سَوْءٍ فَـٰسِقِينَ"
    },
    {
      "id": 2558,
      "verseKey": "21:75",
      "verseNumber": 75,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 282,
      "manzilNumber": 4,
      "text": "وَأَدْخَلْنَـٰهُ فِى رَحْمَتِنَآ ۖ إِنَّهُۥ مِنَ ٱلصَّـٰلِحِينَ"
    },
    {
      "id": 2559,
      "verseKey": "21:76",
      "verseNumber": 76,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَنُوحًا إِذْ نَادَىٰ مِن قَبْلُ فَٱسْتَجَبْنَا لَهُۥ فَنَجَّيْنَـٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ"
    },
    {
      "id": 2560,
      "verseKey": "21:77",
      "verseNumber": 77,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَنَصَرْنَـٰهُ مِنَ ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَـٰتِنَآ ۚ إِنَّهُمْ كَانُوا۟ قَوْمَ سَوْءٍ فَأَغْرَقْنَـٰهُمْ أَجْمَعِينَ"
    },
    {
      "id": 2561,
      "verseKey": "21:78",
      "verseNumber": 78,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَدَاوُۥدَ وَسُلَيْمَـٰنَ إِذْ يَحْكُمَانِ فِى ٱلْحَرْثِ إِذْ نَفَشَتْ فِيهِ غَنَمُ ٱلْقَوْمِ وَكُنَّا لِحُكْمِهِمْ شَـٰهِدِينَ"
    },
    {
      "id": 2562,
      "verseKey": "21:79",
      "verseNumber": 79,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "فَفَهَّمْنَـٰهَا سُلَيْمَـٰنَ ۚ وَكُلًّا ءَاتَيْنَا حُكْمًا وَعِلْمًا ۚ وَسَخَّرْنَا مَعَ دَاوُۥدَ ٱلْجِبَالَ يُسَبِّحْنَ وَٱلطَّيْرَ ۚ وَكُنَّا فَـٰعِلِينَ"
    },
    {
      "id": 2563,
      "verseKey": "21:80",
      "verseNumber": 80,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَعَلَّمْنَـٰهُ صَنْعَةَ لَبُوسٍ لَّكُمْ لِتُحْصِنَكُم مِّنۢ بَأْسِكُمْ ۖ فَهَلْ أَنتُمْ شَـٰكِرُونَ"
    },
    {
      "id": 2564,
      "verseKey": "21:81",
      "verseNumber": 81,
      "pageNumber": 328,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَلِسُلَيْمَـٰنَ ٱلرِّيحَ عَاصِفَةً تَجْرِى بِأَمْرِهِۦٓ إِلَى ٱلْأَرْضِ ٱلَّتِى بَـٰرَكْنَا فِيهَا ۚ وَكُنَّا بِكُلِّ شَىْءٍ عَـٰلِمِينَ"
    },
    {
      "id": 2565,
      "verseKey": "21:82",
      "verseNumber": 82,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 131,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَمِنَ ٱلشَّيَـٰطِينِ مَن يَغُوصُونَ لَهُۥ وَيَعْمَلُونَ عَمَلًا دُونَ ذَٰلِكَ ۖ وَكُنَّا لَهُمْ حَـٰفِظِينَ"
    },
    {
      "id": 2566,
      "verseKey": "21:83",
      "verseNumber": 83,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "۞ وَأَيُّوبَ إِذْ نَادَىٰ رَبَّهُۥٓ أَنِّى مَسَّنِىَ ٱلضُّرُّ وَأَنتَ أَرْحَمُ ٱلرَّٰحِمِينَ"
    },
    {
      "id": 2567,
      "verseKey": "21:84",
      "verseNumber": 84,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "فَٱسْتَجَبْنَا لَهُۥ فَكَشَفْنَا مَا بِهِۦ مِن ضُرٍّ ۖ وَءَاتَيْنَـٰهُ أَهْلَهُۥ وَمِثْلَهُم مَّعَهُمْ رَحْمَةً مِّنْ عِندِنَا وَذِكْرَىٰ لِلْعَـٰبِدِينَ"
    },
    {
      "id": 2568,
      "verseKey": "21:85",
      "verseNumber": 85,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَإِسْمَـٰعِيلَ وَإِدْرِيسَ وَذَا ٱلْكِفْلِ ۖ كُلٌّ مِّنَ ٱلصَّـٰبِرِينَ"
    },
    {
      "id": 2569,
      "verseKey": "21:86",
      "verseNumber": 86,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَأَدْخَلْنَـٰهُمْ فِى رَحْمَتِنَآ ۖ إِنَّهُم مِّنَ ٱلصَّـٰلِحِينَ"
    },
    {
      "id": 2570,
      "verseKey": "21:87",
      "verseNumber": 87,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَذَا ٱلنُّونِ إِذ ذَّهَبَ مُغَـٰضِبًا فَظَنَّ أَن لَّن نَّقْدِرَ عَلَيْهِ فَنَادَىٰ فِى ٱلظُّلُمَـٰتِ أَن لَّآ إِلَـٰهَ إِلَّآ أَنتَ سُبْحَـٰنَكَ إِنِّى كُنتُ مِنَ ٱلظَّـٰلِمِينَ"
    },
    {
      "id": 2571,
      "verseKey": "21:88",
      "verseNumber": 88,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "فَٱسْتَجَبْنَا لَهُۥ وَنَجَّيْنَـٰهُ مِنَ ٱلْغَمِّ ۚ وَكَذَٰلِكَ نُـۨجِى ٱلْمُؤْمِنِينَ"
    },
    {
      "id": 2572,
      "verseKey": "21:89",
      "verseNumber": 89,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَزَكَرِيَّآ إِذْ نَادَىٰ رَبَّهُۥ رَبِّ لَا تَذَرْنِى فَرْدًا وَأَنتَ خَيْرُ ٱلْوَٰرِثِينَ"
    },
    {
      "id": 2573,
      "verseKey": "21:90",
      "verseNumber": 90,
      "pageNumber": 329,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "فَٱسْتَجَبْنَا لَهُۥ وَوَهَبْنَا لَهُۥ يَحْيَىٰ وَأَصْلَحْنَا لَهُۥ زَوْجَهُۥٓ ۚ إِنَّهُمْ كَانُوا۟ يُسَـٰرِعُونَ فِى ٱلْخَيْرَٰتِ وَيَدْعُونَنَا رَغَبًا وَرَهَبًا ۖ وَكَانُوا۟ لَنَا خَـٰشِعِينَ"
    },
    {
      "id": 2574,
      "verseKey": "21:91",
      "verseNumber": 91,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَٱلَّتِىٓ أَحْصَنَتْ فَرْجَهَا فَنَفَخْنَا فِيهَا مِن رُّوحِنَا وَجَعَلْنَـٰهَا وَٱبْنَهَآ ءَايَةً لِّلْعَـٰلَمِينَ"
    },
    {
      "id": 2575,
      "verseKey": "21:92",
      "verseNumber": 92,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "إِنَّ هَـٰذِهِۦٓ أُمَّتُكُمْ أُمَّةً وَٰحِدَةً وَأَنَا۠ رَبُّكُمْ فَٱعْبُدُونِ"
    },
    {
      "id": 2576,
      "verseKey": "21:93",
      "verseNumber": 93,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 283,
      "manzilNumber": 4,
      "text": "وَتَقَطَّعُوٓا۟ أَمْرَهُم بَيْنَهُمْ ۖ كُلٌّ إِلَيْنَا رَٰجِعُونَ"
    },
    {
      "id": 2577,
      "verseKey": "21:94",
      "verseNumber": 94,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "فَمَن يَعْمَلْ مِنَ ٱلصَّـٰلِحَـٰتِ وَهُوَ مُؤْمِنٌ فَلَا كُفْرَانَ لِسَعْيِهِۦ وَإِنَّا لَهُۥ كَـٰتِبُونَ"
    },
    {
      "id": 2578,
      "verseKey": "21:95",
      "verseNumber": 95,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "وَحَرَٰمٌ عَلَىٰ قَرْيَةٍ أَهْلَكْنَـٰهَآ أَنَّهُمْ لَا يَرْجِعُونَ"
    },
    {
      "id": 2579,
      "verseKey": "21:96",
      "verseNumber": 96,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "حَتَّىٰٓ إِذَا فُتِحَتْ يَأْجُوجُ وَمَأْجُوجُ وَهُم مِّن كُلِّ حَدَبٍ يَنسِلُونَ"
    },
    {
      "id": 2580,
      "verseKey": "21:97",
      "verseNumber": 97,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "وَٱقْتَرَبَ ٱلْوَعْدُ ٱلْحَقُّ فَإِذَا هِىَ شَـٰخِصَةٌ أَبْصَـٰرُ ٱلَّذِينَ كَفَرُوا۟ يَـٰوَيْلَنَا قَدْ كُنَّا فِى غَفْلَةٍ مِّنْ هَـٰذَا بَلْ كُنَّا ظَـٰلِمِينَ"
    },
    {
      "id": 2581,
      "verseKey": "21:98",
      "verseNumber": 98,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "إِنَّكُمْ وَمَا تَعْبُدُونَ مِن دُونِ ٱللَّهِ حَصَبُ جَهَنَّمَ أَنتُمْ لَهَا وَٰرِدُونَ"
    },
    {
      "id": 2582,
      "verseKey": "21:99",
      "verseNumber": 99,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "لَوْ كَانَ هَـٰٓؤُلَآءِ ءَالِهَةً مَّا وَرَدُوهَا ۖ وَكُلٌّ فِيهَا خَـٰلِدُونَ"
    },
    {
      "id": 2583,
      "verseKey": "21:100",
      "verseNumber": 100,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "لَهُمْ فِيهَا زَفِيرٌ وَهُمْ فِيهَا لَا يَسْمَعُونَ"
    },
    {
      "id": 2584,
      "verseKey": "21:101",
      "verseNumber": 101,
      "pageNumber": 330,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "إِنَّ ٱلَّذِينَ سَبَقَتْ لَهُم مِّنَّا ٱلْحُسْنَىٰٓ أُو۟لَـٰٓئِكَ عَنْهَا مُبْعَدُونَ"
    },
    {
      "id": 2585,
      "verseKey": "21:102",
      "verseNumber": 102,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "لَا يَسْمَعُونَ حَسِيسَهَا ۖ وَهُمْ فِى مَا ٱشْتَهَتْ أَنفُسُهُمْ خَـٰلِدُونَ"
    },
    {
      "id": 2586,
      "verseKey": "21:103",
      "verseNumber": 103,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "لَا يَحْزُنُهُمُ ٱلْفَزَعُ ٱلْأَكْبَرُ وَتَتَلَقَّىٰهُمُ ٱلْمَلَـٰٓئِكَةُ هَـٰذَا يَوْمُكُمُ ٱلَّذِى كُنتُمْ تُوعَدُونَ"
    },
    {
      "id": 2587,
      "verseKey": "21:104",
      "verseNumber": 104,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "يَوْمَ نَطْوِى ٱلسَّمَآءَ كَطَىِّ ٱلسِّجِلِّ لِلْكُتُبِ ۚ كَمَا بَدَأْنَآ أَوَّلَ خَلْقٍ نُّعِيدُهُۥ ۚ وَعْدًا عَلَيْنَآ ۚ إِنَّا كُنَّا فَـٰعِلِينَ"
    },
    {
      "id": 2588,
      "verseKey": "21:105",
      "verseNumber": 105,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "وَلَقَدْ كَتَبْنَا فِى ٱلزَّبُورِ مِنۢ بَعْدِ ٱلذِّكْرِ أَنَّ ٱلْأَرْضَ يَرِثُهَا عِبَادِىَ ٱلصَّـٰلِحُونَ"
    },
    {
      "id": 2589,
      "verseKey": "21:106",
      "verseNumber": 106,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "إِنَّ فِى هَـٰذَا لَبَلَـٰغًا لِّقَوْمٍ عَـٰبِدِينَ"
    },
    {
      "id": 2590,
      "verseKey": "21:107",
      "verseNumber": 107,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "وَمَآ أَرْسَلْنَـٰكَ إِلَّا رَحْمَةً لِّلْعَـٰلَمِينَ"
    },
    {
      "id": 2591,
      "verseKey": "21:108",
      "verseNumber": 108,
      "pageNumber": 331,
      "juzNumber": 17,
      "hizbNumber": 33,
      "rubElHizbNumber": 132,
      "rukuNumber": 284,
      "manzilNumber": 4,
      "text": "قُلْ إِنَّمَا يُوحَىٰٓ إِلَىَّ أَنَّمَآ إِلَـٰهُكُمْ إِلَـٰهٌ وَٰحِدٌ ۖ فَهَلْ أَنتُم مُّسْلِمُونَ"
    },
    {
      "id": 2592,
      "verseKey": "21:109",
