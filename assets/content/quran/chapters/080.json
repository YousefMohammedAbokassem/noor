{
  "id": 80,
  "nameAr": "عبس",
  "nameSimple": "'Abasa",
  "nameComplex": "`Abasa",
  "translatedName": "He Frowned",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 24,
  "versesCount": 42,
  "bismillahPre": true,
  "startPage": 585,
  "endPage": 585,
  "verses": [
    {
      "id": 5759,
      "verseKey": "80:1",
      "verseNumber": 1,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": " عَبَسَ وَتَوَلَّىٰٓ"
    },
    {
      "id": 5760,
      "verseKey": "80:2",
      "verseNumber": 2,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "أَن جَآءَهُ ٱلْأَعْمَىٰ"
    },
    {
      "id": 5761,
      "verseKey": "80:3",
      "verseNumber": 3,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ"
    },
    {
      "id": 5762,
      "verseKey": "80:4",
      "verseNumber": 4,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ"
    },
    {
      "id": 5763,
      "verseKey": "80:5",
      "verseNumber": 5,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "أَمَّا مَنِ ٱسْتَغْنَىٰ"
    },
    {
      "id": 5764,
      "verseKey": "80:6",
      "verseNumber": 6,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فَأَنتَ لَهُۥ تَصَدَّىٰ"
    },
    {
      "id": 5765,
      "verseKey": "80:7",
      "verseNumber": 7,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ"
    },
    {
      "id": 5766,
      "verseKey": "80:8",
      "verseNumber": 8,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ"
    },
    {
      "id": 5767,
      "verseKey": "80:9",
      "verseNumber": 9,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَهُوَ يَخْشَىٰ"
    },
    {
      "id": 5768,
      "verseKey": "80:10",
      "verseNumber": 10,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فَأَنتَ عَنْهُ تَلَهَّىٰ"
    },
    {
      "id": 5769,
      "verseKey": "80:11",
      "verseNumber": 11,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "كَلَّآ إِنَّهَا تَذْكِرَةٌ"
    },
    {
      "id": 5770,
      "verseKey": "80:12",
      "verseNumber": 12,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ"
    },
    {
      "id": 5771,
      "verseKey": "80:13",
      "verseNumber": 13,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فِى صُحُفٍ مُّكَرَّمَةٍ"
    },
    {
      "id": 5772,
      "verseKey": "80:14",
      "verseNumber": 14,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ"
    },
    {
      "id": 5773,
      "verseKey": "80:15",
      "verseNumber": 15,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "بِأَيْدِى سَفَرَةٍ"
    },
    {
      "id": 5774,
      "verseKey": "80:16",
      "verseNumber": 16,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "كِرَامٍۭ بَرَرَةٍ"
    },
    {
      "id": 5775,
      "verseKey": "80:17",
      "verseNumber": 17,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ"
    },
    {
      "id": 5776,
      "verseKey": "80:18",
      "verseNumber": 18,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ"
    },
    {
      "id": 5777,
      "verseKey": "80:19",
      "verseNumber": 19,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ"
    },
    {
      "id": 5778,
      "verseKey": "80:20",
      "verseNumber": 20,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ"
    },
    {
      "id": 5779,
      "verseKey": "80:21",
      "verseNumber": 21,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ"
    },
    {
      "id": 5780,
      "verseKey": "80:22",
      "verseNumber": 22,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ"
    },
    {
      "id": 5781,
      "verseKey": "80:23",
      "verseNumber": 23,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ"
    },
    {
      "id": 5782,
      "verseKey": "80:24",
      "verseNumber": 24,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ"
    },
    {
      "id": 5783,
      "verseKey": "80:25",
      "verseNumber": 25,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا"
    },
    {
      "id": 5784,
      "verseKey": "80:26",
      "verseNumber": 26,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا"
    },
    {
      "id": 5785,
      "verseKey": "80:27",
      "verseNumber": 27,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فَأَنۢبَتْنَا فِيهَا حَبًّا"
    },
    {
      "id": 5786,
      "verseKey": "80:28",
      "verseNumber": 28,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَعِنَبًا وَقَضْبًا"
    },
    {
      "id": 5787,
      "verseKey": "80:29",
      "verseNumber": 29,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَزَيْتُونًا وَنَخْلًا"
    },
    {
      "id": 5788,
      "verseKey": "80:30",
      "verseNumber": 30,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَحَدَآئِقَ غُلْبًا"
    },
    {
      "id": 5789,
      "verseKey": "80:31",
      "verseNumber": 31,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَفَـٰكِهَةً وَأَبًّا"
    },
    {
      "id": 5790,
      "verseKey": "80:32",
      "verseNumber": 32,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ"
    },
    {
      "id": 5791,
      "verseKey": "80:33",
      "verseNumber": 33,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ"
    },
    {
      "id": 5792,
      "verseKey": "80:34",
      "verseNumber": 34,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ"
    },
    {
      "id": 5793,
      "verseKey": "80:35",
      "verseNumber": 35,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَأُمِّهِۦ وَأَبِيهِ"
    },
    {
      "id": 5794,
      "verseKey": "80:36",
      "verseNumber": 36,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَصَـٰحِبَتِهِۦ وَبَنِيهِ"
    },
    {
      "id": 5795,
      "verseKey": "80:37",
      "verseNumber": 37,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ"
    },
    {
      "id": 5796,
      "verseKey": "80:38",
      "verseNumber": 38,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ"
    },
    {
      "id": 5797,
      "verseKey": "80:39",
      "verseNumber": 39,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ"
    },
    {
      "id": 5798,
      "verseKey": "80:40",
      "verseNumber": 40,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ"
    },
    {
      "id": 5799,
      "verseKey": "80:41",
      "verseNumber": 41,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "تَرْهَقُهَا قَتَرَةٌ"
    },
    {
      "id": 5800,
      "verseKey": "80:42",
      "verseNumber": 42,
      "pageNumber": 585,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 234,
      "rukuNumber": 524,
      "manzilNumber": 7,
      "text": "أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ"
    }
  ]
}
