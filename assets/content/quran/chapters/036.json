  "verses": [
    {
      "id": 3706,
      "verseKey": "36:1",
      "verseNumber": 1,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": " يسٓ"
    },
    {
      "id": 3707,
      "verseKey": "36:2",
      "verseNumber": 2,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "وَٱلْقُرْءَانِ ٱلْحَكِيمِ"
    },
    {
      "id": 3708,
      "verseKey": "36:3",
      "verseNumber": 3,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "إِنَّكَ لَمِنَ ٱلْمُرْسَلِينَ"
    },
    {
      "id": 3709,
      "verseKey": "36:4",
      "verseNumber": 4,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "عَلَىٰ صِرَٰطٍ مُّسْتَقِيمٍ"
    },
    {
      "id": 3710,
      "verseKey": "36:5",
      "verseNumber": 5,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "تَنزِيلَ ٱلْعَزِيزِ ٱلرَّحِيمِ"
    },
    {
      "id": 3711,
      "verseKey": "36:6",
      "verseNumber": 6,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "لِتُنذِرَ قَوْمًا مَّآ أُنذِرَ ءَابَآؤُهُمْ فَهُمْ غَـٰفِلُونَ"
    },
    {
      "id": 3712,
      "verseKey": "36:7",
      "verseNumber": 7,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "لَقَدْ حَقَّ ٱلْقَوْلُ عَلَىٰٓ أَكْثَرِهِمْ فَهُمْ لَا يُؤْمِنُونَ"
    },
    {
      "id": 3713,
      "verseKey": "36:8",
      "verseNumber": 8,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "إِنَّا جَعَلْنَا فِىٓ أَعْنَـٰقِهِمْ أَغْلَـٰلًا فَهِىَ إِلَى ٱلْأَذْقَانِ فَهُم مُّقْمَحُونَ"
    },
    {
      "id": 3714,
      "verseKey": "36:9",
      "verseNumber": 9,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "وَجَعَلْنَا مِنۢ بَيْنِ أَيْدِيهِمْ سَدًّا وَمِنْ خَلْفِهِمْ سَدًّا فَأَغْشَيْنَـٰهُمْ فَهُمْ لَا يُبْصِرُونَ"
    },
    {
      "id": 3715,
      "verseKey": "36:10",
      "verseNumber": 10,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "وَسَوَآءٌ عَلَيْهِمْ ءَأَنذَرْتَهُمْ أَمْ لَمْ تُنذِرْهُمْ لَا يُؤْمِنُونَ"
    },
    {
      "id": 3716,
      "verseKey": "36:11",
      "verseNumber": 11,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "إِنَّمَا تُنذِرُ مَنِ ٱتَّبَعَ ٱلذِّكْرَ وَخَشِىَ ٱلرَّحْمَـٰنَ بِٱلْغَيْبِ ۖ فَبَشِّرْهُ بِمَغْفِرَةٍ وَأَجْرٍ كَرِيمٍ"
    },
    {
      "id": 3717,
      "verseKey": "36:12",
      "verseNumber": 12,
      "pageNumber": 440,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 383,
      "manzilNumber": 5,
      "text": "إِنَّا نَحْنُ نُحْىِ ٱلْمَوْتَىٰ وَنَكْتُبُ مَا قَدَّمُوا۟ وَءَاثَـٰرَهُمْ ۚ وَكُلَّ شَىْءٍ أَحْصَيْنَـٰهُ فِىٓ إِمَامٍ مُّبِينٍ"
    },
    {
      "id": 3718,
      "verseKey": "36:13",
      "verseNumber": 13,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "وَٱضْرِبْ لَهُم مَّثَلًا أَصْحَـٰبَ ٱلْقَرْيَةِ إِذْ جَآءَهَا ٱلْمُرْسَلُونَ"
    },
    {
      "id": 3719,
      "verseKey": "36:14",
      "verseNumber": 14,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "إِذْ أَرْسَلْنَآ إِلَيْهِمُ ٱثْنَيْنِ فَكَذَّبُوهُمَا فَعَزَّزْنَا بِثَالِثٍ فَقَالُوٓا۟ إِنَّآ إِلَيْكُم مُّرْسَلُونَ"
    },
    {
      "id": 3720,
      "verseKey": "36:15",
      "verseNumber": 15,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "قَالُوا۟ مَآ أَنتُمْ إِلَّا بَشَرٌ مِّثْلُنَا وَمَآ أَنزَلَ ٱلرَّحْمَـٰنُ مِن شَىْءٍ إِنْ أَنتُمْ إِلَّا تَكْذِبُونَ"
    },
    {
      "id": 3721,
      "verseKey": "36:16",
      "verseNumber": 16,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "قَالُوا۟ رَبُّنَا يَعْلَمُ إِنَّآ إِلَيْكُمْ لَمُرْسَلُونَ"
    },
    {
      "id": 3722,
      "verseKey": "36:17",
      "verseNumber": 17,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "وَمَا عَلَيْنَآ إِلَّا ٱلْبَلَـٰغُ ٱلْمُبِينُ"
    },
    {
      "id": 3723,
      "verseKey": "36:18",
      "verseNumber": 18,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "قَالُوٓا۟ إِنَّا تَطَيَّرْنَا بِكُمْ ۖ لَئِن لَّمْ تَنتَهُوا۟ لَنَرْجُمَنَّكُمْ وَلَيَمَسَّنَّكُم مِّنَّا عَذَابٌ أَلِيمٌ"
    },
    {
      "id": 3724,
      "verseKey": "36:19",
      "verseNumber": 19,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "قَالُوا۟ طَـٰٓئِرُكُم مَّعَكُمْ ۚ أَئِن ذُكِّرْتُم ۚ بَلْ أَنتُمْ قَوْمٌ مُّسْرِفُونَ"
    },
    {
      "id": 3725,
      "verseKey": "36:20",
      "verseNumber": 20,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "وَجَآءَ مِنْ أَقْصَا ٱلْمَدِينَةِ رَجُلٌ يَسْعَىٰ قَالَ يَـٰقَوْمِ ٱتَّبِعُوا۟ ٱلْمُرْسَلِينَ"
    },
    {
      "id": 3726,
      "verseKey": "36:21",
      "verseNumber": 21,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "ٱتَّبِعُوا۟ مَن لَّا يَسْـَٔلُكُمْ أَجْرًا وَهُم مُّهْتَدُونَ"
    },
    {
      "id": 3727,
      "verseKey": "36:22",
      "verseNumber": 22,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "وَمَا لِىَ لَآ أَعْبُدُ ٱلَّذِى فَطَرَنِى وَإِلَيْهِ تُرْجَعُونَ"
    },
    {
      "id": 3728,
      "verseKey": "36:23",
      "verseNumber": 23,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "ءَأَتَّخِذُ مِن دُونِهِۦٓ ءَالِهَةً إِن يُرِدْنِ ٱلرَّحْمَـٰنُ بِضُرٍّ لَّا تُغْنِ عَنِّى شَفَـٰعَتُهُمْ شَيْـًٔا وَلَا يُنقِذُونِ"
    },
    {
      "id": 3729,
      "verseKey": "36:24",
      "verseNumber": 24,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "إِنِّىٓ إِذًا لَّفِى ضَلَـٰلٍ مُّبِينٍ"
    },
    {
      "id": 3730,
      "verseKey": "36:25",
      "verseNumber": 25,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "إِنِّىٓ ءَامَنتُ بِرَبِّكُمْ فَٱسْمَعُونِ"
    },
    {
      "id": 3731,
      "verseKey": "36:26",
      "verseNumber": 26,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "قِيلَ ٱدْخُلِ ٱلْجَنَّةَ ۖ قَالَ يَـٰلَيْتَ قَوْمِى يَعْلَمُونَ"
    },
    {
      "id": 3732,
      "verseKey": "36:27",
      "verseNumber": 27,
      "pageNumber": 441,
      "juzNumber": 22,
      "hizbNumber": 44,
      "rubElHizbNumber": 176,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "بِمَا غَفَرَ لِى رَبِّى وَجَعَلَنِى مِنَ ٱلْمُكْرَمِينَ"
    },
    {
      "id": 3733,
      "verseKey": "36:28",
      "verseNumber": 28,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "۞ وَمَآ أَنزَلْنَا عَلَىٰ قَوْمِهِۦ مِنۢ بَعْدِهِۦ مِن جُندٍ مِّنَ ٱلسَّمَآءِ وَمَا كُنَّا مُنزِلِينَ"
    },
    {
      "id": 3734,
      "verseKey": "36:29",
      "verseNumber": 29,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "إِن كَانَتْ إِلَّا صَيْحَةً وَٰحِدَةً فَإِذَا هُمْ خَـٰمِدُونَ"
    },
    {
      "id": 3735,
      "verseKey": "36:30",
      "verseNumber": 30,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "يَـٰحَسْرَةً عَلَى ٱلْعِبَادِ ۚ مَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ"
    },
    {
      "id": 3736,
      "verseKey": "36:31",
      "verseNumber": 31,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "أَلَمْ يَرَوْا۟ كَمْ أَهْلَكْنَا قَبْلَهُم مِّنَ ٱلْقُرُونِ أَنَّهُمْ إِلَيْهِمْ لَا يَرْجِعُونَ"
    },
    {
      "id": 3737,
      "verseKey": "36:32",
      "verseNumber": 32,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 384,
      "manzilNumber": 5,
      "text": "وَإِن كُلٌّ لَّمَّا جَمِيعٌ لَّدَيْنَا مُحْضَرُونَ"
    },
    {
      "id": 3738,
      "verseKey": "36:33",
      "verseNumber": 33,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَءَايَةٌ لَّهُمُ ٱلْأَرْضُ ٱلْمَيْتَةُ أَحْيَيْنَـٰهَا وَأَخْرَجْنَا مِنْهَا حَبًّا فَمِنْهُ يَأْكُلُونَ"
    },
    {
      "id": 3739,
      "verseKey": "36:34",
      "verseNumber": 34,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَجَعَلْنَا فِيهَا جَنَّـٰتٍ مِّن نَّخِيلٍ وَأَعْنَـٰبٍ وَفَجَّرْنَا فِيهَا مِنَ ٱلْعُيُونِ"
    },
    {
      "id": 3740,
      "verseKey": "36:35",
      "verseNumber": 35,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "لِيَأْكُلُوا۟ مِن ثَمَرِهِۦ وَمَا عَمِلَتْهُ أَيْدِيهِمْ ۖ أَفَلَا يَشْكُرُونَ"
    },
    {
      "id": 3741,
      "verseKey": "36:36",
      "verseNumber": 36,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "سُبْحَـٰنَ ٱلَّذِى خَلَقَ ٱلْأَزْوَٰجَ كُلَّهَا مِمَّا تُنۢبِتُ ٱلْأَرْضُ وَمِنْ أَنفُسِهِمْ وَمِمَّا لَا يَعْلَمُونَ"
    },
    {
      "id": 3742,
      "verseKey": "36:37",
      "verseNumber": 37,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَءَايَةٌ لَّهُمُ ٱلَّيْلُ نَسْلَخُ مِنْهُ ٱلنَّهَارَ فَإِذَا هُم مُّظْلِمُونَ"
    },
    {
      "id": 3743,
      "verseKey": "36:38",
      "verseNumber": 38,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَٱلشَّمْسُ تَجْرِى لِمُسْتَقَرٍّ لَّهَا ۚ ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ"
    },
    {
      "id": 3744,
      "verseKey": "36:39",
      "verseNumber": 39,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَٱلْقَمَرَ قَدَّرْنَـٰهُ مَنَازِلَ حَتَّىٰ عَادَ كَٱلْعُرْجُونِ ٱلْقَدِيمِ"
    },
    {
      "id": 3745,
      "verseKey": "36:40",
      "verseNumber": 40,
      "pageNumber": 442,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "لَا ٱلشَّمْسُ يَنۢبَغِى لَهَآ أَن تُدْرِكَ ٱلْقَمَرَ وَلَا ٱلَّيْلُ سَابِقُ ٱلنَّهَارِ ۚ وَكُلٌّ فِى فَلَكٍ يَسْبَحُونَ"
    },
    {
      "id": 3746,
      "verseKey": "36:41",
      "verseNumber": 41,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَءَايَةٌ لَّهُمْ أَنَّا حَمَلْنَا ذُرِّيَّتَهُمْ فِى ٱلْفُلْكِ ٱلْمَشْحُونِ"
    },
    {
      "id": 3747,
      "verseKey": "36:42",
      "verseNumber": 42,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَخَلَقْنَا لَهُم مِّن مِّثْلِهِۦ مَا يَرْكَبُونَ"
    },
    {
      "id": 3748,
      "verseKey": "36:43",
      "verseNumber": 43,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَإِن نَّشَأْ نُغْرِقْهُمْ فَلَا صَرِيخَ لَهُمْ وَلَا هُمْ يُنقَذُونَ"
    },
    {
      "id": 3749,
      "verseKey": "36:44",
      "verseNumber": 44,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "إِلَّا رَحْمَةً مِّنَّا وَمَتَـٰعًا إِلَىٰ حِينٍ"
    },
    {
      "id": 3750,
      "verseKey": "36:45",
      "verseNumber": 45,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَإِذَا قِيلَ لَهُمُ ٱتَّقُوا۟ مَا بَيْنَ أَيْدِيكُمْ وَمَا خَلْفَكُمْ لَعَلَّكُمْ تُرْحَمُونَ"
    },
    {
      "id": 3751,
      "verseKey": "36:46",
      "verseNumber": 46,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَمَا تَأْتِيهِم مِّنْ ءَايَةٍ مِّنْ ءَايَـٰتِ رَبِّهِمْ إِلَّا كَانُوا۟ عَنْهَا مُعْرِضِينَ"
    },
    {
      "id": 3752,
      "verseKey": "36:47",
      "verseNumber": 47,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَإِذَا قِيلَ لَهُمْ أَنفِقُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ قَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوٓا۟ أَنُطْعِمُ مَن لَّوْ يَشَآءُ ٱللَّهُ أَطْعَمَهُۥٓ إِنْ أَنتُمْ إِلَّا فِى ضَلَـٰلٍ مُّبِينٍ"
    },
    {
      "id": 3753,
      "verseKey": "36:48",
      "verseNumber": 48,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "وَيَقُولُونَ مَتَىٰ هَـٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَـٰدِقِينَ"
    },
    {
      "id": 3754,
      "verseKey": "36:49",
      "verseNumber": 49,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "مَا يَنظُرُونَ إِلَّا صَيْحَةً وَٰحِدَةً تَأْخُذُهُمْ وَهُمْ يَخِصِّمُونَ"
    },
    {
      "id": 3755,
      "verseKey": "36:50",
      "verseNumber": 50,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 385,
      "manzilNumber": 5,
      "text": "فَلَا يَسْتَطِيعُونَ تَوْصِيَةً وَلَآ إِلَىٰٓ أَهْلِهِمْ يَرْجِعُونَ"
    },
    {
      "id": 3756,
      "verseKey": "36:51",
      "verseNumber": 51,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "وَنُفِخَ فِى ٱلصُّورِ فَإِذَا هُم مِّنَ ٱلْأَجْدَاثِ إِلَىٰ رَبِّهِمْ يَنسِلُونَ"
    },
    {
      "id": 3757,
      "verseKey": "36:52",
      "verseNumber": 52,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "قَالُوا۟ يَـٰوَيْلَنَا مَنۢ بَعَثَنَا مِن مَّرْقَدِنَا ۜ ۗ هَـٰذَا مَا وَعَدَ ٱلرَّحْمَـٰنُ وَصَدَقَ ٱلْمُرْسَلُونَ"
    },
    {
      "id": 3758,
      "verseKey": "36:53",
      "verseNumber": 53,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "إِن كَانَتْ إِلَّا صَيْحَةً وَٰحِدَةً فَإِذَا هُمْ جَمِيعٌ لَّدَيْنَا مُحْضَرُونَ"
    },
    {
      "id": 3759,
      "verseKey": "36:54",
      "verseNumber": 54,
      "pageNumber": 443,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "فَٱلْيَوْمَ لَا تُظْلَمُ نَفْسٌ شَيْـًٔا وَلَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ"
    },
    {
      "id": 3760,
      "verseKey": "36:55",
      "verseNumber": 55,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "إِنَّ أَصْحَـٰبَ ٱلْجَنَّةِ ٱلْيَوْمَ فِى شُغُلٍ فَـٰكِهُونَ"
    },
    {
      "id": 3761,
      "verseKey": "36:56",
      "verseNumber": 56,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "هُمْ وَأَزْوَٰجُهُمْ فِى ظِلَـٰلٍ عَلَى ٱلْأَرَآئِكِ مُتَّكِـُٔونَ"
    },
    {
      "id": 3762,
      "verseKey": "36:57",
      "verseNumber": 57,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "لَهُمْ فِيهَا فَـٰكِهَةٌ وَلَهُم مَّا يَدَّعُونَ"
    },
    {
      "id": 3763,
      "verseKey": "36:58",
      "verseNumber": 58,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "سَلَـٰمٌ قَوْلًا مِّن رَّبٍّ رَّحِيمٍ"
    },
    {
      "id": 3764,
      "verseKey": "36:59",
      "verseNumber": 59,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 177,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "وَٱمْتَـٰزُوا۟ ٱلْيَوْمَ أَيُّهَا ٱلْمُجْرِمُونَ"
    },
    {
      "id": 3765,
      "verseKey": "36:60",
      "verseNumber": 60,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "۞ أَلَمْ أَعْهَدْ إِلَيْكُمْ يَـٰبَنِىٓ ءَادَمَ أَن لَّا تَعْبُدُوا۟ ٱلشَّيْطَـٰنَ ۖ إِنَّهُۥ لَكُمْ عَدُوٌّ مُّبِينٌ"
    },
    {
      "id": 3766,
      "verseKey": "36:61",
      "verseNumber": 61,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "وَأَنِ ٱعْبُدُونِى ۚ هَـٰذَا صِرَٰطٌ مُّسْتَقِيمٌ"
    },
    {
      "id": 3767,
      "verseKey": "36:62",
      "verseNumber": 62,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "وَلَقَدْ أَضَلَّ مِنكُمْ جِبِلًّا كَثِيرًا ۖ أَفَلَمْ تَكُونُوا۟ تَعْقِلُونَ"
    },
    {
      "id": 3768,
      "verseKey": "36:63",
      "verseNumber": 63,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِى كُنتُمْ تُوعَدُونَ"
    },
    {
      "id": 3769,
      "verseKey": "36:64",
      "verseNumber": 64,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "ٱصْلَوْهَا ٱلْيَوْمَ بِمَا كُنتُمْ تَكْفُرُونَ"
    },
    {
      "id": 3770,
      "verseKey": "36:65",
      "verseNumber": 65,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "ٱلْيَوْمَ نَخْتِمُ عَلَىٰٓ أَفْوَٰهِهِمْ وَتُكَلِّمُنَآ أَيْدِيهِمْ وَتَشْهَدُ أَرْجُلُهُم بِمَا كَانُوا۟ يَكْسِبُونَ"
    },
    {
      "id": 3771,
      "verseKey": "36:66",
      "verseNumber": 66,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "وَلَوْ نَشَآءُ لَطَمَسْنَا عَلَىٰٓ أَعْيُنِهِمْ فَٱسْتَبَقُوا۟ ٱلصِّرَٰطَ فَأَنَّىٰ يُبْصِرُونَ"
    },
    {
      "id": 3772,
      "verseKey": "36:67",
      "verseNumber": 67,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 386,
      "manzilNumber": 5,
      "text": "وَلَوْ نَشَآءُ لَمَسَخْنَـٰهُمْ عَلَىٰ مَكَانَتِهِمْ فَمَا ٱسْتَطَـٰعُوا۟ مُضِيًّا وَلَا يَرْجِعُونَ"
    },
    {
      "id": 3773,
      "verseKey": "36:68",
      "verseNumber": 68,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "وَمَن نُّعَمِّرْهُ نُنَكِّسْهُ فِى ٱلْخَلْقِ ۖ أَفَلَا يَعْقِلُونَ"
    },
    {
      "id": 3774,
      "verseKey": "36:69",
      "verseNumber": 69,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "وَمَا عَلَّمْنَـٰهُ ٱلشِّعْرَ وَمَا يَنۢبَغِى لَهُۥٓ ۚ إِنْ هُوَ إِلَّا ذِكْرٌ وَقُرْءَانٌ مُّبِينٌ"
    },
    {
      "id": 3775,
      "verseKey": "36:70",
      "verseNumber": 70,
      "pageNumber": 444,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "لِّيُنذِرَ مَن كَانَ حَيًّا وَيَحِقَّ ٱلْقَوْلُ عَلَى ٱلْكَـٰفِرِينَ"
    },
    {
      "id": 3776,
      "verseKey": "36:71",
      "verseNumber": 71,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "أَوَلَمْ يَرَوْا۟ أَنَّا خَلَقْنَا لَهُم مِّمَّا عَمِلَتْ أَيْدِينَآ أَنْعَـٰمًا فَهُمْ لَهَا مَـٰلِكُونَ"
    },
    {
      "id": 3777,
      "verseKey": "36:72",
      "verseNumber": 72,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "وَذَلَّلْنَـٰهَا لَهُمْ فَمِنْهَا رَكُوبُهُمْ وَمِنْهَا يَأْكُلُونَ"
    },
    {
      "id": 3778,
      "verseKey": "36:73",
      "verseNumber": 73,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "وَلَهُمْ فِيهَا مَنَـٰفِعُ وَمَشَارِبُ ۖ أَفَلَا يَشْكُرُونَ"
    },
    {
      "id": 3779,
      "verseKey": "36:74",
      "verseNumber": 74,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "وَٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ ءَالِهَةً لَّعَلَّهُمْ يُنصَرُونَ"
    },
    {
      "id": 3780,
      "verseKey": "36:75",
      "verseNumber": 75,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "لَا يَسْتَطِيعُونَ نَصْرَهُمْ وَهُمْ لَهُمْ جُندٌ مُّحْضَرُونَ"
    },
    {
      "id": 3781,
      "verseKey": "36:76",
      "verseNumber": 76,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "فَلَا يَحْزُنكَ قَوْلُهُمْ ۘ إِنَّا نَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ"
    },
    {
      "id": 3782,
      "verseKey": "36:77",
      "verseNumber": 77,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "أَوَلَمْ يَرَ ٱلْإِنسَـٰنُ أَنَّا خَلَقْنَـٰهُ مِن نُّطْفَةٍ فَإِذَا هُوَ خَصِيمٌ مُّبِينٌ"
    },
    {
      "id": 3783,
      "verseKey": "36:78",
      "verseNumber": 78,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "وَضَرَبَ لَنَا مَثَلًا وَنَسِىَ خَلْقَهُۥ ۖ قَالَ مَن يُحْىِ ٱلْعِظَـٰمَ وَهِىَ رَمِيمٌ"
    },
    {
      "id": 3784,
      "verseKey": "36:79",
      "verseNumber": 79,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
      "manzilNumber": 5,
      "text": "قُلْ يُحْيِيهَا ٱلَّذِىٓ أَنشَأَهَآ أَوَّلَ مَرَّةٍ ۖ وَهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ"
    },
    {
      "id": 3785,
      "verseKey": "36:80",
      "verseNumber": 80,
      "pageNumber": 445,
      "juzNumber": 23,
      "hizbNumber": 45,
      "rubElHizbNumber": 178,
      "rukuNumber": 387,
