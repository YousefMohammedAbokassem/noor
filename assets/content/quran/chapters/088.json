      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 532,
      "manzilNumber": 7,
      "text": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ"
