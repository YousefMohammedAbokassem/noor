    {
      "id": 5972,
      "verseKey": "88:5",
      "verseNumber": 5,
      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 532,
      "manzilNumber": 7,
