      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 532,
      "manzilNumber": 7,
      "text": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ"
