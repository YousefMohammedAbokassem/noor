      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 532,
      "manzilNumber": 7,
      "text": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ"
    },
    {
      "id": 5975,
      "verseKey": "88:8",
      "verseNumber": 8,
      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 532,
      "manzilNumber": 7,
