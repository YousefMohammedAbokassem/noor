  "verses": [
    {
      "id": 5673,
      "verseKey": "78:1",
      "verseNumber": 1,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": " عَمَّ يَتَسَآءَلُونَ"
    },
    {
      "id": 5674,
      "verseKey": "78:2",
      "verseNumber": 2,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ"
    },
    {
      "id": 5675,
      "verseKey": "78:3",
      "verseNumber": 3,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ"
    },
    {
      "id": 5676,
      "verseKey": "78:4",
      "verseNumber": 4,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "كَلَّا سَيَعْلَمُونَ"
    },
    {
      "id": 5677,
      "verseKey": "78:5",
      "verseNumber": 5,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "ثُمَّ كَلَّا سَيَعْلَمُونَ"
    },
    {
      "id": 5678,
      "verseKey": "78:6",
      "verseNumber": 6,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَـٰدًا"
    },
    {
      "id": 5679,
      "verseKey": "78:7",
      "verseNumber": 7,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَٱلْجِبَالَ أَوْتَادًا"
    },
    {
      "id": 5680,
      "verseKey": "78:8",
      "verseNumber": 8,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَخَلَقْنَـٰكُمْ أَزْوَٰجًا"
    },
    {
      "id": 5681,
      "verseKey": "78:9",
      "verseNumber": 9,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"
    },
    {
      "id": 5682,
      "verseKey": "78:10",
      "verseNumber": 10,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَجَعَلْنَا ٱلَّيْلَ لِبَاسًا"
    },
    {
      "id": 5683,
      "verseKey": "78:11",
      "verseNumber": 11,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًا"
    },
    {
      "id": 5684,
      "verseKey": "78:12",
      "verseNumber": 12,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا"
    },
    {
      "id": 5685,
      "verseKey": "78:13",
      "verseNumber": 13,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَجَعَلْنَا سِرَاجًا وَهَّاجًا"
    },
    {
      "id": 5686,
      "verseKey": "78:14",
      "verseNumber": 14,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءً ثَجَّاجًا"
    },
    {
      "id": 5687,
      "verseKey": "78:15",
      "verseNumber": 15,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "لِّنُخْرِجَ بِهِۦ حَبًّا وَنَبَاتًا"
    },
    {
      "id": 5688,
      "verseKey": "78:16",
      "verseNumber": 16,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَجَنَّـٰتٍ أَلْفَافًا"
    },
    {
      "id": 5689,
      "verseKey": "78:17",
      "verseNumber": 17,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَـٰتًا"
    },
    {
      "id": 5690,
      "verseKey": "78:18",
      "verseNumber": 18,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًا"
    },
    {
      "id": 5691,
      "verseKey": "78:19",
      "verseNumber": 19,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًا"
    },
    {
      "id": 5692,
      "verseKey": "78:20",
      "verseNumber": 20,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا"
    },
    {
      "id": 5693,
      "verseKey": "78:21",
      "verseNumber": 21,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا"
    },
    {
      "id": 5694,
      "verseKey": "78:22",
      "verseNumber": 22,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "لِّلطَّـٰغِينَ مَـَٔابًا"
    },
    {
      "id": 5695,
      "verseKey": "78:23",
      "verseNumber": 23,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "لَّـٰبِثِينَ فِيهَآ أَحْقَابًا"
    },
    {
      "id": 5696,
      "verseKey": "78:24",
      "verseNumber": 24,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا"
    },
    {
      "id": 5697,
      "verseKey": "78:25",
      "verseNumber": 25,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "إِلَّا حَمِيمًا وَغَسَّاقًا"
    },
    {
      "id": 5698,
      "verseKey": "78:26",
      "verseNumber": 26,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "جَزَآءً وِفَاقًا"
    },
    {
      "id": 5699,
      "verseKey": "78:27",
      "verseNumber": 27,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًا"
    },
    {
      "id": 5700,
      "verseKey": "78:28",
      "verseNumber": 28,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَكَذَّبُوا۟ بِـَٔايَـٰتِنَا كِذَّابًا"
    },
    {
      "id": 5701,
      "verseKey": "78:29",
      "verseNumber": 29,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "وَكُلَّ شَىْءٍ أَحْصَيْنَـٰهُ كِتَـٰبًا"
    },
    {
      "id": 5702,
      "verseKey": "78:30",
      "verseNumber": 30,
      "pageNumber": 582,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 520,
      "manzilNumber": 7,
      "text": "فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا"
    },
    {
      "id": 5703,
      "verseKey": "78:31",
      "verseNumber": 31,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "إِنَّ لِلْمُتَّقِينَ مَفَازًا"
    },
    {
      "id": 5704,
      "verseKey": "78:32",
      "verseNumber": 32,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "حَدَآئِقَ وَأَعْنَـٰبًا"
    },
    {
      "id": 5705,
      "verseKey": "78:33",
      "verseNumber": 33,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "وَكَوَاعِبَ أَتْرَابًا"
    },
    {
      "id": 5706,
      "verseKey": "78:34",
      "verseNumber": 34,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "وَكَأْسًا دِهَاقًا"
    },
    {
      "id": 5707,
      "verseKey": "78:35",
      "verseNumber": 35,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّٰبًا"
    },
    {
      "id": 5708,
      "verseKey": "78:36",
      "verseNumber": 36,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "جَزَآءً مِّن رَّبِّكَ عَطَآءً حِسَابًا"
    },
    {
      "id": 5709,
      "verseKey": "78:37",
      "verseNumber": 37,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "رَّبِّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَـٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا"
    },
    {
      "id": 5710,
      "verseKey": "78:38",
      "verseNumber": 38,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَـٰٓئِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَـٰنُ وَقَالَ صَوَابًا"
    },
    {
      "id": 5711,
      "verseKey": "78:39",
      "verseNumber": 39,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا"
    },
    {
      "id": 5712,
      "verseKey": "78:40",
      "verseNumber": 40,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 521,
      "manzilNumber": 7,
      "text": "إِنَّآ أَنذَرْنَـٰكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ ٱلْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ ٱلْكَافِرُ يَـٰلَيْتَنِى كُنتُ تُرَٰبًۢا"
    }
  ]
}
