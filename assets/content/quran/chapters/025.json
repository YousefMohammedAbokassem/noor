{
  "id": 25,
  "nameAr": "الفرقان",
  "nameSimple": "Al-Furqan",
  "nameComplex": "Al-Furqān",
  "translatedName": "The Criterion",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 42,
  "versesCount": 77,
  "bismillahPre": true,
  "startPage": 359,
  "endPage": 366,
  "verses": [
    {
      "id": 2856,
      "verseKey": "25:1",
      "verseNumber": 1,
      "pageNumber": 359,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": " تَبَارَكَ ٱلَّذِى نَزَّلَ ٱلْفُرْقَانَ عَلَىٰ عَبْدِهِۦ لِيَكُونَ لِلْعَـٰلَمِينَ نَذِيرًا"
    },
    {
      "id": 2857,
      "verseKey": "25:2",
      "verseNumber": 2,
      "pageNumber": 359,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَلَمْ يَتَّخِذْ وَلَدًا وَلَمْ يَكُن لَّهُۥ شَرِيكٌ فِى ٱلْمُلْكِ وَخَلَقَ كُلَّ شَىْءٍ فَقَدَّرَهُۥ تَقْدِيرًا"
    },
    {
      "id": 2858,
      "verseKey": "25:3",
      "verseNumber": 3,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "وَٱتَّخَذُوا۟ مِن دُونِهِۦٓ ءَالِهَةً لَّا يَخْلُقُونَ شَيْـًٔا وَهُمْ يُخْلَقُونَ وَلَا يَمْلِكُونَ لِأَنفُسِهِمْ ضَرًّا وَلَا نَفْعًا وَلَا يَمْلِكُونَ مَوْتًا وَلَا حَيَوٰةً وَلَا نُشُورًا"
    },
    {
      "id": 2859,
      "verseKey": "25:4",
      "verseNumber": 4,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "وَقَالَ ٱلَّذِينَ كَفَرُوٓا۟ إِنْ هَـٰذَآ إِلَّآ إِفْكٌ ٱفْتَرَىٰهُ وَأَعَانَهُۥ عَلَيْهِ قَوْمٌ ءَاخَرُونَ ۖ فَقَدْ جَآءُو ظُلْمًا وَزُورًا"
    },
    {
      "id": 2860,
      "verseKey": "25:5",
      "verseNumber": 5,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "وَقَالُوٓا۟ أَسَـٰطِيرُ ٱلْأَوَّلِينَ ٱكْتَتَبَهَا فَهِىَ تُمْلَىٰ عَلَيْهِ بُكْرَةً وَأَصِيلًا"
    },
    {
      "id": 2861,
      "verseKey": "25:6",
      "verseNumber": 6,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "قُلْ أَنزَلَهُ ٱلَّذِى يَعْلَمُ ٱلسِّرَّ فِى ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ إِنَّهُۥ كَانَ غَفُورًا رَّحِيمًا"
    },
    {
      "id": 2862,
      "verseKey": "25:7",
      "verseNumber": 7,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "وَقَالُوا۟ مَالِ هَـٰذَا ٱلرَّسُولِ يَأْكُلُ ٱلطَّعَامَ وَيَمْشِى فِى ٱلْأَسْوَاقِ ۙ لَوْلَآ أُنزِلَ إِلَيْهِ مَلَكٌ فَيَكُونَ مَعَهُۥ نَذِيرًا"
    },
    {
      "id": 2863,
      "verseKey": "25:8",
      "verseNumber": 8,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "أَوْ يُلْقَىٰٓ إِلَيْهِ كَنزٌ أَوْ تَكُونُ لَهُۥ جَنَّةٌ يَأْكُلُ مِنْهَا ۚ وَقَالَ ٱلظَّـٰلِمُونَ إِن تَتَّبِعُونَ إِلَّا رَجُلًا مَّسْحُورًا"
    },
    {
      "id": 2864,
      "verseKey": "25:9",
      "verseNumber": 9,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 310,
      "manzilNumber": 4,
      "text": "ٱنظُرْ كَيْفَ ضَرَبُوا۟ لَكَ ٱلْأَمْثَـٰلَ فَضَلُّوا۟ فَلَا يَسْتَطِيعُونَ سَبِيلًا"
    },
    {
      "id": 2865,
      "verseKey": "25:10",
      "verseNumber": 10,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "تَبَارَكَ ٱلَّذِىٓ إِن شَآءَ جَعَلَ لَكَ خَيْرًا مِّن ذَٰلِكَ جَنَّـٰتٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ وَيَجْعَل لَّكَ قُصُورًۢا"
    },
    {
      "id": 2866,
      "verseKey": "25:11",
      "verseNumber": 11,
      "pageNumber": 360,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "بَلْ كَذَّبُوا۟ بِٱلسَّاعَةِ ۖ وَأَعْتَدْنَا لِمَن كَذَّبَ بِٱلسَّاعَةِ سَعِيرًا"
    },
    {
      "id": 2867,
      "verseKey": "25:12",
      "verseNumber": 12,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "إِذَا رَأَتْهُم مِّن مَّكَانٍۭ بَعِيدٍ سَمِعُوا۟ لَهَا تَغَيُّظًا وَزَفِيرًا"
    },
    {
      "id": 2868,
      "verseKey": "25:13",
      "verseNumber": 13,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "وَإِذَآ أُلْقُوا۟ مِنْهَا مَكَانًا ضَيِّقًا مُّقَرَّنِينَ دَعَوْا۟ هُنَالِكَ ثُبُورًا"
    },
    {
      "id": 2869,
      "verseKey": "25:14",
      "verseNumber": 14,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "لَّا تَدْعُوا۟ ٱلْيَوْمَ ثُبُورًا وَٰحِدًا وَٱدْعُوا۟ ثُبُورًا كَثِيرًا"
    },
    {
      "id": 2870,
      "verseKey": "25:15",
      "verseNumber": 15,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "قُلْ أَذَٰلِكَ خَيْرٌ أَمْ جَنَّةُ ٱلْخُلْدِ ٱلَّتِى وُعِدَ ٱلْمُتَّقُونَ ۚ كَانَتْ لَهُمْ جَزَآءً وَمَصِيرًا"
    },
    {
      "id": 2871,
      "verseKey": "25:16",
      "verseNumber": 16,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "لَّهُمْ فِيهَا مَا يَشَآءُونَ خَـٰلِدِينَ ۚ كَانَ عَلَىٰ رَبِّكَ وَعْدًا مَّسْـُٔولًا"
    },
    {
      "id": 2872,
      "verseKey": "25:17",
      "verseNumber": 17,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "وَيَوْمَ يَحْشُرُهُمْ وَمَا يَعْبُدُونَ مِن دُونِ ٱللَّهِ فَيَقُولُ ءَأَنتُمْ أَضْلَلْتُمْ عِبَادِى هَـٰٓؤُلَآءِ أَمْ هُمْ ضَلُّوا۟ ٱلسَّبِيلَ"
    },
    {
      "id": 2873,
      "verseKey": "25:18",
      "verseNumber": 18,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "قَالُوا۟ سُبْحَـٰنَكَ مَا كَانَ يَنۢبَغِى لَنَآ أَن نَّتَّخِذَ مِن دُونِكَ مِنْ أَوْلِيَآءَ وَلَـٰكِن مَّتَّعْتَهُمْ وَءَابَآءَهُمْ حَتَّىٰ نَسُوا۟ ٱلذِّكْرَ وَكَانُوا۟ قَوْمًۢا بُورًا"
    },
    {
      "id": 2874,
      "verseKey": "25:19",
      "verseNumber": 19,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "فَقَدْ كَذَّبُوكُم بِمَا تَقُولُونَ فَمَا تَسْتَطِيعُونَ صَرْفًا وَلَا نَصْرًا ۚ وَمَن يَظْلِم مِّنكُمْ نُذِقْهُ عَذَابًا كَبِيرًا"
    },
    {
      "id": 2875,
      "verseKey": "25:20",
      "verseNumber": 20,
      "pageNumber": 361,
      "juzNumber": 18,
      "hizbNumber": 36,
      "rubElHizbNumber": 144,
      "rukuNumber": 311,
      "manzilNumber": 4,
      "text": "وَمَآ أَرْسَلْنَا قَبْلَكَ مِنَ ٱلْمُرْسَلِينَ إِلَّآ إِنَّهُمْ لَيَأْكُلُونَ ٱلطَّعَامَ وَيَمْشُونَ فِى ٱلْأَسْوَاقِ ۗ وَجَعَلْنَا بَعْضَكُمْ لِبَعْضٍ فِتْنَةً أَتَصْبِرُونَ ۗ وَكَانَ رَبُّكَ بَصِيرًا"
    },
    {
      "id": 2876,
      "verseKey": "25:21",
      "verseNumber": 21,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "۞ وَقَالَ ٱلَّذِينَ لَا يَرْجُونَ لِقَآءَنَا لَوْلَآ أُنزِلَ عَلَيْنَا ٱلْمَلَـٰٓئِكَةُ أَوْ نَرَىٰ رَبَّنَا ۗ لَقَدِ ٱسْتَكْبَرُوا۟ فِىٓ أَنفُسِهِمْ وَعَتَوْ عُتُوًّا كَبِيرًا"
    },
    {
      "id": 2877,
      "verseKey": "25:22",
      "verseNumber": 22,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "يَوْمَ يَرَوْنَ ٱلْمَلَـٰٓئِكَةَ لَا بُشْرَىٰ يَوْمَئِذٍ لِّلْمُجْرِمِينَ وَيَقُولُونَ حِجْرًا مَّحْجُورًا"
    },
    {
      "id": 2878,
      "verseKey": "25:23",
      "verseNumber": 23,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَقَدِمْنَآ إِلَىٰ مَا عَمِلُوا۟ مِنْ عَمَلٍ فَجَعَلْنَـٰهُ هَبَآءً مَّنثُورًا"
    },
    {
      "id": 2879,
      "verseKey": "25:24",
      "verseNumber": 24,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "أَصْحَـٰبُ ٱلْجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُّسْتَقَرًّا وَأَحْسَنُ مَقِيلًا"
    },
    {
      "id": 2880,
      "verseKey": "25:25",
      "verseNumber": 25,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَيَوْمَ تَشَقَّقُ ٱلسَّمَآءُ بِٱلْغَمَـٰمِ وَنُزِّلَ ٱلْمَلَـٰٓئِكَةُ تَنزِيلًا"
    },
    {
      "id": 2881,
      "verseKey": "25:26",
      "verseNumber": 26,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "ٱلْمُلْكُ يَوْمَئِذٍ ٱلْحَقُّ لِلرَّحْمَـٰنِ ۚ وَكَانَ يَوْمًا عَلَى ٱلْكَـٰفِرِينَ عَسِيرًا"
    },
    {
      "id": 2882,
      "verseKey": "25:27",
      "verseNumber": 27,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَيَوْمَ يَعَضُّ ٱلظَّالِمُ عَلَىٰ يَدَيْهِ يَقُولُ يَـٰلَيْتَنِى ٱتَّخَذْتُ مَعَ ٱلرَّسُولِ سَبِيلًا"
    },
    {
      "id": 2883,
      "verseKey": "25:28",
      "verseNumber": 28,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "يَـٰوَيْلَتَىٰ لَيْتَنِى لَمْ أَتَّخِذْ فُلَانًا خَلِيلًا"
    },
    {
      "id": 2884,
      "verseKey": "25:29",
      "verseNumber": 29,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "لَّقَدْ أَضَلَّنِى عَنِ ٱلذِّكْرِ بَعْدَ إِذْ جَآءَنِى ۗ وَكَانَ ٱلشَّيْطَـٰنُ لِلْإِنسَـٰنِ خَذُولًا"
    },
    {
      "id": 2885,
      "verseKey": "25:30",
      "verseNumber": 30,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَقَالَ ٱلرَّسُولُ يَـٰرَبِّ إِنَّ قَوْمِى ٱتَّخَذُوا۟ هَـٰذَا ٱلْقُرْءَانَ مَهْجُورًا"
    },
    {
      "id": 2886,
      "verseKey": "25:31",
      "verseNumber": 31,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَكَذَٰلِكَ جَعَلْنَا لِكُلِّ نَبِىٍّ عَدُوًّا مِّنَ ٱلْمُجْرِمِينَ ۗ وَكَفَىٰ بِرَبِّكَ هَادِيًا وَنَصِيرًا"
    },
    {
      "id": 2887,
      "verseKey": "25:32",
      "verseNumber": 32,
      "pageNumber": 362,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَوْلَا نُزِّلَ عَلَيْهِ ٱلْقُرْءَانُ جُمْلَةً وَٰحِدَةً ۚ كَذَٰلِكَ لِنُثَبِّتَ بِهِۦ فُؤَادَكَ ۖ وَرَتَّلْنَـٰهُ تَرْتِيلًا"
    },
    {
      "id": 2888,
      "verseKey": "25:33",
      "verseNumber": 33,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "وَلَا يَأْتُونَكَ بِمَثَلٍ إِلَّا جِئْنَـٰكَ بِٱلْحَقِّ وَأَحْسَنَ تَفْسِيرًا"
    },
    {
      "id": 2889,
      "verseKey": "25:34",
      "verseNumber": 34,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 312,
      "manzilNumber": 4,
      "text": "ٱلَّذِينَ يُحْشَرُونَ عَلَىٰ وُجُوهِهِمْ إِلَىٰ جَهَنَّمَ أُو۟لَـٰٓئِكَ شَرٌّ مَّكَانًا وَأَضَلُّ سَبِيلًا"
    },
    {
      "id": 2890,
      "verseKey": "25:35",
      "verseNumber": 35,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَـٰبَ وَجَعَلْنَا مَعَهُۥٓ أَخَاهُ هَـٰرُونَ وَزِيرًا"
    },
    {
      "id": 2891,
      "verseKey": "25:36",
      "verseNumber": 36,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "فَقُلْنَا ٱذْهَبَآ إِلَى ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَـٰتِنَا فَدَمَّرْنَـٰهُمْ تَدْمِيرًا"
    },
    {
      "id": 2892,
      "verseKey": "25:37",
      "verseNumber": 37,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "وَقَوْمَ نُوحٍ لَّمَّا كَذَّبُوا۟ ٱلرُّسُلَ أَغْرَقْنَـٰهُمْ وَجَعَلْنَـٰهُمْ لِلنَّاسِ ءَايَةً ۖ وَأَعْتَدْنَا لِلظَّـٰلِمِينَ عَذَابًا أَلِيمًا"
    },
    {
      "id": 2893,
      "verseKey": "25:38",
      "verseNumber": 38,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "وَعَادًا وَثَمُودَا۟ وَأَصْحَـٰبَ ٱلرَّسِّ وَقُرُونًۢا بَيْنَ ذَٰلِكَ كَثِيرًا"
    },
    {
      "id": 2894,
      "verseKey": "25:39",
      "verseNumber": 39,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "وَكُلًّا ضَرَبْنَا لَهُ ٱلْأَمْثَـٰلَ ۖ وَكُلًّا تَبَّرْنَا تَتْبِيرًا"
    },
    {
      "id": 2895,
      "verseKey": "25:40",
      "verseNumber": 40,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "وَلَقَدْ أَتَوْا۟ عَلَى ٱلْقَرْيَةِ ٱلَّتِىٓ أُمْطِرَتْ مَطَرَ ٱلسَّوْءِ ۚ أَفَلَمْ يَكُونُوا۟ يَرَوْنَهَا ۚ بَلْ كَانُوا۟ لَا يَرْجُونَ نُشُورًا"
    },
    {
      "id": 2896,
      "verseKey": "25:41",
      "verseNumber": 41,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "وَإِذَا رَأَوْكَ إِن يَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَـٰذَا ٱلَّذِى بَعَثَ ٱللَّهُ رَسُولًا"
    },
    {
      "id": 2897,
      "verseKey": "25:42",
      "verseNumber": 42,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "إِن كَادَ لَيُضِلُّنَا عَنْ ءَالِهَتِنَا لَوْلَآ أَن صَبَرْنَا عَلَيْهَا ۚ وَسَوْفَ يَعْلَمُونَ حِينَ يَرَوْنَ ٱلْعَذَابَ مَنْ أَضَلُّ سَبِيلًا"
    },
    {
      "id": 2898,
      "verseKey": "25:43",
      "verseNumber": 43,
      "pageNumber": 363,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "أَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَـٰهَهُۥ هَوَىٰهُ أَفَأَنتَ تَكُونُ عَلَيْهِ وَكِيلًا"
    },
    {
      "id": 2899,
      "verseKey": "25:44",
      "verseNumber": 44,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 313,
      "manzilNumber": 4,
      "text": "أَمْ تَحْسَبُ أَنَّ أَكْثَرَهُمْ يَسْمَعُونَ أَوْ يَعْقِلُونَ ۚ إِنْ هُمْ إِلَّا كَٱلْأَنْعَـٰمِ ۖ بَلْ هُمْ أَضَلُّ سَبِيلًا"
    },
    {
      "id": 2900,
      "verseKey": "25:45",
      "verseNumber": 45,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "أَلَمْ تَرَ إِلَىٰ رَبِّكَ كَيْفَ مَدَّ ٱلظِّلَّ وَلَوْ شَآءَ لَجَعَلَهُۥ سَاكِنًا ثُمَّ جَعَلْنَا ٱلشَّمْسَ عَلَيْهِ دَلِيلًا"
    },
    {
      "id": 2901,
      "verseKey": "25:46",
      "verseNumber": 46,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "ثُمَّ قَبَضْنَـٰهُ إِلَيْنَا قَبْضًا يَسِيرًا"
    },
    {
      "id": 2902,
      "verseKey": "25:47",
      "verseNumber": 47,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَهُوَ ٱلَّذِى جَعَلَ لَكُمُ ٱلَّيْلَ لِبَاسًا وَٱلنَّوْمَ سُبَاتًا وَجَعَلَ ٱلنَّهَارَ نُشُورًا"
    },
    {
      "id": 2903,
      "verseKey": "25:48",
      "verseNumber": 48,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَهُوَ ٱلَّذِىٓ أَرْسَلَ ٱلرِّيَـٰحَ بُشْرًۢا بَيْنَ يَدَىْ رَحْمَتِهِۦ ۚ وَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءً طَهُورًا"
    },
    {
      "id": 2904,
      "verseKey": "25:49",
      "verseNumber": 49,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "لِّنُحْـِۧىَ بِهِۦ بَلْدَةً مَّيْتًا وَنُسْقِيَهُۥ مِمَّا خَلَقْنَآ أَنْعَـٰمًا وَأَنَاسِىَّ كَثِيرًا"
    },
    {
      "id": 2905,
      "verseKey": "25:50",
      "verseNumber": 50,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَلَقَدْ صَرَّفْنَـٰهُ بَيْنَهُمْ لِيَذَّكَّرُوا۟ فَأَبَىٰٓ أَكْثَرُ ٱلنَّاسِ إِلَّا كُفُورًا"
    },
    {
      "id": 2906,
      "verseKey": "25:51",
      "verseNumber": 51,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَلَوْ شِئْنَا لَبَعَثْنَا فِى كُلِّ قَرْيَةٍ نَّذِيرًا"
    },
    {
      "id": 2907,
      "verseKey": "25:52",
      "verseNumber": 52,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 145,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "فَلَا تُطِعِ ٱلْكَـٰفِرِينَ وَجَـٰهِدْهُم بِهِۦ جِهَادًا كَبِيرًا"
    },
    {
      "id": 2908,
      "verseKey": "25:53",
      "verseNumber": 53,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "۞ وَهُوَ ٱلَّذِى مَرَجَ ٱلْبَحْرَيْنِ هَـٰذَا عَذْبٌ فُرَاتٌ وَهَـٰذَا مِلْحٌ أُجَاجٌ وَجَعَلَ بَيْنَهُمَا بَرْزَخًا وَحِجْرًا مَّحْجُورًا"
    },
    {
      "id": 2909,
      "verseKey": "25:54",
      "verseNumber": 54,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَهُوَ ٱلَّذِى خَلَقَ مِنَ ٱلْمَآءِ بَشَرًا فَجَعَلَهُۥ نَسَبًا وَصِهْرًا ۗ وَكَانَ رَبُّكَ قَدِيرًا"
    },
    {
      "id": 2910,
      "verseKey": "25:55",
      "verseNumber": 55,
      "pageNumber": 364,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَنفَعُهُمْ وَلَا يَضُرُّهُمْ ۗ وَكَانَ ٱلْكَافِرُ عَلَىٰ رَبِّهِۦ ظَهِيرًا"
    },
    {
      "id": 2911,
      "verseKey": "25:56",
      "verseNumber": 56,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَمَآ أَرْسَلْنَـٰكَ إِلَّا مُبَشِّرًا وَنَذِيرًا"
    },
    {
      "id": 2912,
      "verseKey": "25:57",
      "verseNumber": 57,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "قُلْ مَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ إِلَّا مَن شَآءَ أَن يَتَّخِذَ إِلَىٰ رَبِّهِۦ سَبِيلًا"
    },
    {
      "id": 2913,
      "verseKey": "25:58",
      "verseNumber": 58,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَتَوَكَّلْ عَلَى ٱلْحَىِّ ٱلَّذِى لَا يَمُوتُ وَسَبِّحْ بِحَمْدِهِۦ ۚ وَكَفَىٰ بِهِۦ بِذُنُوبِ عِبَادِهِۦ خَبِيرًا"
    },
    {
      "id": 2914,
      "verseKey": "25:59",
      "verseNumber": 59,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "ٱلَّذِى خَلَقَ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۚ ٱلرَّحْمَـٰنُ فَسْـَٔلْ بِهِۦ خَبِيرًا"
    },
    {
      "id": 2915,
      "verseKey": "25:60",
      "verseNumber": 60,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 314,
      "manzilNumber": 4,
      "text": "وَإِذَا قِيلَ لَهُمُ ٱسْجُدُوا۟ لِلرَّحْمَـٰنِ قَالُوا۟ وَمَا ٱلرَّحْمَـٰنُ أَنَسْجُدُ لِمَا تَأْمُرُنَا وَزَادَهُمْ نُفُورًا ۩"
    },
    {
      "id": 2916,
      "verseKey": "25:61",
      "verseNumber": 61,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "تَبَارَكَ ٱلَّذِى جَعَلَ فِى ٱلسَّمَآءِ بُرُوجًا وَجَعَلَ فِيهَا سِرَٰجًا وَقَمَرًا مُّنِيرًا"
    },
    {
      "id": 2917,
      "verseKey": "25:62",
      "verseNumber": 62,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَهُوَ ٱلَّذِى جَعَلَ ٱلَّيْلَ وَٱلنَّهَارَ خِلْفَةً لِّمَنْ أَرَادَ أَن يَذَّكَّرَ أَوْ أَرَادَ شُكُورًا"
    },
    {
      "id": 2918,
      "verseKey": "25:63",
      "verseNumber": 63,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَعِبَادُ ٱلرَّحْمَـٰنِ ٱلَّذِينَ يَمْشُونَ عَلَى ٱلْأَرْضِ هَوْنًا وَإِذَا خَاطَبَهُمُ ٱلْجَـٰهِلُونَ قَالُوا۟ سَلَـٰمًا"
    },
    {
      "id": 2919,
      "verseKey": "25:64",
      "verseNumber": 64,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ يَبِيتُونَ لِرَبِّهِمْ سُجَّدًا وَقِيَـٰمًا"
    },
    {
      "id": 2920,
      "verseKey": "25:65",
      "verseNumber": 65,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ يَقُولُونَ رَبَّنَا ٱصْرِفْ عَنَّا عَذَابَ جَهَنَّمَ ۖ إِنَّ عَذَابَهَا كَانَ غَرَامًا"
    },
    {
      "id": 2921,
      "verseKey": "25:66",
      "verseNumber": 66,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "إِنَّهَا سَآءَتْ مُسْتَقَرًّا وَمُقَامًا"
    },
    {
      "id": 2922,
      "verseKey": "25:67",
      "verseNumber": 67,
      "pageNumber": 365,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ إِذَآ أَنفَقُوا۟ لَمْ يُسْرِفُوا۟ وَلَمْ يَقْتُرُوا۟ وَكَانَ بَيْنَ ذَٰلِكَ قَوَامًا"
    },
    {
      "id": 2923,
      "verseKey": "25:68",
      "verseNumber": 68,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ لَا يَدْعُونَ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَ وَلَا يَقْتُلُونَ ٱلنَّفْسَ ٱلَّتِى حَرَّمَ ٱللَّهُ إِلَّا بِٱلْحَقِّ وَلَا يَزْنُونَ ۚ وَمَن يَفْعَلْ ذَٰلِكَ يَلْقَ أَثَامًا"
    },
    {
      "id": 2924,
      "verseKey": "25:69",
      "verseNumber": 69,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "يُضَـٰعَفْ لَهُ ٱلْعَذَابُ يَوْمَ ٱلْقِيَـٰمَةِ وَيَخْلُدْ فِيهِۦ مُهَانًا"
    },
    {
      "id": 2925,
      "verseKey": "25:70",
      "verseNumber": 70,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "إِلَّا مَن تَابَ وَءَامَنَ وَعَمِلَ عَمَلًا صَـٰلِحًا فَأُو۟لَـٰٓئِكَ يُبَدِّلُ ٱللَّهُ سَيِّـَٔاتِهِمْ حَسَنَـٰتٍ ۗ وَكَانَ ٱللَّهُ غَفُورًا رَّحِيمًا"
    },
    {
      "id": 2926,
      "verseKey": "25:71",
      "verseNumber": 71,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَمَن تَابَ وَعَمِلَ صَـٰلِحًا فَإِنَّهُۥ يَتُوبُ إِلَى ٱللَّهِ مَتَابًا"
    },
    {
      "id": 2927,
      "verseKey": "25:72",
      "verseNumber": 72,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ لَا يَشْهَدُونَ ٱلزُّورَ وَإِذَا مَرُّوا۟ بِٱللَّغْوِ مَرُّوا۟ كِرَامًا"
    },
    {
      "id": 2928,
      "verseKey": "25:73",
      "verseNumber": 73,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ إِذَا ذُكِّرُوا۟ بِـَٔايَـٰتِ رَبِّهِمْ لَمْ يَخِرُّوا۟ عَلَيْهَا صُمًّا وَعُمْيَانًا"
    },
    {
      "id": 2929,
      "verseKey": "25:74",
      "verseNumber": 74,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "وَٱلَّذِينَ يَقُولُونَ رَبَّنَا هَبْ لَنَا مِنْ أَزْوَٰجِنَا وَذُرِّيَّـٰتِنَا قُرَّةَ أَعْيُنٍ وَٱجْعَلْنَا لِلْمُتَّقِينَ إِمَامًا"
    },
    {
      "id": 2930,
      "verseKey": "25:75",
      "verseNumber": 75,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "أُو۟لَـٰٓئِكَ يُجْزَوْنَ ٱلْغُرْفَةَ بِمَا صَبَرُوا۟ وَيُلَقَّوْنَ فِيهَا تَحِيَّةً وَسَلَـٰمًا"
    },
    {
      "id": 2931,
      "verseKey": "25:76",
      "verseNumber": 76,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "خَـٰلِدِينَ فِيهَا ۚ حَسُنَتْ مُسْتَقَرًّا وَمُقَامًا"
    },
    {
      "id": 2932,
      "verseKey": "25:77",
      "verseNumber": 77,
      "pageNumber": 366,
      "juzNumber": 19,
      "hizbNumber": 37,
      "rubElHizbNumber": 146,
      "rukuNumber": 315,
      "manzilNumber": 4,
      "text": "قُلْ مَا يَعْبَؤُا۟ بِكُمْ رَبِّى لَوْلَا دُعَآؤُكُمْ ۖ فَقَدْ كَذَّبْتُمْ فَسَوْفَ يَكُونُ لِزَامًۢا"
    }
  ]
}
