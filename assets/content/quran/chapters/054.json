  "verses": [
    {
      "id": 4847,
      "verseKey": "54:1",
      "verseNumber": 1,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": " ٱقْتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلْقَمَرُ"
    },
    {
      "id": 4848,
      "verseKey": "54:2",
      "verseNumber": 2,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَإِن يَرَوْا۟ ءَايَةً يُعْرِضُوا۟ وَيَقُولُوا۟ سِحْرٌ مُّسْتَمِرٌّ"
    },
    {
      "id": 4849,
      "verseKey": "54:3",
      "verseNumber": 3,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَكَذَّبُوا۟ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُمْ ۚ وَكُلُّ أَمْرٍ مُّسْتَقِرٌّ"
    },
    {
      "id": 4850,
      "verseKey": "54:4",
      "verseNumber": 4,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَلَقَدْ جَآءَهُم مِّنَ ٱلْأَنۢبَآءِ مَا فِيهِ مُزْدَجَرٌ"
    },
    {
      "id": 4851,
      "verseKey": "54:5",
      "verseNumber": 5,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "حِكْمَةٌۢ بَـٰلِغَةٌ ۖ فَمَا تُغْنِ ٱلنُّذُرُ"
    },
    {
      "id": 4852,
      "verseKey": "54:6",
      "verseNumber": 6,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "فَتَوَلَّ عَنْهُمْ ۘ يَوْمَ يَدْعُ ٱلدَّاعِ إِلَىٰ شَىْءٍ نُّكُرٍ"
    },
    {
      "id": 4853,
      "verseKey": "54:7",
      "verseNumber": 7,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "خُشَّعًا أَبْصَـٰرُهُمْ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ كَأَنَّهُمْ جَرَادٌ مُّنتَشِرٌ"
    },
    {
      "id": 4854,
      "verseKey": "54:8",
      "verseNumber": 8,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "مُّهْطِعِينَ إِلَى ٱلدَّاعِ ۖ يَقُولُ ٱلْكَـٰفِرُونَ هَـٰذَا يَوْمٌ عَسِرٌ"
    },
    {
      "id": 4855,
      "verseKey": "54:9",
      "verseNumber": 9,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "۞ كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍ فَكَذَّبُوا۟ عَبْدَنَا وَقَالُوا۟ مَجْنُونٌ وَٱزْدُجِرَ"
    },
    {
      "id": 4856,
      "verseKey": "54:10",
      "verseNumber": 10,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "فَدَعَا رَبَّهُۥٓ أَنِّى مَغْلُوبٌ فَٱنتَصِرْ"
    },
    {
      "id": 4857,
      "verseKey": "54:11",
      "verseNumber": 11,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "فَفَتَحْنَآ أَبْوَٰبَ ٱلسَّمَآءِ بِمَآءٍ مُّنْهَمِرٍ"
    },
    {
      "id": 4858,
      "verseKey": "54:12",
      "verseNumber": 12,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَفَجَّرْنَا ٱلْأَرْضَ عُيُونًا فَٱلْتَقَى ٱلْمَآءُ عَلَىٰٓ أَمْرٍ قَدْ قُدِرَ"
    },
    {
      "id": 4859,
      "verseKey": "54:13",
      "verseNumber": 13,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَحَمَلْنَـٰهُ عَلَىٰ ذَاتِ أَلْوَٰحٍ وَدُسُرٍ"
    },
    {
      "id": 4860,
      "verseKey": "54:14",
      "verseNumber": 14,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "تَجْرِى بِأَعْيُنِنَا جَزَآءً لِّمَن كَانَ كُفِرَ"
    },
    {
      "id": 4861,
      "verseKey": "54:15",
      "verseNumber": 15,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَلَقَد تَّرَكْنَـٰهَآ ءَايَةً فَهَلْ مِن مُّدَّكِرٍ"
    },
    {
      "id": 4862,
      "verseKey": "54:16",
      "verseNumber": 16,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ"
    },
    {
      "id": 4863,
      "verseKey": "54:17",
      "verseNumber": 17,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍ"
    },
    {
      "id": 4864,
      "verseKey": "54:18",
      "verseNumber": 18,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "كَذَّبَتْ عَادٌ فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ"
    },
    {
      "id": 4865,
      "verseKey": "54:19",
      "verseNumber": 19,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ رِيحًا صَرْصَرًا فِى يَوْمِ نَحْسٍ مُّسْتَمِرٍّ"
    },
    {
      "id": 4866,
      "verseKey": "54:20",
      "verseNumber": 20,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "تَنزِعُ ٱلنَّاسَ كَأَنَّهُمْ أَعْجَازُ نَخْلٍ مُّنقَعِرٍ"
    },
    {
      "id": 4867,
      "verseKey": "54:21",
      "verseNumber": 21,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ"
    },
    {
      "id": 4868,
      "verseKey": "54:22",
      "verseNumber": 22,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 465,
      "manzilNumber": 7,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍ"
    },
    {
      "id": 4869,
      "verseKey": "54:23",
      "verseNumber": 23,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "كَذَّبَتْ ثَمُودُ بِٱلنُّذُرِ"
    },
    {
      "id": 4870,
      "verseKey": "54:24",
      "verseNumber": 24,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "فَقَالُوٓا۟ أَبَشَرًا مِّنَّا وَٰحِدًا نَّتَّبِعُهُۥٓ إِنَّآ إِذًا لَّفِى ضَلَـٰلٍ وَسُعُرٍ"
    },
    {
      "id": 4871,
      "verseKey": "54:25",
      "verseNumber": 25,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "أَءُلْقِىَ ٱلذِّكْرُ عَلَيْهِ مِنۢ بَيْنِنَا بَلْ هُوَ كَذَّابٌ أَشِرٌ"
    },
    {
      "id": 4872,
      "verseKey": "54:26",
      "verseNumber": 26,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "سَيَعْلَمُونَ غَدًا مَّنِ ٱلْكَذَّابُ ٱلْأَشِرُ"
    },
    {
      "id": 4873,
      "verseKey": "54:27",
      "verseNumber": 27,
      "pageNumber": 529,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "إِنَّا مُرْسِلُوا۟ ٱلنَّاقَةِ فِتْنَةً لَّهُمْ فَٱرْتَقِبْهُمْ وَٱصْطَبِرْ"
    },
    {
      "id": 4874,
      "verseKey": "54:28",
      "verseNumber": 28,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "وَنَبِّئْهُمْ أَنَّ ٱلْمَآءَ قِسْمَةٌۢ بَيْنَهُمْ ۖ كُلُّ شِرْبٍ مُّحْتَضَرٌ"
    },
    {
      "id": 4875,
      "verseKey": "54:29",
      "verseNumber": 29,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "فَنَادَوْا۟ صَاحِبَهُمْ فَتَعَاطَىٰ فَعَقَرَ"
    },
    {
      "id": 4876,
      "verseKey": "54:30",
      "verseNumber": 30,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ"
    },
    {
      "id": 4877,
      "verseKey": "54:31",
      "verseNumber": 31,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ صَيْحَةً وَٰحِدَةً فَكَانُوا۟ كَهَشِيمِ ٱلْمُحْتَظِرِ"
    },
    {
      "id": 4878,
      "verseKey": "54:32",
      "verseNumber": 32,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍ"
    },
    {
      "id": 4879,
      "verseKey": "54:33",
      "verseNumber": 33,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "كَذَّبَتْ قَوْمُ لُوطٍۭ بِٱلنُّذُرِ"
    },
    {
      "id": 4880,
      "verseKey": "54:34",
      "verseNumber": 34,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ حَاصِبًا إِلَّآ ءَالَ لُوطٍ ۖ نَّجَّيْنَـٰهُم بِسَحَرٍ"
    },
    {
      "id": 4881,
      "verseKey": "54:35",
      "verseNumber": 35,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "نِّعْمَةً مِّنْ عِندِنَا ۚ كَذَٰلِكَ نَجْزِى مَن شَكَرَ"
    },
    {
      "id": 4882,
      "verseKey": "54:36",
      "verseNumber": 36,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "وَلَقَدْ أَنذَرَهُم بَطْشَتَنَا فَتَمَارَوْا۟ بِٱلنُّذُرِ"
    },
    {
      "id": 4883,
      "verseKey": "54:37",
      "verseNumber": 37,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "وَلَقَدْ رَٰوَدُوهُ عَن ضَيْفِهِۦ فَطَمَسْنَآ أَعْيُنَهُمْ فَذُوقُوا۟ عَذَابِى وَنُذُرِ"
    },
    {
      "id": 4884,
      "verseKey": "54:38",
      "verseNumber": 38,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "وَلَقَدْ صَبَّحَهُم بُكْرَةً عَذَابٌ مُّسْتَقِرٌّ"
    },
    {
      "id": 4885,
      "verseKey": "54:39",
      "verseNumber": 39,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "فَذُوقُوا۟ عَذَابِى وَنُذُرِ"
    },
    {
      "id": 4886,
      "verseKey": "54:40",
      "verseNumber": 40,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 466,
      "manzilNumber": 7,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍ"
    },
    {
      "id": 4887,
      "verseKey": "54:41",
      "verseNumber": 41,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 467,
      "manzilNumber": 7,
      "text": "وَلَقَدْ جَآءَ ءَالَ فِرْعَوْنَ ٱلنُّذُرُ"
    },
    {
      "id": 4888,
      "verseKey": "54:42",
      "verseNumber": 42,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 467,
      "manzilNumber": 7,
      "text": "كَذَّبُوا۟ بِـَٔايَـٰتِنَا كُلِّهَا فَأَخَذْنَـٰهُمْ أَخْذَ عَزِيزٍ مُّقْتَدِرٍ"
    },
    {
      "id": 4889,
      "verseKey": "54:43",
      "verseNumber": 43,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 467,
      "manzilNumber": 7,
      "text": "أَكُفَّارُكُمْ خَيْرٌ مِّنْ أُو۟لَـٰٓئِكُمْ أَمْ لَكُم بَرَآءَةٌ فِى ٱلزُّبُرِ"
    },
    {
      "id": 4890,
      "verseKey": "54:44",
      "verseNumber": 44,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 467,
      "manzilNumber": 7,
      "text": "أَمْ يَقُولُونَ نَحْنُ جَمِيعٌ مُّنتَصِرٌ"
    },
    {
      "id": 4891,
      "verseKey": "54:45",
      "verseNumber": 45,
      "pageNumber": 530,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 212,
      "rukuNumber": 467,
      "manzilNumber": 7,
