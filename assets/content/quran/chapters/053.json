  "verses": [
    {
      "id": 4785,
      "verseKey": "53:1",
      "verseNumber": 1,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": " وَٱلنَّجْمِ إِذَا هَوَىٰ"
    },
    {
      "id": 4786,
      "verseKey": "53:2",
      "verseNumber": 2,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَىٰ"
    },
    {
      "id": 4787,
      "verseKey": "53:3",
      "verseNumber": 3,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "وَمَا يَنطِقُ عَنِ ٱلْهَوَىٰٓ"
    },
    {
      "id": 4788,
      "verseKey": "53:4",
      "verseNumber": 4,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "إِنْ هُوَ إِلَّا وَحْىٌ يُوحَىٰ"
    },
    {
      "id": 4789,
      "verseKey": "53:5",
      "verseNumber": 5,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "عَلَّمَهُۥ شَدِيدُ ٱلْقُوَىٰ"
    },
    {
      "id": 4790,
      "verseKey": "53:6",
      "verseNumber": 6,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "ذُو مِرَّةٍ فَٱسْتَوَىٰ"
    },
    {
      "id": 4791,
      "verseKey": "53:7",
      "verseNumber": 7,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "وَهُوَ بِٱلْأُفُقِ ٱلْأَعْلَىٰ"
    },
    {
      "id": 4792,
      "verseKey": "53:8",
      "verseNumber": 8,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "ثُمَّ دَنَا فَتَدَلَّىٰ"
    },
    {
      "id": 4793,
      "verseKey": "53:9",
      "verseNumber": 9,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "فَكَانَ قَابَ قَوْسَيْنِ أَوْ أَدْنَىٰ"
    },
    {
      "id": 4794,
      "verseKey": "53:10",
      "verseNumber": 10,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "فَأَوْحَىٰٓ إِلَىٰ عَبْدِهِۦ مَآ أَوْحَىٰ"
    },
    {
      "id": 4795,
      "verseKey": "53:11",
      "verseNumber": 11,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "مَا كَذَبَ ٱلْفُؤَادُ مَا رَأَىٰٓ"
    },
    {
      "id": 4796,
      "verseKey": "53:12",
      "verseNumber": 12,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "أَفَتُمَـٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ"
    },
    {
      "id": 4797,
      "verseKey": "53:13",
      "verseNumber": 13,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "وَلَقَدْ رَءَاهُ نَزْلَةً أُخْرَىٰ"
    },
    {
      "id": 4798,
      "verseKey": "53:14",
      "verseNumber": 14,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "عِندَ سِدْرَةِ ٱلْمُنتَهَىٰ"
    },
    {
      "id": 4799,
      "verseKey": "53:15",
      "verseNumber": 15,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "عِندَهَا جَنَّةُ ٱلْمَأْوَىٰٓ"
    },
    {
      "id": 4800,
      "verseKey": "53:16",
      "verseNumber": 16,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "إِذْ يَغْشَى ٱلسِّدْرَةَ مَا يَغْشَىٰ"
    },
    {
      "id": 4801,
      "verseKey": "53:17",
      "verseNumber": 17,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "مَا زَاغَ ٱلْبَصَرُ وَمَا طَغَىٰ"
    },
    {
      "id": 4802,
      "verseKey": "53:18",
      "verseNumber": 18,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "لَقَدْ رَأَىٰ مِنْ ءَايَـٰتِ رَبِّهِ ٱلْكُبْرَىٰٓ"
    },
    {
      "id": 4803,
      "verseKey": "53:19",
      "verseNumber": 19,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "أَفَرَءَيْتُمُ ٱللَّـٰتَ وَٱلْعُزَّىٰ"
    },
    {
      "id": 4804,
      "verseKey": "53:20",
      "verseNumber": 20,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلْأُخْرَىٰٓ"
    },
    {
      "id": 4805,
      "verseKey": "53:21",
      "verseNumber": 21,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلْأُنثَىٰ"
    },
    {
      "id": 4806,
      "verseKey": "53:22",
      "verseNumber": 22,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "تِلْكَ إِذًا قِسْمَةٌ ضِيزَىٰٓ"
    },
    {
      "id": 4807,
      "verseKey": "53:23",
      "verseNumber": 23,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "إِنْ هِىَ إِلَّآ أَسْمَآءٌ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلْطَـٰنٍ ۚ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهْوَى ٱلْأَنفُسُ ۖ وَلَقَدْ جَآءَهُم مِّن رَّبِّهِمُ ٱلْهُدَىٰٓ"
    },
    {
      "id": 4808,
      "verseKey": "53:24",
      "verseNumber": 24,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "أَمْ لِلْإِنسَـٰنِ مَا تَمَنَّىٰ"
    },
    {
      "id": 4809,
      "verseKey": "53:25",
      "verseNumber": 25,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 462,
      "manzilNumber": 7,
      "text": "فَلِلَّهِ ٱلْـَٔاخِرَةُ وَٱلْأُولَىٰ"
    },
    {
      "id": 4810,
      "verseKey": "53:26",
      "verseNumber": 26,
      "pageNumber": 526,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "۞ وَكَم مِّن مَّلَكٍ فِى ٱلسَّمَـٰوَٰتِ لَا تُغْنِى شَفَـٰعَتُهُمْ شَيْـًٔا إِلَّا مِنۢ بَعْدِ أَن يَأْذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرْضَىٰٓ"
    },
    {
      "id": 4811,
      "verseKey": "53:27",
      "verseNumber": 27,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْـَٔاخِرَةِ لَيُسَمُّونَ ٱلْمَلَـٰٓئِكَةَ تَسْمِيَةَ ٱلْأُنثَىٰ"
    },
    {
      "id": 4812,
      "verseKey": "53:28",
      "verseNumber": 28,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "وَمَا لَهُم بِهِۦ مِنْ عِلْمٍ ۖ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ ۖ وَإِنَّ ٱلظَّنَّ لَا يُغْنِى مِنَ ٱلْحَقِّ شَيْـًٔا"
    },
    {
      "id": 4813,
      "verseKey": "53:29",
      "verseNumber": 29,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "فَأَعْرِضْ عَن مَّن تَوَلَّىٰ عَن ذِكْرِنَا وَلَمْ يُرِدْ إِلَّا ٱلْحَيَوٰةَ ٱلدُّنْيَا"
    },
    {
      "id": 4814,
      "verseKey": "53:30",
      "verseNumber": 30,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "ذَٰلِكَ مَبْلَغُهُم مِّنَ ٱلْعِلْمِ ۚ إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِمَنِ ٱهْتَدَىٰ"
    },
    {
      "id": 4815,
      "verseKey": "53:31",
      "verseNumber": 31,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "وَلِلَّهِ مَا فِى ٱلسَّمَـٰوَٰتِ وَمَا فِى ٱلْأَرْضِ لِيَجْزِىَ ٱلَّذِينَ أَسَـٰٓـُٔوا۟ بِمَا عَمِلُوا۟ وَيَجْزِىَ ٱلَّذِينَ أَحْسَنُوا۟ بِٱلْحُسْنَى"
    },
    {
      "id": 4816,
      "verseKey": "53:32",
      "verseNumber": 32,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 463,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ يَجْتَنِبُونَ كَبَـٰٓئِرَ ٱلْإِثْمِ وَٱلْفَوَٰحِشَ إِلَّا ٱللَّمَمَ ۚ إِنَّ رَبَّكَ وَٰسِعُ ٱلْمَغْفِرَةِ ۚ هُوَ أَعْلَمُ بِكُمْ إِذْ أَنشَأَكُم مِّنَ ٱلْأَرْضِ وَإِذْ أَنتُمْ أَجِنَّةٌ فِى بُطُونِ أُمَّهَـٰتِكُمْ ۖ فَلَا تُزَكُّوٓا۟ أَنفُسَكُمْ ۖ هُوَ أَعْلَمُ بِمَنِ ٱتَّقَىٰٓ"
    },
    {
      "id": 4817,
      "verseKey": "53:33",
      "verseNumber": 33,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "أَفَرَءَيْتَ ٱلَّذِى تَوَلَّىٰ"
    },
    {
      "id": 4818,
      "verseKey": "53:34",
      "verseNumber": 34,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَعْطَىٰ قَلِيلًا وَأَكْدَىٰٓ"
    },
    {
      "id": 4819,
      "verseKey": "53:35",
      "verseNumber": 35,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "أَعِندَهُۥ عِلْمُ ٱلْغَيْبِ فَهُوَ يَرَىٰٓ"
    },
    {
      "id": 4820,
      "verseKey": "53:36",
      "verseNumber": 36,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "أَمْ لَمْ يُنَبَّأْ بِمَا فِى صُحُفِ مُوسَىٰ"
    },
    {
      "id": 4821,
      "verseKey": "53:37",
      "verseNumber": 37,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَإِبْرَٰهِيمَ ٱلَّذِى وَفَّىٰٓ"
    },
    {
      "id": 4822,
      "verseKey": "53:38",
      "verseNumber": 38,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "أَلَّا تَزِرُ وَازِرَةٌ وِزْرَ أُخْرَىٰ"
    },
    {
      "id": 4823,
      "verseKey": "53:39",
      "verseNumber": 39,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَن لَّيْسَ لِلْإِنسَـٰنِ إِلَّا مَا سَعَىٰ"
    },
    {
      "id": 4824,
      "verseKey": "53:40",
      "verseNumber": 40,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّ سَعْيَهُۥ سَوْفَ يُرَىٰ"
    },
    {
      "id": 4825,
      "verseKey": "53:41",
      "verseNumber": 41,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "ثُمَّ يُجْزَىٰهُ ٱلْجَزَآءَ ٱلْأَوْفَىٰ"
    },
    {
      "id": 4826,
      "verseKey": "53:42",
      "verseNumber": 42,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّ إِلَىٰ رَبِّكَ ٱلْمُنتَهَىٰ"
    },
    {
      "id": 4827,
      "verseKey": "53:43",
      "verseNumber": 43,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّهُۥ هُوَ أَضْحَكَ وَأَبْكَىٰ"
    },
    {
      "id": 4828,
      "verseKey": "53:44",
      "verseNumber": 44,
      "pageNumber": 527,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّهُۥ هُوَ أَمَاتَ وَأَحْيَا"
    },
    {
      "id": 4829,
      "verseKey": "53:45",
      "verseNumber": 45,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّهُۥ خَلَقَ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰ"
    },
    {
      "id": 4830,
      "verseKey": "53:46",
      "verseNumber": 46,
      "pageNumber": 528,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "مِن نُّطْفَةٍ إِذَا تُمْنَىٰ"
