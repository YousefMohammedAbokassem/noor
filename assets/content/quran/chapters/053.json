      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّ عَلَيْهِ ٱلنَّشْأَةَ ٱلْأُخْرَىٰ"
