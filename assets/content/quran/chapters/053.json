      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 211,
      "rukuNumber": 464,
      "manzilNumber": 7,
      "text": "وَأَنَّهُۥ هُوَ أَغْنَىٰ وَأَقْنَىٰ"
