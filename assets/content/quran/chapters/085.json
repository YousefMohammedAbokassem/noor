{
  "id": 85,
  "nameAr": "البروج",
  "nameSimple": "Al-Buruj",
  "nameComplex": "Al-Burūj",
  "translatedName": "The Mansions of the Stars",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 27,
  "versesCount": 22,
  "bismillahPre": true,
  "startPage": 590,
  "endPage": 590,
  "verses": [
    {
      "id": 5910,
      "verseKey": "85:1",
      "verseNumber": 1,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": " وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ"
    },
    {
      "id": 5911,
      "verseKey": "85:2",
      "verseNumber": 2,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "وَٱلْيَوْمِ ٱلْمَوْعُودِ"
    },
    {
      "id": 5912,
      "verseKey": "85:3",
      "verseNumber": 3,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "وَشَاهِدٍ وَمَشْهُودٍ"
    },
    {
      "id": 5913,
      "verseKey": "85:4",
      "verseNumber": 4,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "قُتِلَ أَصْحَـٰبُ ٱلْأُخْدُودِ"
    },
    {
      "id": 5914,
      "verseKey": "85:5",
      "verseNumber": 5,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ"
    },
    {
      "id": 5915,
      "verseKey": "85:6",
      "verseNumber": 6,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "إِذْ هُمْ عَلَيْهَا قُعُودٌ"
    },
    {
      "id": 5916,
      "verseKey": "85:7",
      "verseNumber": 7,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ"
    },
    {
      "id": 5917,
      "verseKey": "85:8",
      "verseNumber": 8,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ"
    },
    {
      "id": 5918,
      "verseKey": "85:9",
      "verseNumber": 9,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍ شَهِيدٌ"
    },
    {
      "id": 5919,
      "verseKey": "85:10",
      "verseNumber": 10,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَـٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ"
    },
    {
      "id": 5920,
      "verseKey": "85:11",
      "verseNumber": 11,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ جَنَّـٰتٌ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ"
    },
    {
      "id": 5921,
      "verseKey": "85:12",
      "verseNumber": 12,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ"
    },
    {
      "id": 5922,
      "verseKey": "85:13",
      "verseNumber": 13,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ"
    },
    {
      "id": 5923,
      "verseKey": "85:14",
      "verseNumber": 14,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ"
    },
    {
      "id": 5924,
      "verseKey": "85:15",
      "verseNumber": 15,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ"
    },
    {
      "id": 5925,
      "verseKey": "85:16",
      "verseNumber": 16,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "فَعَّالٌ لِّمَا يُرِيدُ"
    },
    {
      "id": 5926,
      "verseKey": "85:17",
      "verseNumber": 17,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ"
    },
    {
      "id": 5927,
      "verseKey": "85:18",
      "verseNumber": 18,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "فِرْعَوْنَ وَثَمُودَ"
    },
    {
      "id": 5928,
      "verseKey": "85:19",
      "verseNumber": 19,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ"
    },
    {
      "id": 5929,
      "verseKey": "85:20",
      "verseNumber": 20,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ"
    },
    {
      "id": 5930,
      "verseKey": "85:21",
      "verseNumber": 21,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "بَلْ هُوَ قُرْءَانٌ مَّجِيدٌ"
    },
    {
      "id": 5931,
      "verseKey": "85:22",
      "verseNumber": 22,
      "pageNumber": 590,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 529,
      "manzilNumber": 7,
      "text": "فِى لَوْحٍ مَّحْفُوظٍۭ"
    }
  ]
}
