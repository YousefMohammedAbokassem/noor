    },
    {
      "id": 5325,
      "verseKey": "69:2",
      "verseNumber": 2,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "مَا ٱلْحَآقَّةُ"
    },
    {
      "id": 5326,
      "verseKey": "69:3",
      "verseNumber": 3,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْحَآقَّةُ"
    },
    {
      "id": 5327,
      "verseKey": "69:4",
      "verseNumber": 4,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "كَذَّبَتْ ثَمُودُ وَعَادٌۢ بِٱلْقَارِعَةِ"
    },
    {
      "id": 5328,
      "verseKey": "69:5",
      "verseNumber": 5,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَأَمَّا ثَمُودُ فَأُهْلِكُوا۟ بِٱلطَّاغِيَةِ"
    },
    {
      "id": 5329,
      "verseKey": "69:6",
      "verseNumber": 6,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَأَمَّا عَادٌ فَأُهْلِكُوا۟ بِرِيحٍ صَرْصَرٍ عَاتِيَةٍ"
    },
    {
      "id": 5330,
      "verseKey": "69:7",
      "verseNumber": 7,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٍ وَثَمَـٰنِيَةَ أَيَّامٍ حُسُومًا فَتَرَى ٱلْقَوْمَ فِيهَا صَرْعَىٰ كَأَنَّهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ"
    },
    {
      "id": 5331,
      "verseKey": "69:8",
      "verseNumber": 8,
      "pageNumber": 566,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَهَلْ تَرَىٰ لَهُم مِّنۢ بَاقِيَةٍ"
    },
    {
      "id": 5332,
      "verseKey": "69:9",
      "verseNumber": 9,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَجَآءَ فِرْعَوْنُ وَمَن قَبْلَهُۥ وَٱلْمُؤْتَفِكَـٰتُ بِٱلْخَاطِئَةِ"
    },
    {
      "id": 5333,
      "verseKey": "69:10",
      "verseNumber": 10,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَعَصَوْا۟ رَسُولَ رَبِّهِمْ فَأَخَذَهُمْ أَخْذَةً رَّابِيَةً"
    },
    {
      "id": 5334,
      "verseKey": "69:11",
      "verseNumber": 11,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "إِنَّا لَمَّا طَغَا ٱلْمَآءُ حَمَلْنَـٰكُمْ فِى ٱلْجَارِيَةِ"
    },
    {
      "id": 5335,
      "verseKey": "69:12",
      "verseNumber": 12,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "لِنَجْعَلَهَا لَكُمْ تَذْكِرَةً وَتَعِيَهَآ أُذُنٌ وَٰعِيَةٌ"
    },
    {
      "id": 5336,
      "verseKey": "69:13",
      "verseNumber": 13,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَإِذَا نُفِخَ فِى ٱلصُّورِ نَفْخَةٌ وَٰحِدَةٌ"
    },
    {
      "id": 5337,
      "verseKey": "69:14",
      "verseNumber": 14,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَحُمِلَتِ ٱلْأَرْضُ وَٱلْجِبَالُ فَدُكَّتَا دَكَّةً وَٰحِدَةً"
    },
    {
      "id": 5338,
      "verseKey": "69:15",
      "verseNumber": 15,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَيَوْمَئِذٍ وَقَعَتِ ٱلْوَاقِعَةُ"
    },
    {
      "id": 5339,
      "verseKey": "69:16",
      "verseNumber": 16,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِىَ يَوْمَئِذٍ وَاهِيَةٌ"
    },
    {
      "id": 5340,
      "verseKey": "69:17",
      "verseNumber": 17,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَٱلْمَلَكُ عَلَىٰٓ أَرْجَآئِهَا ۚ وَيَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمَـٰنِيَةٌ"
    },
    {
      "id": 5341,
      "verseKey": "69:18",
      "verseNumber": 18,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "يَوْمَئِذٍ تُعْرَضُونَ لَا تَخْفَىٰ مِنكُمْ خَافِيَةٌ"
    },
    {
      "id": 5342,
      "verseKey": "69:19",
      "verseNumber": 19,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ ٱقْرَءُوا۟ كِتَـٰبِيَهْ"
    },
    {
      "id": 5343,
      "verseKey": "69:20",
      "verseNumber": 20,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "إِنِّى ظَنَنتُ أَنِّى مُلَـٰقٍ حِسَابِيَهْ"
    },
    {
      "id": 5344,
      "verseKey": "69:21",
      "verseNumber": 21,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ"
    },
    {
      "id": 5345,
      "verseKey": "69:22",
      "verseNumber": 22,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فِى جَنَّةٍ عَالِيَةٍ"
    },
    {
      "id": 5346,
      "verseKey": "69:23",
      "verseNumber": 23,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "قُطُوفُهَا دَانِيَةٌ"
    },
    {
      "id": 5347,
      "verseKey": "69:24",
      "verseNumber": 24,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَآ أَسْلَفْتُمْ فِى ٱلْأَيَّامِ ٱلْخَالِيَةِ"
    },
    {
      "id": 5348,
      "verseKey": "69:25",
      "verseNumber": 25,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِشِمَالِهِۦ فَيَقُولُ يَـٰلَيْتَنِى لَمْ أُوتَ كِتَـٰبِيَهْ"
    },
    {
      "id": 5349,
      "verseKey": "69:26",
      "verseNumber": 26,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَلَمْ أَدْرِ مَا حِسَابِيَهْ"
    },
    {
      "id": 5350,
      "verseKey": "69:27",
      "verseNumber": 27,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "يَـٰلَيْتَهَا كَانَتِ ٱلْقَاضِيَةَ"
    },
    {
      "id": 5351,
      "verseKey": "69:28",
      "verseNumber": 28,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "مَآ أَغْنَىٰ عَنِّى مَالِيَهْ ۜ"
    },
    {
      "id": 5352,
      "verseKey": "69:29",
      "verseNumber": 29,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "هَلَكَ عَنِّى سُلْطَـٰنِيَهْ"
    },
    {
      "id": 5353,
      "verseKey": "69:30",
      "verseNumber": 30,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "خُذُوهُ فَغُلُّوهُ"
    },
    {
      "id": 5354,
      "verseKey": "69:31",
      "verseNumber": 31,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "ثُمَّ ٱلْجَحِيمَ صَلُّوهُ"
    },
    {
      "id": 5355,
      "verseKey": "69:32",
      "verseNumber": 32,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "ثُمَّ فِى سِلْسِلَةٍ ذَرْعُهَا سَبْعُونَ ذِرَاعًا فَٱسْلُكُوهُ"
    },
    {
      "id": 5356,
      "verseKey": "69:33",
      "verseNumber": 33,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ كَانَ لَا يُؤْمِنُ بِٱللَّهِ ٱلْعَظِيمِ"
    },
    {
      "id": 5357,
      "verseKey": "69:34",
      "verseNumber": 34,
      "pageNumber": 567,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"
    },
    {
      "id": 5358,
      "verseKey": "69:35",
      "verseNumber": 35,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "فَلَيْسَ لَهُ ٱلْيَوْمَ هَـٰهُنَا حَمِيمٌ"
    },
    {
      "id": 5359,
      "verseKey": "69:36",
      "verseNumber": 36,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ"
    },
    {
      "id": 5360,
      "verseKey": "69:37",
      "verseNumber": 37,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 502,
      "manzilNumber": 7,
      "text": "لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَـٰطِـُٔونَ"
    },
    {
      "id": 5361,
      "verseKey": "69:38",
      "verseNumber": 38,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ"
    },
    {
      "id": 5362,
      "verseKey": "69:39",
      "verseNumber": 39,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "وَمَا لَا تُبْصِرُونَ"
    },
    {
      "id": 5363,
      "verseKey": "69:40",
      "verseNumber": 40,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ"
    },
    {
      "id": 5364,
      "verseKey": "69:41",
      "verseNumber": 41,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "وَمَا هُوَ بِقَوْلِ شَاعِرٍ ۚ قَلِيلًا مَّا تُؤْمِنُونَ"
    },
    {
      "id": 5365,
      "verseKey": "69:42",
      "verseNumber": 42,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "وَلَا بِقَوْلِ كَاهِنٍ ۚ قَلِيلًا مَّا تَذَكَّرُونَ"
    },
    {
      "id": 5366,
      "verseKey": "69:43",
      "verseNumber": 43,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ"
    },
    {
      "id": 5367,
      "verseKey": "69:44",
      "verseNumber": 44,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ"
    },
    {
      "id": 5368,
      "verseKey": "69:45",
      "verseNumber": 45,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ"
    },
    {
      "id": 5369,
      "verseKey": "69:46",
      "verseNumber": 46,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "ثُمَّ لَقَطَعْنَا مِنْهُ ٱلْوَتِينَ"
    },
    {
      "id": 5370,
      "verseKey": "69:47",
      "verseNumber": 47,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "فَمَا مِنكُم مِّنْ أَحَدٍ عَنْهُ حَـٰجِزِينَ"
    },
    {
      "id": 5371,
      "verseKey": "69:48",
      "verseNumber": 48,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
      "rukuNumber": 503,
      "manzilNumber": 7,
      "text": "وَإِنَّهُۥ لَتَذْكِرَةٌ لِّلْمُتَّقِينَ"
    },
    {
      "id": 5372,
      "verseKey": "69:49",
      "verseNumber": 49,
      "pageNumber": 568,
      "juzNumber": 29,
      "hizbNumber": 57,
      "rubElHizbNumber": 227,
