      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": " سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى"
    },
    {
      "id": 5950,
      "verseKey": "87:2",
      "verseNumber": 2,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "ٱلَّذِى خَلَقَ فَسَوَّىٰ"
    },
    {
      "id": 5951,
      "verseKey": "87:3",
      "verseNumber": 3,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ"
    },
    {
      "id": 5952,
      "verseKey": "87:4",
      "verseNumber": 4,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ"
    },
    {
      "id": 5953,
      "verseKey": "87:5",
      "verseNumber": 5,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ"
    },
    {
      "id": 5954,
      "verseKey": "87:6",
      "verseNumber": 6,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ"
    },
    {
      "id": 5955,
      "verseKey": "87:7",
      "verseNumber": 7,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ"
    },
    {
      "id": 5956,
      "verseKey": "87:8",
      "verseNumber": 8,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ"
    },
    {
      "id": 5957,
      "verseKey": "87:9",
      "verseNumber": 9,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ"
    },
    {
      "id": 5958,
      "verseKey": "87:10",
      "verseNumber": 10,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "سَيَذَّكَّرُ مَن يَخْشَىٰ"
    },
    {
      "id": 5959,
      "verseKey": "87:11",
      "verseNumber": 11,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى"
    },
    {
      "id": 5960,
      "verseKey": "87:12",
      "verseNumber": 12,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ"
    },
    {
      "id": 5961,
      "verseKey": "87:13",
      "verseNumber": 13,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ"
    },
    {
      "id": 5962,
      "verseKey": "87:14",
      "verseNumber": 14,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ"
    },
    {
      "id": 5963,
      "verseKey": "87:15",
      "verseNumber": 15,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ"
    },
    {
      "id": 5964,
      "verseKey": "87:16",
      "verseNumber": 16,
      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا"
    },
    {
      "id": 5965,
      "verseKey": "87:17",
      "verseNumber": 17,
      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ"
    },
    {
      "id": 5966,
      "verseKey": "87:18",
      "verseNumber": 18,
      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ"
    },
    {
      "id": 5967,
      "verseKey": "87:19",
      "verseNumber": 19,
      "pageNumber": 592,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 531,
      "manzilNumber": 7,
      "text": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ"
    }
  ]
}
