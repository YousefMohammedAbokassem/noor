  "verses": [
    {
      "id": 4676,
      "verseKey": "51:1",
      "verseNumber": 1,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": " وَٱلذَّٰرِيَـٰتِ ذَرْوًا"
    },
    {
      "id": 4677,
      "verseKey": "51:2",
      "verseNumber": 2,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "فَٱلْحَـٰمِلَـٰتِ وِقْرًا"
    },
    {
      "id": 4678,
      "verseKey": "51:3",
      "verseNumber": 3,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "فَٱلْجَـٰرِيَـٰتِ يُسْرًا"
    },
    {
      "id": 4679,
      "verseKey": "51:4",
      "verseNumber": 4,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "فَٱلْمُقَسِّمَـٰتِ أَمْرًا"
    },
    {
      "id": 4680,
      "verseKey": "51:5",
      "verseNumber": 5,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "إِنَّمَا تُوعَدُونَ لَصَادِقٌ"
    },
    {
      "id": 4681,
      "verseKey": "51:6",
      "verseNumber": 6,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَإِنَّ ٱلدِّينَ لَوَٰقِعٌ"
    },
    {
      "id": 4682,
      "verseKey": "51:7",
      "verseNumber": 7,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلْحُبُكِ"
    },
    {
      "id": 4683,
      "verseKey": "51:8",
      "verseNumber": 8,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "إِنَّكُمْ لَفِى قَوْلٍ مُّخْتَلِفٍ"
    },
    {
      "id": 4684,
      "verseKey": "51:9",
      "verseNumber": 9,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "يُؤْفَكُ عَنْهُ مَنْ أُفِكَ"
    },
    {
      "id": 4685,
      "verseKey": "51:10",
      "verseNumber": 10,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "قُتِلَ ٱلْخَرَّٰصُونَ"
    },
    {
      "id": 4686,
      "verseKey": "51:11",
      "verseNumber": 11,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ هُمْ فِى غَمْرَةٍ سَاهُونَ"
    },
    {
      "id": 4687,
      "verseKey": "51:12",
      "verseNumber": 12,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "يَسْـَٔلُونَ أَيَّانَ يَوْمُ ٱلدِّينِ"
    },
    {
      "id": 4688,
      "verseKey": "51:13",
      "verseNumber": 13,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "يَوْمَ هُمْ عَلَى ٱلنَّارِ يُفْتَنُونَ"
    },
    {
      "id": 4689,
      "verseKey": "51:14",
      "verseNumber": 14,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "ذُوقُوا۟ فِتْنَتَكُمْ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تَسْتَعْجِلُونَ"
    },
    {
      "id": 4690,
      "verseKey": "51:15",
      "verseNumber": 15,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَعُيُونٍ"
    },
    {
      "id": 4691,
      "verseKey": "51:16",
      "verseNumber": 16,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "ءَاخِذِينَ مَآ ءَاتَىٰهُمْ رَبُّهُمْ ۚ إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُحْسِنِينَ"
    },
    {
      "id": 4692,
      "verseKey": "51:17",
      "verseNumber": 17,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "كَانُوا۟ قَلِيلًا مِّنَ ٱلَّيْلِ مَا يَهْجَعُونَ"
    },
    {
      "id": 4693,
      "verseKey": "51:18",
      "verseNumber": 18,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَبِٱلْأَسْحَارِ هُمْ يَسْتَغْفِرُونَ"
    },
    {
      "id": 4694,
      "verseKey": "51:19",
      "verseNumber": 19,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَفِىٓ أَمْوَٰلِهِمْ حَقٌّ لِّلسَّآئِلِ وَٱلْمَحْرُومِ"
    },
    {
      "id": 4695,
      "verseKey": "51:20",
      "verseNumber": 20,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَفِى ٱلْأَرْضِ ءَايَـٰتٌ لِّلْمُوقِنِينَ"
    },
    {
      "id": 4696,
      "verseKey": "51:21",
      "verseNumber": 21,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَفِىٓ أَنفُسِكُمْ ۚ أَفَلَا تُبْصِرُونَ"
    },
    {
      "id": 4697,
      "verseKey": "51:22",
      "verseNumber": 22,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "وَفِى ٱلسَّمَآءِ رِزْقُكُمْ وَمَا تُوعَدُونَ"
    },
    {
      "id": 4698,
      "verseKey": "51:23",
      "verseNumber": 23,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 457,
      "manzilNumber": 7,
      "text": "فَوَرَبِّ ٱلسَّمَآءِ وَٱلْأَرْضِ إِنَّهُۥ لَحَقٌّ مِّثْلَ مَآ أَنَّكُمْ تَنطِقُونَ"
    },
    {
      "id": 4699,
      "verseKey": "51:24",
      "verseNumber": 24,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ ٱلْمُكْرَمِينَ"
    },
    {
      "id": 4700,
      "verseKey": "51:25",
      "verseNumber": 25,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "إِذْ دَخَلُوا۟ عَلَيْهِ فَقَالُوا۟ سَلَـٰمًا ۖ قَالَ سَلَـٰمٌ قَوْمٌ مُّنكَرُونَ"
    },
    {
      "id": 4701,
      "verseKey": "51:26",
      "verseNumber": 26,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَرَاغَ إِلَىٰٓ أَهْلِهِۦ فَجَآءَ بِعِجْلٍ سَمِينٍ"
    },
    {
      "id": 4702,
      "verseKey": "51:27",
      "verseNumber": 27,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَقَرَّبَهُۥٓ إِلَيْهِمْ قَالَ أَلَا تَأْكُلُونَ"
    },
    {
      "id": 4703,
      "verseKey": "51:28",
      "verseNumber": 28,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَأَوْجَسَ مِنْهُمْ خِيفَةً ۖ قَالُوا۟ لَا تَخَفْ ۖ وَبَشَّرُوهُ بِغُلَـٰمٍ عَلِيمٍ"
    },
    {
      "id": 4704,
      "verseKey": "51:29",
      "verseNumber": 29,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَأَقْبَلَتِ ٱمْرَأَتُهُۥ فِى صَرَّةٍ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٌ"
    },
    {
      "id": 4705,
      "verseKey": "51:30",
      "verseNumber": 30,
      "pageNumber": 521,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "قَالُوا۟ كَذَٰلِكِ قَالَ رَبُّكِ ۖ إِنَّهُۥ هُوَ ٱلْحَكِيمُ ٱلْعَلِيمُ"
    },
    {
      "id": 4706,
      "verseKey": "51:31",
      "verseNumber": 31,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "۞ قَالَ فَمَا خَطْبُكُمْ أَيُّهَا ٱلْمُرْسَلُونَ"
    },
    {
      "id": 4707,
      "verseKey": "51:32",
      "verseNumber": 32,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "قَالُوٓا۟ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٍ مُّجْرِمِينَ"
    },
    {
      "id": 4708,
      "verseKey": "51:33",
      "verseNumber": 33,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "لِنُرْسِلَ عَلَيْهِمْ حِجَارَةً مِّن طِينٍ"
    },
    {
      "id": 4709,
      "verseKey": "51:34",
      "verseNumber": 34,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "مُّسَوَّمَةً عِندَ رَبِّكَ لِلْمُسْرِفِينَ"
    },
    {
      "id": 4710,
      "verseKey": "51:35",
      "verseNumber": 35,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَأَخْرَجْنَا مَن كَانَ فِيهَا مِنَ ٱلْمُؤْمِنِينَ"
    },
    {
      "id": 4711,
      "verseKey": "51:36",
      "verseNumber": 36,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَمَا وَجَدْنَا فِيهَا غَيْرَ بَيْتٍ مِّنَ ٱلْمُسْلِمِينَ"
    },
    {
      "id": 4712,
      "verseKey": "51:37",
      "verseNumber": 37,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "وَتَرَكْنَا فِيهَآ ءَايَةً لِّلَّذِينَ يَخَافُونَ ٱلْعَذَابَ ٱلْأَلِيمَ"
    },
    {
      "id": 4713,
      "verseKey": "51:38",
      "verseNumber": 38,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "وَفِى مُوسَىٰٓ إِذْ أَرْسَلْنَـٰهُ إِلَىٰ فِرْعَوْنَ بِسُلْطَـٰنٍ مُّبِينٍ"
    },
    {
      "id": 4714,
      "verseKey": "51:39",
      "verseNumber": 39,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَتَوَلَّىٰ بِرُكْنِهِۦ وَقَالَ سَـٰحِرٌ أَوْ مَجْنُونٌ"
    },
    {
      "id": 4715,
      "verseKey": "51:40",
      "verseNumber": 40,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَأَخَذْنَـٰهُ وَجُنُودَهُۥ فَنَبَذْنَـٰهُمْ فِى ٱلْيَمِّ وَهُوَ مُلِيمٌ"
    },
    {
      "id": 4716,
      "verseKey": "51:41",
      "verseNumber": 41,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "وَفِى عَادٍ إِذْ أَرْسَلْنَا عَلَيْهِمُ ٱلرِّيحَ ٱلْعَقِيمَ"
    },
    {
      "id": 4717,
      "verseKey": "51:42",
      "verseNumber": 42,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "مَا تَذَرُ مِن شَىْءٍ أَتَتْ عَلَيْهِ إِلَّا جَعَلَتْهُ كَٱلرَّمِيمِ"
    },
    {
      "id": 4718,
      "verseKey": "51:43",
      "verseNumber": 43,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "وَفِى ثَمُودَ إِذْ قِيلَ لَهُمْ تَمَتَّعُوا۟ حَتَّىٰ حِينٍ"
    },
    {
      "id": 4719,
      "verseKey": "51:44",
      "verseNumber": 44,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَعَتَوْا۟ عَنْ أَمْرِ رَبِّهِمْ فَأَخَذَتْهُمُ ٱلصَّـٰعِقَةُ وَهُمْ يَنظُرُونَ"
    },
    {
      "id": 4720,
      "verseKey": "51:45",
      "verseNumber": 45,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "فَمَا ٱسْتَطَـٰعُوا۟ مِن قِيَامٍ وَمَا كَانُوا۟ مُنتَصِرِينَ"
    },
    {
      "id": 4721,
      "verseKey": "51:46",
      "verseNumber": 46,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 458,
      "manzilNumber": 7,
      "text": "وَقَوْمَ نُوحٍ مِّن قَبْلُ ۖ إِنَّهُمْ كَانُوا۟ قَوْمًا فَـٰسِقِينَ"
    },
    {
      "id": 4722,
      "verseKey": "51:47",
      "verseNumber": 47,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "وَٱلسَّمَآءَ بَنَيْنَـٰهَا بِأَيْي۟دٍ وَإِنَّا لَمُوسِعُونَ"
    },
    {
      "id": 4723,
      "verseKey": "51:48",
      "verseNumber": 48,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "وَٱلْأَرْضَ فَرَشْنَـٰهَا فَنِعْمَ ٱلْمَـٰهِدُونَ"
    },
    {
      "id": 4724,
      "verseKey": "51:49",
      "verseNumber": 49,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "وَمِن كُلِّ شَىْءٍ خَلَقْنَا زَوْجَيْنِ لَعَلَّكُمْ تَذَكَّرُونَ"
    },
    {
      "id": 4725,
      "verseKey": "51:50",
      "verseNumber": 50,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "فَفِرُّوٓا۟ إِلَى ٱللَّهِ ۖ إِنِّى لَكُم مِّنْهُ نَذِيرٌ مُّبِينٌ"
    },
    {
      "id": 4726,
      "verseKey": "51:51",
      "verseNumber": 51,
      "pageNumber": 522,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "وَلَا تَجْعَلُوا۟ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَ ۖ إِنِّى لَكُم مِّنْهُ نَذِيرٌ مُّبِينٌ"
    },
    {
      "id": 4727,
      "verseKey": "51:52",
      "verseNumber": 52,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوْ مَجْنُونٌ"
    },
    {
      "id": 4728,
      "verseKey": "51:53",
      "verseNumber": 53,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "أَتَوَاصَوْا۟ بِهِۦ ۚ بَلْ هُمْ قَوْمٌ طَاغُونَ"
    },
    {
      "id": 4729,
      "verseKey": "51:54",
      "verseNumber": 54,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٍ"
    },
    {
      "id": 4730,
      "verseKey": "51:55",
      "verseNumber": 55,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "وَذَكِّرْ فَإِنَّ ٱلذِّكْرَىٰ تَنفَعُ ٱلْمُؤْمِنِينَ"
    },
    {
      "id": 4731,
      "verseKey": "51:56",
      "verseNumber": 56,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "وَمَا خَلَقْتُ ٱلْجِنَّ وَٱلْإِنسَ إِلَّا لِيَعْبُدُونِ"
    },
    {
      "id": 4732,
      "verseKey": "51:57",
      "verseNumber": 57,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٍ وَمَآ أُرِيدُ أَن يُطْعِمُونِ"
    },
    {
      "id": 4733,
      "verseKey": "51:58",
      "verseNumber": 58,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلْقُوَّةِ ٱلْمَتِينُ"
    },
    {
      "id": 4734,
      "verseKey": "51:59",
      "verseNumber": 59,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "فَإِنَّ لِلَّذِينَ ظَلَمُوا۟ ذَنُوبًا مِّثْلَ ذَنُوبِ أَصْحَـٰبِهِمْ فَلَا يَسْتَعْجِلُونِ"
    },
    {
      "id": 4735,
      "verseKey": "51:60",
      "verseNumber": 60,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 459,
      "manzilNumber": 7,
      "text": "فَوَيْلٌ لِّلَّذِينَ كَفَرُوا۟ مِن يَوْمِهِمُ ٱلَّذِى يُوعَدُونَ"
    }
  ]
