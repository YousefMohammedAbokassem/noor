{
  "id": 50,
  "nameAr": "ق",
  "nameSimple": "Qaf",
  "nameComplex": "Qāf",
  "translatedName": "The Letter \"Qaf\"",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 34,
  "versesCount": 45,
  "bismillahPre": true,
  "startPage": 518,
  "endPage": 520,
  "verses": [
    {
      "id": 4631,
      "verseKey": "50:1",
      "verseNumber": 1,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": " قٓ ۚ وَٱلْقُرْءَانِ ٱلْمَجِيدِ"
    },
    {
      "id": 4632,
      "verseKey": "50:2",
      "verseNumber": 2,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "بَلْ عَجِبُوٓا۟ أَن جَآءَهُم مُّنذِرٌ مِّنْهُمْ فَقَالَ ٱلْكَـٰفِرُونَ هَـٰذَا شَىْءٌ عَجِيبٌ"
    },
    {
      "id": 4633,
      "verseKey": "50:3",
      "verseNumber": 3,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًا ۖ ذَٰلِكَ رَجْعٌۢ بَعِيدٌ"
    },
    {
      "id": 4634,
      "verseKey": "50:4",
      "verseNumber": 4,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "قَدْ عَلِمْنَا مَا تَنقُصُ ٱلْأَرْضُ مِنْهُمْ ۖ وَعِندَنَا كِتَـٰبٌ حَفِيظٌۢ"
    },
    {
      "id": 4635,
      "verseKey": "50:5",
      "verseNumber": 5,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "بَلْ كَذَّبُوا۟ بِٱلْحَقِّ لَمَّا جَآءَهُمْ فَهُمْ فِىٓ أَمْرٍ مَّرِيجٍ"
    },
    {
      "id": 4636,
      "verseKey": "50:6",
      "verseNumber": 6,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "أَفَلَمْ يَنظُرُوٓا۟ إِلَى ٱلسَّمَآءِ فَوْقَهُمْ كَيْفَ بَنَيْنَـٰهَا وَزَيَّنَّـٰهَا وَمَا لَهَا مِن فُرُوجٍ"
    },
    {
      "id": 4637,
      "verseKey": "50:7",
      "verseNumber": 7,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "وَٱلْأَرْضَ مَدَدْنَـٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ زَوْجٍۭ بَهِيجٍ"
    },
    {
      "id": 4638,
      "verseKey": "50:8",
      "verseNumber": 8,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "تَبْصِرَةً وَذِكْرَىٰ لِكُلِّ عَبْدٍ مُّنِيبٍ"
    },
    {
      "id": 4639,
      "verseKey": "50:9",
      "verseNumber": 9,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "وَنَزَّلْنَا مِنَ ٱلسَّمَآءِ مَآءً مُّبَـٰرَكًا فَأَنۢبَتْنَا بِهِۦ جَنَّـٰتٍ وَحَبَّ ٱلْحَصِيدِ"
    },
    {
      "id": 4640,
      "verseKey": "50:10",
      "verseNumber": 10,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "وَٱلنَّخْلَ بَاسِقَـٰتٍ لَّهَا طَلْعٌ نَّضِيدٌ"
    },
    {
      "id": 4641,
      "verseKey": "50:11",
      "verseNumber": 11,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "رِّزْقًا لِّلْعِبَادِ ۖ وَأَحْيَيْنَا بِهِۦ بَلْدَةً مَّيْتًا ۚ كَذَٰلِكَ ٱلْخُرُوجُ"
    },
    {
      "id": 4642,
      "verseKey": "50:12",
      "verseNumber": 12,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍ وَأَصْحَـٰبُ ٱلرَّسِّ وَثَمُودُ"
    },
    {
      "id": 4643,
      "verseKey": "50:13",
      "verseNumber": 13,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "وَعَادٌ وَفِرْعَوْنُ وَإِخْوَٰنُ لُوطٍ"
    },
    {
      "id": 4644,
      "verseKey": "50:14",
      "verseNumber": 14,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "وَأَصْحَـٰبُ ٱلْأَيْكَةِ وَقَوْمُ تُبَّعٍ ۚ كُلٌّ كَذَّبَ ٱلرُّسُلَ فَحَقَّ وَعِيدِ"
    },
    {
      "id": 4645,
      "verseKey": "50:15",
      "verseNumber": 15,
      "pageNumber": 518,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 454,
      "manzilNumber": 7,
      "text": "أَفَعَيِينَا بِٱلْخَلْقِ ٱلْأَوَّلِ ۚ بَلْ هُمْ فِى لَبْسٍ مِّنْ خَلْقٍ جَدِيدٍ"
    },
    {
      "id": 4646,
      "verseKey": "50:16",
      "verseNumber": 16,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "وَلَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ وَنَعْلَمُ مَا تُوَسْوِسُ بِهِۦ نَفْسُهُۥ ۖ وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنْ حَبْلِ ٱلْوَرِيدِ"
    },
    {
      "id": 4647,
      "verseKey": "50:17",
      "verseNumber": 17,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "إِذْ يَتَلَقَّى ٱلْمُتَلَقِّيَانِ عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ قَعِيدٌ"
    },
    {
      "id": 4648,
      "verseKey": "50:18",
      "verseNumber": 18,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "مَّا يَلْفِظُ مِن قَوْلٍ إِلَّا لَدَيْهِ رَقِيبٌ عَتِيدٌ"
    },
    {
      "id": 4649,
      "verseKey": "50:19",
      "verseNumber": 19,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "وَجَآءَتْ سَكْرَةُ ٱلْمَوْتِ بِٱلْحَقِّ ۖ ذَٰلِكَ مَا كُنتَ مِنْهُ تَحِيدُ"
    },
    {
      "id": 4650,
      "verseKey": "50:20",
      "verseNumber": 20,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "وَنُفِخَ فِى ٱلصُّورِ ۚ ذَٰلِكَ يَوْمُ ٱلْوَعِيدِ"
    },
    {
      "id": 4651,
      "verseKey": "50:21",
      "verseNumber": 21,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "وَجَآءَتْ كُلُّ نَفْسٍ مَّعَهَا سَآئِقٌ وَشَهِيدٌ"
    },
    {
      "id": 4652,
      "verseKey": "50:22",
      "verseNumber": 22,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "لَّقَدْ كُنتَ فِى غَفْلَةٍ مِّنْ هَـٰذَا فَكَشَفْنَا عَنكَ غِطَآءَكَ فَبَصَرُكَ ٱلْيَوْمَ حَدِيدٌ"
    },
    {
      "id": 4653,
      "verseKey": "50:23",
      "verseNumber": 23,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "وَقَالَ قَرِينُهُۥ هَـٰذَا مَا لَدَىَّ عَتِيدٌ"
    },
    {
      "id": 4654,
      "verseKey": "50:24",
      "verseNumber": 24,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "أَلْقِيَا فِى جَهَنَّمَ كُلَّ كَفَّارٍ عَنِيدٍ"
    },
    {
      "id": 4655,
      "verseKey": "50:25",
      "verseNumber": 25,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "مَّنَّاعٍ لِّلْخَيْرِ مُعْتَدٍ مُّرِيبٍ"
    },
    {
      "id": 4656,
      "verseKey": "50:26",
      "verseNumber": 26,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 207,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "ٱلَّذِى جَعَلَ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَ فَأَلْقِيَاهُ فِى ٱلْعَذَابِ ٱلشَّدِيدِ"
    },
    {
      "id": 4657,
      "verseKey": "50:27",
      "verseNumber": 27,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "۞ قَالَ قَرِينُهُۥ رَبَّنَا مَآ أَطْغَيْتُهُۥ وَلَـٰكِن كَانَ فِى ضَلَـٰلٍۭ بَعِيدٍ"
    },
    {
      "id": 4658,
      "verseKey": "50:28",
      "verseNumber": 28,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "قَالَ لَا تَخْتَصِمُوا۟ لَدَىَّ وَقَدْ قَدَّمْتُ إِلَيْكُم بِٱلْوَعِيدِ"
    },
    {
      "id": 4659,
      "verseKey": "50:29",
      "verseNumber": 29,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 455,
      "manzilNumber": 7,
      "text": "مَا يُبَدَّلُ ٱلْقَوْلُ لَدَىَّ وَمَآ أَنَا۠ بِظَلَّـٰمٍ لِّلْعَبِيدِ"
    },
    {
      "id": 4660,
      "verseKey": "50:30",
      "verseNumber": 30,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "يَوْمَ نَقُولُ لِجَهَنَّمَ هَلِ ٱمْتَلَأْتِ وَتَقُولُ هَلْ مِن مَّزِيدٍ"
    },
    {
      "id": 4661,
      "verseKey": "50:31",
      "verseNumber": 31,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "وَأُزْلِفَتِ ٱلْجَنَّةُ لِلْمُتَّقِينَ غَيْرَ بَعِيدٍ"
    },
    {
      "id": 4662,
      "verseKey": "50:32",
      "verseNumber": 32,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "هَـٰذَا مَا تُوعَدُونَ لِكُلِّ أَوَّابٍ حَفِيظٍ"
    },
    {
      "id": 4663,
      "verseKey": "50:33",
      "verseNumber": 33,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "مَّنْ خَشِىَ ٱلرَّحْمَـٰنَ بِٱلْغَيْبِ وَجَآءَ بِقَلْبٍ مُّنِيبٍ"
    },
    {
      "id": 4664,
      "verseKey": "50:34",
      "verseNumber": 34,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "ٱدْخُلُوهَا بِسَلَـٰمٍ ۖ ذَٰلِكَ يَوْمُ ٱلْخُلُودِ"
    },
    {
      "id": 4665,
      "verseKey": "50:35",
      "verseNumber": 35,
      "pageNumber": 519,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "لَهُم مَّا يَشَآءُونَ فِيهَا وَلَدَيْنَا مَزِيدٌ"
    },
    {
      "id": 4666,
      "verseKey": "50:36",
      "verseNumber": 36,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "وَكَمْ أَهْلَكْنَا قَبْلَهُم مِّن قَرْنٍ هُمْ أَشَدُّ مِنْهُم بَطْشًا فَنَقَّبُوا۟ فِى ٱلْبِلَـٰدِ هَلْ مِن مَّحِيصٍ"
    },
    {
      "id": 4667,
      "verseKey": "50:37",
      "verseNumber": 37,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "إِنَّ فِى ذَٰلِكَ لَذِكْرَىٰ لِمَن كَانَ لَهُۥ قَلْبٌ أَوْ أَلْقَى ٱلسَّمْعَ وَهُوَ شَهِيدٌ"
    },
    {
      "id": 4668,
      "verseKey": "50:38",
      "verseNumber": 38,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "وَلَقَدْ خَلَقْنَا ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍ وَمَا مَسَّنَا مِن لُّغُوبٍ"
    },
    {
      "id": 4669,
      "verseKey": "50:39",
      "verseNumber": 39,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ ٱلْغُرُوبِ"
    },
    {
      "id": 4670,
      "verseKey": "50:40",
      "verseNumber": 40,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "وَمِنَ ٱلَّيْلِ فَسَبِّحْهُ وَأَدْبَـٰرَ ٱلسُّجُودِ"
    },
    {
      "id": 4671,
      "verseKey": "50:41",
      "verseNumber": 41,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
      "text": "وَٱسْتَمِعْ يَوْمَ يُنَادِ ٱلْمُنَادِ مِن مَّكَانٍ قَرِيبٍ"
    },
    {
      "id": 4672,
      "verseKey": "50:42",
      "verseNumber": 42,
      "pageNumber": 520,
      "juzNumber": 26,
      "hizbNumber": 52,
      "rubElHizbNumber": 208,
      "rukuNumber": 456,
      "manzilNumber": 7,
