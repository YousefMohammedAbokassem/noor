{
  "id": 89,
  "nameAr": "الفجر",
  "nameSimple": "Al-Fajr",
  "nameComplex": "Al-Fajr",
  "translatedName": "The Dawn",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 10,
  "versesCount": 30,
  "bismillahPre": true,
  "startPage": 593,
  "endPage": 594,
  "verses": [
    {
      "id": 5994,
      "verseKey": "89:1",
      "verseNumber": 1,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": " وَٱلْفَجْرِ"
    },
    {
      "id": 5995,
      "verseKey": "89:2",
      "verseNumber": 2,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَلَيَالٍ عَشْرٍ"
    },
    {
      "id": 5996,
      "verseKey": "89:3",
      "verseNumber": 3,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَٱلشَّفْعِ وَٱلْوَتْرِ"
    },
    {
      "id": 5997,
      "verseKey": "89:4",
      "verseNumber": 4,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَٱلَّيْلِ إِذَا يَسْرِ"
    },
    {
      "id": 5998,
      "verseKey": "89:5",
      "verseNumber": 5,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "هَلْ فِى ذَٰلِكَ قَسَمٌ لِّذِى حِجْرٍ"
    },
    {
      "id": 5999,
      "verseKey": "89:6",
      "verseNumber": 6,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ"
    },
    {
      "id": 6000,
      "verseKey": "89:7",
      "verseNumber": 7,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "إِرَمَ ذَاتِ ٱلْعِمَادِ"
    },
    {
      "id": 6001,
      "verseKey": "89:8",
      "verseNumber": 8,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "ٱلَّتِى لَمْ يُخْلَقْ مِثْلُهَا فِى ٱلْبِلَـٰدِ"
    },
    {
      "id": 6002,
      "verseKey": "89:9",
      "verseNumber": 9,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَثَمُودَ ٱلَّذِينَ جَابُوا۟ ٱلصَّخْرَ بِٱلْوَادِ"
    },
    {
      "id": 6003,
      "verseKey": "89:10",
      "verseNumber": 10,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَفِرْعَوْنَ ذِى ٱلْأَوْتَادِ"
    },
    {
      "id": 6004,
      "verseKey": "89:11",
      "verseNumber": 11,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ طَغَوْا۟ فِى ٱلْبِلَـٰدِ"
    },
    {
      "id": 6005,
      "verseKey": "89:12",
      "verseNumber": 12,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "فَأَكْثَرُوا۟ فِيهَا ٱلْفَسَادَ"
    },
    {
      "id": 6006,
      "verseKey": "89:13",
      "verseNumber": 13,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ"
    },
    {
      "id": 6007,
      "verseKey": "89:14",
      "verseNumber": 14,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "إِنَّ رَبَّكَ لَبِٱلْمِرْصَادِ"
    },
    {
      "id": 6008,
      "verseKey": "89:15",
      "verseNumber": 15,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "فَأَمَّا ٱلْإِنسَـٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ"
    },
    {
      "id": 6009,
      "verseKey": "89:16",
      "verseNumber": 16,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَأَمَّآ إِذَا مَا ٱبْتَلَىٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ فَيَقُولُ رَبِّىٓ أَهَـٰنَنِ"
    },
    {
      "id": 6010,
      "verseKey": "89:17",
      "verseNumber": 17,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "كَلَّا ۖ بَل لَّا تُكْرِمُونَ ٱلْيَتِيمَ"
    },
    {
      "id": 6011,
      "verseKey": "89:18",
      "verseNumber": 18,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَلَا تَحَـٰٓضُّونَ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"
    },
    {
      "id": 6012,
      "verseKey": "89:19",
      "verseNumber": 19,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَتَأْكُلُونَ ٱلتُّرَاثَ أَكْلًا لَّمًّا"
    },
    {
      "id": 6013,
      "verseKey": "89:20",
      "verseNumber": 20,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَتُحِبُّونَ ٱلْمَالَ حُبًّا جَمًّا"
    },
    {
      "id": 6014,
      "verseKey": "89:21",
      "verseNumber": 21,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "كَلَّآ إِذَا دُكَّتِ ٱلْأَرْضُ دَكًّا دَكًّا"
    },
    {
      "id": 6015,
      "verseKey": "89:22",
      "verseNumber": 22,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَجَآءَ رَبُّكَ وَٱلْمَلَكُ صَفًّا صَفًّا"
    },
    {
      "id": 6016,
      "verseKey": "89:23",
      "verseNumber": 23,
      "pageNumber": 593,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَجِا۟ىٓءَ يَوْمَئِذٍۭ بِجَهَنَّمَ ۚ يَوْمَئِذٍ يَتَذَكَّرُ ٱلْإِنسَـٰنُ وَأَنَّىٰ لَهُ ٱلذِّكْرَىٰ"
    },
    {
      "id": 6017,
      "verseKey": "89:24",
      "verseNumber": 24,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "يَقُولُ يَـٰلَيْتَنِى قَدَّمْتُ لِحَيَاتِى"
    },
    {
      "id": 6018,
      "verseKey": "89:25",
      "verseNumber": 25,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "فَيَوْمَئِذٍ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٌ"
    },
    {
      "id": 6019,
      "verseKey": "89:26",
      "verseNumber": 26,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٌ"
    },
    {
      "id": 6020,
      "verseKey": "89:27",
      "verseNumber": 27,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "يَـٰٓأَيَّتُهَا ٱلنَّفْسُ ٱلْمُطْمَئِنَّةُ"
    },
    {
      "id": 6021,
      "verseKey": "89:28",
      "verseNumber": 28,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "ٱرْجِعِىٓ إِلَىٰ رَبِّكِ رَاضِيَةً مَّرْضِيَّةً"
    },
    {
      "id": 6022,
      "verseKey": "89:29",
      "verseNumber": 29,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "فَٱدْخُلِى فِى عِبَـٰدِى"
    },
    {
      "id": 6023,
      "verseKey": "89:30",
      "verseNumber": 30,
      "pageNumber": 594,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 237,
      "rukuNumber": 533,
      "manzilNumber": 7,
      "text": "وَٱدْخُلِى جَنَّتِى"
    }
  ]
}
