      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": " وَٱلنَّـٰزِعَـٰتِ غَرْقًا"
    },
    {
      "id": 5714,
      "verseKey": "79:2",
      "verseNumber": 2,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "وَٱلنَّـٰشِطَـٰتِ نَشْطًا"
    },
    {
      "id": 5715,
      "verseKey": "79:3",
      "verseNumber": 3,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "وَٱلسَّـٰبِحَـٰتِ سَبْحًا"
    },
    {
      "id": 5716,
      "verseKey": "79:4",
      "verseNumber": 4,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَٱلسَّـٰبِقَـٰتِ سَبْقًا"
    },
    {
      "id": 5717,
      "verseKey": "79:5",
      "verseNumber": 5,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَٱلْمُدَبِّرَٰتِ أَمْرًا"
    },
    {
      "id": 5718,
      "verseKey": "79:6",
      "verseNumber": 6,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ"
    },
    {
      "id": 5719,
      "verseKey": "79:7",
      "verseNumber": 7,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "تَتْبَعُهَا ٱلرَّادِفَةُ"
    },
    {
      "id": 5720,
      "verseKey": "79:8",
      "verseNumber": 8,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ"
    },
    {
      "id": 5721,
      "verseKey": "79:9",
      "verseNumber": 9,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "أَبْصَـٰرُهَا خَـٰشِعَةٌ"
    },
    {
      "id": 5722,
      "verseKey": "79:10",
      "verseNumber": 10,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ"
    },
    {
      "id": 5723,
      "verseKey": "79:11",
      "verseNumber": 11,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً"
    },
    {
      "id": 5724,
      "verseKey": "79:12",
      "verseNumber": 12,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ"
    },
    {
      "id": 5725,
      "verseKey": "79:13",
      "verseNumber": 13,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ"
    },
    {
      "id": 5726,
      "verseKey": "79:14",
      "verseNumber": 14,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَإِذَا هُم بِٱلسَّاهِرَةِ"
    },
    {
      "id": 5727,
      "verseKey": "79:15",
      "verseNumber": 15,
      "pageNumber": 583,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ"
    },
    {
      "id": 5728,
      "verseKey": "79:16",
      "verseNumber": 16,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى"
    },
    {
      "id": 5729,
      "verseKey": "79:17",
      "verseNumber": 17,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ"
    },
    {
      "id": 5730,
      "verseKey": "79:18",
      "verseNumber": 18,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ"
    },
    {
      "id": 5731,
      "verseKey": "79:19",
      "verseNumber": 19,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ"
    },
    {
      "id": 5732,
      "verseKey": "79:20",
      "verseNumber": 20,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَأَرَىٰهُ ٱلْـَٔايَةَ ٱلْكُبْرَىٰ"
    },
    {
      "id": 5733,
      "verseKey": "79:21",
      "verseNumber": 21,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَكَذَّبَ وَعَصَىٰ"
    },
    {
      "id": 5734,
      "verseKey": "79:22",
      "verseNumber": 22,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "ثُمَّ أَدْبَرَ يَسْعَىٰ"
    },
    {
      "id": 5735,
      "verseKey": "79:23",
      "verseNumber": 23,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَحَشَرَ فَنَادَىٰ"
    },
    {
      "id": 5736,
      "verseKey": "79:24",
      "verseNumber": 24,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ"
    },
    {
      "id": 5737,
      "verseKey": "79:25",
      "verseNumber": 25,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْـَٔاخِرَةِ وَٱلْأُولَىٰٓ"
    },
    {
      "id": 5738,
      "verseKey": "79:26",
      "verseNumber": 26,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 522,
      "manzilNumber": 7,
      "text": "إِنَّ فِى ذَٰلِكَ لَعِبْرَةً لِّمَن يَخْشَىٰٓ"
    },
    {
      "id": 5739,
      "verseKey": "79:27",
      "verseNumber": 27,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا"
    },
    {
      "id": 5740,
      "verseKey": "79:28",
      "verseNumber": 28,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "رَفَعَ سَمْكَهَا فَسَوَّىٰهَا"
    },
    {
      "id": 5741,
      "verseKey": "79:29",
      "verseNumber": 29,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا"
    },
    {
      "id": 5742,
      "verseKey": "79:30",
      "verseNumber": 30,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ"
    },
    {
      "id": 5743,
      "verseKey": "79:31",
      "verseNumber": 31,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا"
    },
    {
      "id": 5744,
      "verseKey": "79:32",
      "verseNumber": 32,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "وَٱلْجِبَالَ أَرْسَىٰهَا"
    },
    {
      "id": 5745,
      "verseKey": "79:33",
      "verseNumber": 33,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "مَتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ"
    },
    {
      "id": 5746,
      "verseKey": "79:34",
      "verseNumber": 34,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ"
    },
    {
      "id": 5747,
      "verseKey": "79:35",
      "verseNumber": 35,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَـٰنُ مَا سَعَىٰ"
    },
    {
      "id": 5748,
      "verseKey": "79:36",
      "verseNumber": 36,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ"
    },
    {
      "id": 5749,
      "verseKey": "79:37",
      "verseNumber": 37,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "فَأَمَّا مَن طَغَىٰ"
    },
    {
      "id": 5750,
      "verseKey": "79:38",
      "verseNumber": 38,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا"
    },
    {
      "id": 5751,
      "verseKey": "79:39",
      "verseNumber": 39,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ"
    },
    {
      "id": 5752,
      "verseKey": "79:40",
      "verseNumber": 40,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ"
    },
    {
      "id": 5753,
      "verseKey": "79:41",
      "verseNumber": 41,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ"
    },
    {
      "id": 5754,
      "verseKey": "79:42",
      "verseNumber": 42,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا"
    },
    {
      "id": 5755,
      "verseKey": "79:43",
      "verseNumber": 43,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ"
    },
    {
      "id": 5756,
      "verseKey": "79:44",
      "verseNumber": 44,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ"
    },
    {
      "id": 5757,
      "verseKey": "79:45",
      "verseNumber": 45,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا"
    },
    {
      "id": 5758,
      "verseKey": "79:46",
      "verseNumber": 46,
      "pageNumber": 584,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 233,
      "rukuNumber": 523,
      "manzilNumber": 7,
      "text": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا"
    }
  ]
}
