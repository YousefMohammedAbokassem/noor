      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ"
    },
    {
      "id": 6203,
      "verseKey": "107:6",
      "verseNumber": 6,
      "pageNumber": 602,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ هُمْ يُرَآءُونَ"
    },
    {
      "id": 6204,
      "verseKey": "107:7",
      "verseNumber": 7,
