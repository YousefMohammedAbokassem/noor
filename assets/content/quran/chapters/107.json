      "rukuNumber": 551,
      "manzilNumber": 7,
      "text": " أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ"
    },
    {
      "id": 6199,
      "verseKey": "107:2",
      "verseNumber": 2,
      "pageNumber": 602,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "text": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ"
    },
    {
      "id": 6200,
      "verseKey": "107:3",
      "verseNumber": 3,
      "pageNumber": 602,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"
    },
    {
      "id": 6201,
      "verseKey": "107:4",
      "verseNumber": 4,
      "pageNumber": 602,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 551,
      "manzilNumber": 7,
      "text": "فَوَيْلٌ لِّلْمُصَلِّينَ"
    },
    {
      "id": 6202,
      "verseKey": "107:5",
      "verseNumber": 5,
