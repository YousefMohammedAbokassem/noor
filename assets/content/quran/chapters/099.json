      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": " إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا"
    },
    {
      "id": 6140,
      "verseKey": "99:2",
      "verseNumber": 2,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا"
    },
    {
      "id": 6141,
      "verseKey": "99:3",
      "verseNumber": 3,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "وَقَالَ ٱلْإِنسَـٰنُ مَا لَهَا"
    },
    {
      "id": 6142,
      "verseKey": "99:4",
      "verseNumber": 4,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا"
    },
    {
      "id": 6143,
      "verseKey": "99:5",
      "verseNumber": 5,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا"
    },
    {
      "id": 6144,
      "verseKey": "99:6",
      "verseNumber": 6,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "يَوْمَئِذٍ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًا لِّيُرَوْا۟ أَعْمَـٰلَهُمْ"
    },
    {
      "id": 6145,
      "verseKey": "99:7",
      "verseNumber": 7,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُۥ"
    },
    {
      "id": 6146,
      "verseKey": "99:8",
      "verseNumber": 8,
      "pageNumber": 599,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 239,
      "rukuNumber": 543,
      "manzilNumber": 7,
      "text": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُۥ"
    }
  ]
}
