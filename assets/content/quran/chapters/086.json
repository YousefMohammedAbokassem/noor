      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": " وَٱلسَّمَآءِ وَٱلطَّارِقِ"
    },
    {
      "id": 5933,
      "verseKey": "86:2",
      "verseNumber": 2,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ"
    },
    {
      "id": 5934,
      "verseKey": "86:3",
      "verseNumber": 3,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "ٱلنَّجْمُ ٱلثَّاقِبُ"
    },
    {
      "id": 5935,
      "verseKey": "86:4",
      "verseNumber": 4,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ"
    },
    {
      "id": 5936,
      "verseKey": "86:5",
      "verseNumber": 5,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ"
    },
    {
      "id": 5937,
      "verseKey": "86:6",
      "verseNumber": 6,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "خُلِقَ مِن مَّآءٍ دَافِقٍ"
    },
    {
      "id": 5938,
      "verseKey": "86:7",
      "verseNumber": 7,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ"
    },
    {
      "id": 5939,
      "verseKey": "86:8",
      "verseNumber": 8,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ"
    },
    {
      "id": 5940,
      "verseKey": "86:9",
      "verseNumber": 9,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ"
    },
    {
      "id": 5941,
      "verseKey": "86:10",
      "verseNumber": 10,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ"
    },
    {
      "id": 5942,
      "verseKey": "86:11",
      "verseNumber": 11,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ"
    },
    {
      "id": 5943,
      "verseKey": "86:12",
      "verseNumber": 12,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ"
    },
    {
      "id": 5944,
      "verseKey": "86:13",
      "verseNumber": 13,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ"
    },
    {
      "id": 5945,
      "verseKey": "86:14",
      "verseNumber": 14,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "وَمَا هُوَ بِٱلْهَزْلِ"
    },
    {
      "id": 5946,
      "verseKey": "86:15",
      "verseNumber": 15,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًا"
    },
    {
      "id": 5947,
      "verseKey": "86:16",
      "verseNumber": 16,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "وَأَكِيدُ كَيْدًا"
    },
    {
      "id": 5948,
      "verseKey": "86:17",
      "verseNumber": 17,
      "pageNumber": 591,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 530,
      "manzilNumber": 7,
      "text": "فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا"
    }
  ]
}
