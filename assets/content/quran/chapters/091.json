  "verses": [
    {
      "id": 6044,
      "verseKey": "91:1",
      "verseNumber": 1,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": " وَٱلشَّمْسِ وَضُحَىٰهَا"
    },
    {
      "id": 6045,
      "verseKey": "91:2",
      "verseNumber": 2,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَٱلْقَمَرِ إِذَا تَلَىٰهَا"
    },
    {
      "id": 6046,
      "verseKey": "91:3",
      "verseNumber": 3,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَٱلنَّهَارِ إِذَا جَلَّىٰهَا"
    },
    {
      "id": 6047,
      "verseKey": "91:4",
      "verseNumber": 4,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَٱلَّيْلِ إِذَا يَغْشَىٰهَا"
    },
    {
      "id": 6048,
      "verseKey": "91:5",
      "verseNumber": 5,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَٱلسَّمَآءِ وَمَا بَنَىٰهَا"
    },
    {
      "id": 6049,
      "verseKey": "91:6",
      "verseNumber": 6,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَٱلْأَرْضِ وَمَا طَحَىٰهَا"
    },
    {
      "id": 6050,
      "verseKey": "91:7",
      "verseNumber": 7,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَنَفْسٍ وَمَا سَوَّىٰهَا"
    },
    {
      "id": 6051,
      "verseKey": "91:8",
      "verseNumber": 8,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا"
    },
    {
      "id": 6052,
      "verseKey": "91:9",
      "verseNumber": 9,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "قَدْ أَفْلَحَ مَن زَكَّىٰهَا"
    },
    {
      "id": 6053,
      "verseKey": "91:10",
      "verseNumber": 10,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَقَدْ خَابَ مَن دَسَّىٰهَا"
    },
    {
      "id": 6054,
      "verseKey": "91:11",
      "verseNumber": 11,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ"
    },
    {
      "id": 6055,
      "verseKey": "91:12",
      "verseNumber": 12,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا"
    },
    {
      "id": 6056,
      "verseKey": "91:13",
      "verseNumber": 13,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَـٰهَا"
    },
    {
      "id": 6057,
      "verseKey": "91:14",
      "verseNumber": 14,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا"
    },
    {
      "id": 6058,
      "verseKey": "91:15",
      "verseNumber": 15,
      "pageNumber": 595,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 238,
      "rukuNumber": 535,
      "manzilNumber": 7,
      "text": "وَلَا يَخَافُ عُقْبَـٰهَا"
    }
  ]
}
