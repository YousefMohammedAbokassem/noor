{
  "id": 15,
  "nameAr": "الحجر",
  "nameSimple": "Al-Hijr",
  "nameComplex": "Al-Ĥijr",
  "translatedName": "The Rocky Tract",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 54,
  "versesCount": 99,
  "bismillahPre": true,
  "startPage": 262,
  "endPage": 267,
  "verses": [
    {
      "id": 1803,
      "verseKey": "15:1",
      "verseNumber": 1,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": " الٓر ۚ تِلْكَ ءَايَـٰتُ ٱلْكِتَـٰبِ وَقُرْءَانٍ مُّبِينٍ"
    },
    {
      "id": 1804,
      "verseKey": "15:2",
      "verseNumber": 2,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "رُّبَمَا يَوَدُّ ٱلَّذِينَ كَفَرُوا۟ لَوْ كَانُوا۟ مُسْلِمِينَ"
    },
    {
      "id": 1805,
      "verseKey": "15:3",
      "verseNumber": 3,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "ذَرْهُمْ يَأْكُلُوا۟ وَيَتَمَتَّعُوا۟ وَيُلْهِهِمُ ٱلْأَمَلُ ۖ فَسَوْفَ يَعْلَمُونَ"
    },
    {
      "id": 1806,
      "verseKey": "15:4",
      "verseNumber": 4,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ إِلَّا وَلَهَا كِتَابٌ مَّعْلُومٌ"
    },
    {
      "id": 1807,
      "verseKey": "15:5",
      "verseNumber": 5,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "مَّا تَسْبِقُ مِنْ أُمَّةٍ أَجَلَهَا وَمَا يَسْتَـْٔخِرُونَ"
    },
    {
      "id": 1808,
      "verseKey": "15:6",
      "verseNumber": 6,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "وَقَالُوا۟ يَـٰٓأَيُّهَا ٱلَّذِى نُزِّلَ عَلَيْهِ ٱلذِّكْرُ إِنَّكَ لَمَجْنُونٌ"
    },
    {
      "id": 1809,
      "verseKey": "15:7",
      "verseNumber": 7,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "لَّوْ مَا تَأْتِينَا بِٱلْمَلَـٰٓئِكَةِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِينَ"
    },
    {
      "id": 1810,
      "verseKey": "15:8",
      "verseNumber": 8,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "مَا نُنَزِّلُ ٱلْمَلَـٰٓئِكَةَ إِلَّا بِٱلْحَقِّ وَمَا كَانُوٓا۟ إِذًا مُّنظَرِينَ"
    },
    {
      "id": 1811,
      "verseKey": "15:9",
      "verseNumber": 9,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "إِنَّا نَحْنُ نَزَّلْنَا ٱلذِّكْرَ وَإِنَّا لَهُۥ لَحَـٰفِظُونَ"
    },
    {
      "id": 1812,
      "verseKey": "15:10",
      "verseNumber": 10,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ فِى شِيَعِ ٱلْأَوَّلِينَ"
    },
    {
      "id": 1813,
      "verseKey": "15:11",
      "verseNumber": 11,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "وَمَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ"
    },
    {
      "id": 1814,
      "verseKey": "15:12",
      "verseNumber": 12,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "كَذَٰلِكَ نَسْلُكُهُۥ فِى قُلُوبِ ٱلْمُجْرِمِينَ"
    },
    {
      "id": 1815,
      "verseKey": "15:13",
      "verseNumber": 13,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "لَا يُؤْمِنُونَ بِهِۦ ۖ وَقَدْ خَلَتْ سُنَّةُ ٱلْأَوَّلِينَ"
    },
    {
      "id": 1816,
      "verseKey": "15:14",
      "verseNumber": 14,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "وَلَوْ فَتَحْنَا عَلَيْهِم بَابًا مِّنَ ٱلسَّمَآءِ فَظَلُّوا۟ فِيهِ يَعْرُجُونَ"
    },
    {
      "id": 1817,
      "verseKey": "15:15",
      "verseNumber": 15,
      "pageNumber": 262,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 218,
      "manzilNumber": 3,
      "text": "لَقَالُوٓا۟ إِنَّمَا سُكِّرَتْ أَبْصَـٰرُنَا بَلْ نَحْنُ قَوْمٌ مَّسْحُورُونَ"
    },
    {
      "id": 1818,
      "verseKey": "15:16",
      "verseNumber": 16,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًا وَزَيَّنَّـٰهَا لِلنَّـٰظِرِينَ"
    },
    {
      "id": 1819,
      "verseKey": "15:17",
      "verseNumber": 17,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَحَفِظْنَـٰهَا مِن كُلِّ شَيْطَـٰنٍ رَّجِيمٍ"
    },
    {
      "id": 1820,
      "verseKey": "15:18",
      "verseNumber": 18,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "إِلَّا مَنِ ٱسْتَرَقَ ٱلسَّمْعَ فَأَتْبَعَهُۥ شِهَابٌ مُّبِينٌ"
    },
    {
      "id": 1821,
      "verseKey": "15:19",
      "verseNumber": 19,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَٱلْأَرْضَ مَدَدْنَـٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ شَىْءٍ مَّوْزُونٍ"
    },
    {
      "id": 1822,
      "verseKey": "15:20",
      "verseNumber": 20,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَجَعَلْنَا لَكُمْ فِيهَا مَعَـٰيِشَ وَمَن لَّسْتُمْ لَهُۥ بِرَٰزِقِينَ"
    },
    {
      "id": 1823,
      "verseKey": "15:21",
      "verseNumber": 21,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَإِن مِّن شَىْءٍ إِلَّا عِندَنَا خَزَآئِنُهُۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍ مَّعْلُومٍ"
    },
    {
      "id": 1824,
      "verseKey": "15:22",
      "verseNumber": 22,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَأَرْسَلْنَا ٱلرِّيَـٰحَ لَوَٰقِحَ فَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءً فَأَسْقَيْنَـٰكُمُوهُ وَمَآ أَنتُمْ لَهُۥ بِخَـٰزِنِينَ"
    },
    {
      "id": 1825,
      "verseKey": "15:23",
      "verseNumber": 23,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَإِنَّا لَنَحْنُ نُحْىِۦ وَنُمِيتُ وَنَحْنُ ٱلْوَٰرِثُونَ"
    },
    {
      "id": 1826,
      "verseKey": "15:24",
      "verseNumber": 24,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ"
    },
    {
      "id": 1827,
      "verseKey": "15:25",
      "verseNumber": 25,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 219,
      "manzilNumber": 3,
      "text": "وَإِنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ ۚ إِنَّهُۥ حَكِيمٌ عَلِيمٌ"
    },
    {
      "id": 1828,
      "verseKey": "15:26",
      "verseNumber": 26,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "وَلَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ مِن صَلْصَـٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ"
    },
    {
      "id": 1829,
      "verseKey": "15:27",
      "verseNumber": 27,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "وَٱلْجَآنَّ خَلَقْنَـٰهُ مِن قَبْلُ مِن نَّارِ ٱلسَّمُومِ"
    },
    {
      "id": 1830,
      "verseKey": "15:28",
      "verseNumber": 28,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "وَإِذْ قَالَ رَبُّكَ لِلْمَلَـٰٓئِكَةِ إِنِّى خَـٰلِقٌۢ بَشَرًا مِّن صَلْصَـٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ"
    },
    {
      "id": 1831,
      "verseKey": "15:29",
      "verseNumber": 29,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَـٰجِدِينَ"
    },
    {
      "id": 1832,
      "verseKey": "15:30",
      "verseNumber": 30,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "فَسَجَدَ ٱلْمَلَـٰٓئِكَةُ كُلُّهُمْ أَجْمَعُونَ"
    },
    {
      "id": 1833,
      "verseKey": "15:31",
      "verseNumber": 31,
      "pageNumber": 263,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "إِلَّآ إِبْلِيسَ أَبَىٰٓ أَن يَكُونَ مَعَ ٱلسَّـٰجِدِينَ"
    },
    {
      "id": 1834,
      "verseKey": "15:32",
      "verseNumber": 32,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ يَـٰٓإِبْلِيسُ مَا لَكَ أَلَّا تَكُونَ مَعَ ٱلسَّـٰجِدِينَ"
    },
    {
      "id": 1835,
      "verseKey": "15:33",
      "verseNumber": 33,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ لَمْ أَكُن لِّأَسْجُدَ لِبَشَرٍ خَلَقْتَهُۥ مِن صَلْصَـٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ"
    },
    {
      "id": 1836,
      "verseKey": "15:34",
      "verseNumber": 34,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ فَٱخْرُجْ مِنْهَا فَإِنَّكَ رَجِيمٌ"
    },
    {
      "id": 1837,
      "verseKey": "15:35",
      "verseNumber": 35,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "وَإِنَّ عَلَيْكَ ٱللَّعْنَةَ إِلَىٰ يَوْمِ ٱلدِّينِ"
    },
    {
      "id": 1838,
      "verseKey": "15:36",
      "verseNumber": 36,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ رَبِّ فَأَنظِرْنِىٓ إِلَىٰ يَوْمِ يُبْعَثُونَ"
    },
    {
      "id": 1839,
      "verseKey": "15:37",
      "verseNumber": 37,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ فَإِنَّكَ مِنَ ٱلْمُنظَرِينَ"
    },
    {
      "id": 1840,
      "verseKey": "15:38",
      "verseNumber": 38,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "إِلَىٰ يَوْمِ ٱلْوَقْتِ ٱلْمَعْلُومِ"
    },
    {
      "id": 1841,
      "verseKey": "15:39",
      "verseNumber": 39,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ رَبِّ بِمَآ أَغْوَيْتَنِى لَأُزَيِّنَنَّ لَهُمْ فِى ٱلْأَرْضِ وَلَأُغْوِيَنَّهُمْ أَجْمَعِينَ"
    },
    {
      "id": 1842,
      "verseKey": "15:40",
      "verseNumber": 40,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "إِلَّا عِبَادَكَ مِنْهُمُ ٱلْمُخْلَصِينَ"
    },
    {
      "id": 1843,
      "verseKey": "15:41",
      "verseNumber": 41,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "قَالَ هَـٰذَا صِرَٰطٌ عَلَىَّ مُسْتَقِيمٌ"
    },
    {
      "id": 1844,
      "verseKey": "15:42",
      "verseNumber": 42,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
      "rubElHizbNumber": 105,
      "rukuNumber": 220,
      "manzilNumber": 3,
      "text": "إِنَّ عِبَادِى لَيْسَ لَكَ عَلَيْهِمْ سُلْطَـٰنٌ إِلَّا مَنِ ٱتَّبَعَكَ مِنَ ٱلْغَاوِينَ"
    },
    {
      "id": 1845,
      "verseKey": "15:43",
      "verseNumber": 43,
      "pageNumber": 264,
      "juzNumber": 14,
      "hizbNumber": 27,
