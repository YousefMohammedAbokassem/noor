      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": " وَٱلطُّورِ"
    },
    {
      "id": 4737,
      "verseKey": "52:2",
      "verseNumber": 2,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَكِتَـٰبٍ مَّسْطُورٍ"
    },
    {
      "id": 4738,
      "verseKey": "52:3",
      "verseNumber": 3,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "فِى رَقٍّ مَّنشُورٍ"
    },
    {
      "id": 4739,
      "verseKey": "52:4",
      "verseNumber": 4,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَٱلْبَيْتِ ٱلْمَعْمُورِ"
    },
    {
      "id": 4740,
      "verseKey": "52:5",
      "verseNumber": 5,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَٱلسَّقْفِ ٱلْمَرْفُوعِ"
    },
    {
      "id": 4741,
      "verseKey": "52:6",
      "verseNumber": 6,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَٱلْبَحْرِ ٱلْمَسْجُورِ"
    },
    {
      "id": 4742,
      "verseKey": "52:7",
      "verseNumber": 7,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "إِنَّ عَذَابَ رَبِّكَ لَوَٰقِعٌ"
    },
    {
      "id": 4743,
      "verseKey": "52:8",
      "verseNumber": 8,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "مَّا لَهُۥ مِن دَافِعٍ"
    },
    {
      "id": 4744,
      "verseKey": "52:9",
      "verseNumber": 9,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "يَوْمَ تَمُورُ ٱلسَّمَآءُ مَوْرًا"
    },
    {
      "id": 4745,
      "verseKey": "52:10",
      "verseNumber": 10,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَتَسِيرُ ٱلْجِبَالُ سَيْرًا"
    },
    {
      "id": 4746,
      "verseKey": "52:11",
      "verseNumber": 11,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "فَوَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "id": 4747,
      "verseKey": "52:12",
      "verseNumber": 12,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "ٱلَّذِينَ هُمْ فِى خَوْضٍ يَلْعَبُونَ"
    },
    {
      "id": 4748,
      "verseKey": "52:13",
      "verseNumber": 13,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "يَوْمَ يُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا"
    },
    {
      "id": 4749,
      "verseKey": "52:14",
      "verseNumber": 14,
      "pageNumber": 523,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "هَـٰذِهِ ٱلنَّارُ ٱلَّتِى كُنتُم بِهَا تُكَذِّبُونَ"
    },
    {
      "id": 4750,
      "verseKey": "52:15",
      "verseNumber": 15,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "أَفَسِحْرٌ هَـٰذَآ أَمْ أَنتُمْ لَا تُبْصِرُونَ"
    },
    {
      "id": 4751,
      "verseKey": "52:16",
      "verseNumber": 16,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "ٱصْلَوْهَا فَٱصْبِرُوٓا۟ أَوْ لَا تَصْبِرُوا۟ سَوَآءٌ عَلَيْكُمْ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ"
    },
    {
      "id": 4752,
      "verseKey": "52:17",
      "verseNumber": 17,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَنَعِيمٍ"
    },
    {
      "id": 4753,
      "verseKey": "52:18",
      "verseNumber": 18,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "فَـٰكِهِينَ بِمَآ ءَاتَىٰهُمْ رَبُّهُمْ وَوَقَىٰهُمْ رَبُّهُمْ عَذَابَ ٱلْجَحِيمِ"
    },
    {
      "id": 4754,
      "verseKey": "52:19",
      "verseNumber": 19,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ"
    },
    {
      "id": 4755,
      "verseKey": "52:20",
      "verseNumber": 20,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "مُتَّكِـِٔينَ عَلَىٰ سُرُرٍ مَّصْفُوفَةٍ ۖ وَزَوَّجْنَـٰهُم بِحُورٍ عِينٍ"
    },
    {
      "id": 4756,
      "verseKey": "52:21",
      "verseNumber": 21,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَٱلَّذِينَ ءَامَنُوا۟ وَٱتَّبَعَتْهُمْ ذُرِّيَّتُهُم بِإِيمَـٰنٍ أَلْحَقْنَا بِهِمْ ذُرِّيَّتَهُمْ وَمَآ أَلَتْنَـٰهُم مِّنْ عَمَلِهِم مِّن شَىْءٍ ۚ كُلُّ ٱمْرِئٍۭ بِمَا كَسَبَ رَهِينٌ"
    },
    {
      "id": 4757,
      "verseKey": "52:22",
      "verseNumber": 22,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَأَمْدَدْنَـٰهُم بِفَـٰكِهَةٍ وَلَحْمٍ مِّمَّا يَشْتَهُونَ"
    },
    {
      "id": 4758,
      "verseKey": "52:23",
      "verseNumber": 23,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 209,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "يَتَنَـٰزَعُونَ فِيهَا كَأْسًا لَّا لَغْوٌ فِيهَا وَلَا تَأْثِيمٌ"
    },
    {
      "id": 4759,
      "verseKey": "52:24",
      "verseNumber": 24,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "۞ وَيَطُوفُ عَلَيْهِمْ غِلْمَانٌ لَّهُمْ كَأَنَّهُمْ لُؤْلُؤٌ مَّكْنُونٌ"
    },
    {
      "id": 4760,
      "verseKey": "52:25",
      "verseNumber": 25,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"
    },
    {
      "id": 4761,
      "verseKey": "52:26",
      "verseNumber": 26,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "قَالُوٓا۟ إِنَّا كُنَّا قَبْلُ فِىٓ أَهْلِنَا مُشْفِقِينَ"
    },
    {
      "id": 4762,
      "verseKey": "52:27",
      "verseNumber": 27,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "فَمَنَّ ٱللَّهُ عَلَيْنَا وَوَقَىٰنَا عَذَابَ ٱلسَّمُومِ"
    },
    {
      "id": 4763,
      "verseKey": "52:28",
      "verseNumber": 28,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 460,
      "manzilNumber": 7,
      "text": "إِنَّا كُنَّا مِن قَبْلُ نَدْعُوهُ ۖ إِنَّهُۥ هُوَ ٱلْبَرُّ ٱلرَّحِيمُ"
    },
    {
      "id": 4764,
      "verseKey": "52:29",
      "verseNumber": 29,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "فَذَكِّرْ فَمَآ أَنتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَلَا مَجْنُونٍ"
    },
    {
      "id": 4765,
      "verseKey": "52:30",
      "verseNumber": 30,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ يَقُولُونَ شَاعِرٌ نَّتَرَبَّصُ بِهِۦ رَيْبَ ٱلْمَنُونِ"
    },
    {
      "id": 4766,
      "verseKey": "52:31",
      "verseNumber": 31,
      "pageNumber": 524,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "قُلْ تَرَبَّصُوا۟ فَإِنِّى مَعَكُم مِّنَ ٱلْمُتَرَبِّصِينَ"
    },
    {
      "id": 4767,
      "verseKey": "52:32",
      "verseNumber": 32,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ تَأْمُرُهُمْ أَحْلَـٰمُهُم بِهَـٰذَآ ۚ أَمْ هُمْ قَوْمٌ طَاغُونَ"
    },
    {
      "id": 4768,
      "verseKey": "52:33",
      "verseNumber": 33,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ يَقُولُونَ تَقَوَّلَهُۥ ۚ بَل لَّا يُؤْمِنُونَ"
    },
    {
      "id": 4769,
      "verseKey": "52:34",
      "verseNumber": 34,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "فَلْيَأْتُوا۟ بِحَدِيثٍ مِّثْلِهِۦٓ إِن كَانُوا۟ صَـٰدِقِينَ"
    },
    {
      "id": 4770,
      "verseKey": "52:35",
      "verseNumber": 35,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ خُلِقُوا۟ مِنْ غَيْرِ شَىْءٍ أَمْ هُمُ ٱلْخَـٰلِقُونَ"
    },
    {
      "id": 4771,
      "verseKey": "52:36",
      "verseNumber": 36,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ خَلَقُوا۟ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ ۚ بَل لَّا يُوقِنُونَ"
    },
    {
      "id": 4772,
      "verseKey": "52:37",
      "verseNumber": 37,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ عِندَهُمْ خَزَآئِنُ رَبِّكَ أَمْ هُمُ ٱلْمُصَۣيْطِرُونَ"
    },
    {
      "id": 4773,
      "verseKey": "52:38",
      "verseNumber": 38,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ لَهُمْ سُلَّمٌ يَسْتَمِعُونَ فِيهِ ۖ فَلْيَأْتِ مُسْتَمِعُهُم بِسُلْطَـٰنٍ مُّبِينٍ"
    },
    {
      "id": 4774,
      "verseKey": "52:39",
      "verseNumber": 39,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ لَهُ ٱلْبَنَـٰتُ وَلَكُمُ ٱلْبَنُونَ"
    },
    {
      "id": 4775,
      "verseKey": "52:40",
      "verseNumber": 40,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ تَسْـَٔلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ"
    },
    {
      "id": 4776,
      "verseKey": "52:41",
      "verseNumber": 41,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ"
    },
    {
      "id": 4777,
      "verseKey": "52:42",
      "verseNumber": 42,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ يُرِيدُونَ كَيْدًا ۖ فَٱلَّذِينَ كَفَرُوا۟ هُمُ ٱلْمَكِيدُونَ"
    },
    {
      "id": 4778,
      "verseKey": "52:43",
      "verseNumber": 43,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "أَمْ لَهُمْ إِلَـٰهٌ غَيْرُ ٱللَّهِ ۚ سُبْحَـٰنَ ٱللَّهِ عَمَّا يُشْرِكُونَ"
    },
    {
      "id": 4779,
      "verseKey": "52:44",
      "verseNumber": 44,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "وَإِن يَرَوْا۟ كِسْفًا مِّنَ ٱلسَّمَآءِ سَاقِطًا يَقُولُوا۟ سَحَابٌ مَّرْكُومٌ"
    },
    {
      "id": 4780,
      "verseKey": "52:45",
      "verseNumber": 45,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
      "text": "فَذَرْهُمْ حَتَّىٰ يُلَـٰقُوا۟ يَوْمَهُمُ ٱلَّذِى فِيهِ يُصْعَقُونَ"
    },
    {
      "id": 4781,
      "verseKey": "52:46",
      "verseNumber": 46,
      "pageNumber": 525,
      "juzNumber": 27,
      "hizbNumber": 53,
      "rubElHizbNumber": 210,
      "rukuNumber": 461,
      "manzilNumber": 7,
