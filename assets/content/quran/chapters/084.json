      "manzilNumber": 7,
      "text": " إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ"
    },
    {
      "id": 5886,
      "verseKey": "84:2",
      "verseNumber": 2,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ"
    },
    {
      "id": 5887,
      "verseKey": "84:3",
      "verseNumber": 3,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَإِذَا ٱلْأَرْضُ مُدَّتْ"
    },
    {
      "id": 5888,
      "verseKey": "84:4",
      "verseNumber": 4,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ"
    },
    {
      "id": 5889,
      "verseKey": "84:5",
      "verseNumber": 5,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ"
    },
    {
      "id": 5890,
      "verseKey": "84:6",
      "verseNumber": 6,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًا فَمُلَـٰقِيهِ"
    },
    {
      "id": 5891,
      "verseKey": "84:7",
      "verseNumber": 7,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ"
    },
    {
      "id": 5892,
      "verseKey": "84:8",
      "verseNumber": 8,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا"
    },
    {
      "id": 5893,
      "verseKey": "84:9",
      "verseNumber": 9,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا"
    },
    {
      "id": 5894,
      "verseKey": "84:10",
      "verseNumber": 10,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ وَرَآءَ ظَهْرِهِۦ"
    },
    {
      "id": 5895,
      "verseKey": "84:11",
      "verseNumber": 11,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "فَسَوْفَ يَدْعُوا۟ ثُبُورًا"
    },
    {
      "id": 5896,
      "verseKey": "84:12",
      "verseNumber": 12,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَيَصْلَىٰ سَعِيرًا"
    },
    {
      "id": 5897,
      "verseKey": "84:13",
      "verseNumber": 13,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا"
    },
    {
      "id": 5898,
      "verseKey": "84:14",
      "verseNumber": 14,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ"
    },
    {
      "id": 5899,
      "verseKey": "84:15",
      "verseNumber": 15,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًا"
    },
    {
      "id": 5900,
      "verseKey": "84:16",
      "verseNumber": 16,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "فَلَآ أُقْسِمُ بِٱلشَّفَقِ"
    },
    {
      "id": 5901,
      "verseKey": "84:17",
      "verseNumber": 17,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَٱلَّيْلِ وَمَا وَسَقَ"
    },
    {
      "id": 5902,
      "verseKey": "84:18",
      "verseNumber": 18,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَٱلْقَمَرِ إِذَا ٱتَّسَقَ"
    },
    {
      "id": 5903,
      "verseKey": "84:19",
      "verseNumber": 19,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ"
    },
    {
      "id": 5904,
      "verseKey": "84:20",
      "verseNumber": 20,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "فَمَا لَهُمْ لَا يُؤْمِنُونَ"
    },
    {
      "id": 5905,
      "verseKey": "84:21",
      "verseNumber": 21,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩"
    },
    {
      "id": 5906,
      "verseKey": "84:22",
      "verseNumber": 22,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ"
    },
    {
      "id": 5907,
      "verseKey": "84:23",
      "verseNumber": 23,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ"
    },
    {
      "id": 5908,
      "verseKey": "84:24",
      "verseNumber": 24,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ"
    },
    {
      "id": 5909,
      "verseKey": "84:25",
      "verseNumber": 25,
      "pageNumber": 589,
      "juzNumber": 30,
      "hizbNumber": 59,
      "rubElHizbNumber": 236,
      "rukuNumber": 528,
      "manzilNumber": 7,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ"
    }
  ]
}
