{
  "id": 75,
  "nameAr": "القيامة",
  "nameSimple": "Al-Qiyamah",
  "nameComplex": "Al-Qiyāmah",
  "translatedName": "The Resurrection",
  "translatedNameLanguage": "english",
  "revelationPlace": "makkah",
  "revelationOrder": 31,
  "versesCount": 40,
  "bismillahPre": true,
  "startPage": 577,
  "endPage": 578,
  "verses": [
    {
      "id": 5552,
      "verseKey": "75:1",
      "verseNumber": 1,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": " لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَـٰمَةِ"
    },
    {
      "id": 5553,
      "verseKey": "75:2",
      "verseNumber": 2,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ"
    },
    {
      "id": 5554,
      "verseKey": "75:3",
      "verseNumber": 3,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ"
    },
    {
      "id": 5555,
      "verseKey": "75:4",
      "verseNumber": 4,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "بَلَىٰ قَـٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ"
    },
    {
      "id": 5556,
      "verseKey": "75:5",
      "verseNumber": 5,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "بَلْ يُرِيدُ ٱلْإِنسَـٰنُ لِيَفْجُرَ أَمَامَهُۥ"
    },
    {
      "id": 5557,
      "verseKey": "75:6",
      "verseNumber": 6,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَـٰمَةِ"
    },
    {
      "id": 5558,
      "verseKey": "75:7",
      "verseNumber": 7,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "فَإِذَا بَرِقَ ٱلْبَصَرُ"
    },
    {
      "id": 5559,
      "verseKey": "75:8",
      "verseNumber": 8,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَخَسَفَ ٱلْقَمَرُ"
    },
    {
      "id": 5560,
      "verseKey": "75:9",
      "verseNumber": 9,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ"
    },
    {
      "id": 5561,
      "verseKey": "75:10",
      "verseNumber": 10,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "يَقُولُ ٱلْإِنسَـٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ"
    },
    {
      "id": 5562,
      "verseKey": "75:11",
      "verseNumber": 11,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "كَلَّا لَا وَزَرَ"
    },
    {
      "id": 5563,
      "verseKey": "75:12",
      "verseNumber": 12,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ"
    },
    {
      "id": 5564,
      "verseKey": "75:13",
      "verseNumber": 13,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "يُنَبَّؤُا۟ ٱلْإِنسَـٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ"
    },
    {
      "id": 5565,
      "verseKey": "75:14",
      "verseNumber": 14,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "بَلِ ٱلْإِنسَـٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ"
    },
    {
      "id": 5566,
      "verseKey": "75:15",
      "verseNumber": 15,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ"
    },
    {
      "id": 5567,
      "verseKey": "75:16",
      "verseNumber": 16,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ"
    },
    {
      "id": 5568,
      "verseKey": "75:17",
      "verseNumber": 17,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ"
    },
    {
      "id": 5569,
      "verseKey": "75:18",
      "verseNumber": 18,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "فَإِذَا قَرَأْنَـٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ"
    },
    {
      "id": 5570,
      "verseKey": "75:19",
      "verseNumber": 19,
      "pageNumber": 577,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ"
    },
    {
      "id": 5571,
      "verseKey": "75:20",
      "verseNumber": 20,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ"
    },
    {
      "id": 5572,
      "verseKey": "75:21",
      "verseNumber": 21,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَتَذَرُونَ ٱلْـَٔاخِرَةَ"
    },
    {
      "id": 5573,
      "verseKey": "75:22",
      "verseNumber": 22,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ"
    },
    {
      "id": 5574,
      "verseKey": "75:23",
      "verseNumber": 23,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "إِلَىٰ رَبِّهَا نَاظِرَةٌ"
    },
    {
      "id": 5575,
      "verseKey": "75:24",
      "verseNumber": 24,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَوُجُوهٌ يَوْمَئِذٍۭ بَاسِرَةٌ"
    },
    {
      "id": 5576,
      "verseKey": "75:25",
      "verseNumber": 25,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ"
    },
    {
      "id": 5577,
      "verseKey": "75:26",
      "verseNumber": 26,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ"
    },
    {
      "id": 5578,
      "verseKey": "75:27",
      "verseNumber": 27,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَقِيلَ مَنْ ۜ رَاقٍ"
    },
    {
      "id": 5579,
      "verseKey": "75:28",
      "verseNumber": 28,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ"
    },
    {
      "id": 5580,
      "verseKey": "75:29",
      "verseNumber": 29,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ"
    },
    {
      "id": 5581,
      "verseKey": "75:30",
      "verseNumber": 30,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 514,
      "manzilNumber": 7,
      "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ"
    },
    {
      "id": 5582,
      "verseKey": "75:31",
      "verseNumber": 31,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "فَلَا صَدَّقَ وَلَا صَلَّىٰ"
    },
    {
      "id": 5583,
      "verseKey": "75:32",
      "verseNumber": 32,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "وَلَـٰكِن كَذَّبَ وَتَوَلَّىٰ"
    },
    {
      "id": 5584,
      "verseKey": "75:33",
      "verseNumber": 33,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ"
    },
    {
      "id": 5585,
      "verseKey": "75:34",
      "verseNumber": 34,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "أَوْلَىٰ لَكَ فَأَوْلَىٰ"
    },
    {
      "id": 5586,
      "verseKey": "75:35",
      "verseNumber": 35,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ"
    },
    {
      "id": 5587,
      "verseKey": "75:36",
      "verseNumber": 36,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَن يُتْرَكَ سُدًى"
    },
    {
      "id": 5588,
      "verseKey": "75:37",
      "verseNumber": 37,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِىٍّ يُمْنَىٰ"
    },
    {
      "id": 5589,
      "verseKey": "75:38",
      "verseNumber": 38,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ"
    },
    {
      "id": 5590,
      "verseKey": "75:39",
      "verseNumber": 39,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ"
    },
    {
      "id": 5591,
      "verseKey": "75:40",
      "verseNumber": 40,
      "pageNumber": 578,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 231,
      "rukuNumber": 515,
      "manzilNumber": 7,
      "text": "أَلَيْسَ ذَٰلِكَ بِقَـٰدِرٍ عَلَىٰٓ أَن يُحْـِۧىَ ٱلْمَوْتَىٰ"
    }
  ]
}
