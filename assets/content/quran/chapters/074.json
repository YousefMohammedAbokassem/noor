      "verseNumber": 27,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "وَمَآ أَدْرَىٰكَ مَا سَقَرُ"
