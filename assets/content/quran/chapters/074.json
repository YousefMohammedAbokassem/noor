      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "ثُمَّ قُتِلَ كَيْفَ قَدَّرَ"
