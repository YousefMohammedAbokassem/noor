    {
      "id": 5512,
      "verseKey": "74:17",
      "verseNumber": 17,
      "pageNumber": 575,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
