    {
      "id": 5523,
      "verseKey": "74:28",
      "verseNumber": 28,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "لَا تُبْقِى وَلَا تَذَرُ"
    },
    {
      "id": 5524,
      "verseKey": "74:29",
      "verseNumber": 29,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "لَوَّاحَةٌ لِّلْبَشَرِ"
    },
    {
      "id": 5525,
      "verseKey": "74:30",
      "verseNumber": 30,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "عَلَيْهَا تِسْعَةَ عَشَرَ"
    },
    {
      "id": 5526,
      "verseKey": "74:31",
      "verseNumber": 31,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "وَمَا جَعَلْنَآ أَصْحَـٰبَ ٱلنَّارِ إِلَّا مَلَـٰٓئِكَةً ۙ وَمَا جَعَلْنَا عِدَّتَهُمْ إِلَّا فِتْنَةً لِّلَّذِينَ كَفَرُوا۟ لِيَسْتَيْقِنَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَـٰبَ وَيَزْدَادَ ٱلَّذِينَ ءَامَنُوٓا۟ إِيمَـٰنًا ۙ وَلَا يَرْتَابَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَـٰبَ وَٱلْمُؤْمِنُونَ ۙ وَلِيَقُولَ ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌ وَٱلْكَـٰفِرُونَ مَاذَآ أَرَادَ ٱللَّهُ بِهَـٰذَا مَثَلًا ۚ كَذَٰلِكَ يُضِلُّ ٱللَّهُ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ ۚ وَمَا يَعْلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَ ۚ وَمَا هِىَ إِلَّا ذِكْرَىٰ لِلْبَشَرِ"
    },
    {
      "id": 5527,
      "verseKey": "74:32",
      "verseNumber": 32,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 513,
      "manzilNumber": 7,
      "text": "كَلَّا وَٱلْقَمَرِ"
    },
    {
      "id": 5528,
      "verseKey": "74:33",
      "verseNumber": 33,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 513,
      "manzilNumber": 7,
