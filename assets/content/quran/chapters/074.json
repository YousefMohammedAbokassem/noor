      "verseKey": "74:36",
      "verseNumber": 36,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 513,
      "manzilNumber": 7,
