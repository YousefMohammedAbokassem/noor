      "verseKey": "74:25",
      "verseNumber": 25,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "إِنْ هَـٰذَآ إِلَّا قَوْلُ ٱلْبَشَرِ"
    },
    {
      "id": 5521,
      "verseKey": "74:26",
      "verseNumber": 26,
      "pageNumber": 576,
      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 512,
      "manzilNumber": 7,
      "text": "سَأُصْلِيهِ سَقَرَ"
