      "juzNumber": 29,
      "hizbNumber": 58,
      "rubElHizbNumber": 230,
      "rukuNumber": 513,
      "manzilNumber": 7,
      "text": "وَكُنَّا نَخُوضُ مَعَ ٱلْخَآئِضِينَ"
    },
