      "manzilNumber": 7,
      "text": " أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَـٰبِ ٱلْفِيلِ"
    },
    {
      "id": 6190,
      "verseKey": "105:2",
      "verseNumber": 2,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 549,
      "manzilNumber": 7,
      "text": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍ"
    },
    {
      "id": 6191,
      "verseKey": "105:3",
      "verseNumber": 3,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 549,
      "manzilNumber": 7,
      "text": "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ"
    },
    {
      "id": 6192,
      "verseKey": "105:4",
      "verseNumber": 4,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 549,
      "manzilNumber": 7,
      "text": "تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ"
    },
    {
      "id": 6193,
      "verseKey": "105:5",
      "verseNumber": 5,
      "pageNumber": 601,
      "juzNumber": 30,
      "hizbNumber": 60,
      "rubElHizbNumber": 240,
      "rukuNumber": 549,
      "manzilNumber": 7,
      "text": "فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍۭ"
    }
  ]
