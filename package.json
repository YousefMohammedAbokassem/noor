{
  "name": "noor-al-hayah-mobile",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client --lan --clear",
    "start:go": "expo start --lan --clear",
    "start:tunnel": "expo start --dev-client --tunnel --clear",
    "start:tunnel:go": "expo start --tunnel --clear",
    "start:lan": "expo start --dev-client --lan --clear",
    "start:lan:go": "expo start --lan --clear",
    "dev": "expo start --dev-client --lan --clear",
    "dev:tunnel": "expo start --dev-client --tunnel --clear",
    "dev:go": "expo start --lan --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "adhan:build:ios-sounds": "swift scripts/build-ios-adhan-sounds.swift",
    "eas-build-post-install": "node scripts/eas-post-install.mjs",
    "build:dev:android": "EAS_BUILD_NO_EXPO_GO_WARNING=true npx eas-cli build -p android --profile development",
    "build:dev:ios": "EAS_BUILD_NO_EXPO_GO_WARNING=true npx eas-cli build -p ios --profile development",
    "build:android": "NODE_ENV=production EAS_BUILD_NO_EXPO_GO_WARNING=true npx eas-cli build -p android --profile production",
    "build:aab": "NODE_ENV=production EAS_BUILD_NO_EXPO_GO_WARNING=true npx eas-cli build -p android --profile production",
    "build:apk": "NODE_ENV=production EAS_BUILD_NO_EXPO_GO_WARNING=true npx eas-cli build -p android --profile preview",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npx expo-doctor",
    "quran:build": "node scripts/fetch-quran-data.mjs",
    "sync:quran": "npm run quran:build"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@hookform/resolvers": "^3.10.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.66.4",
    "adhan": "^4.4.3",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "expo": "~54.0.34",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-background-task": "~1.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.17",
    "i18next": "^25.0.1",
    "react": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "^4.0.3",
    "react-native-worklets": "0.5.1",
    "tz-lookup": "^6.1.25",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "^5.7.2"
  }
}
