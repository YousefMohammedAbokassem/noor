{
  "name": "noor-al-hayah-mobile",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "main": "index.js",
  "scripts": {
    "start": "expo start --lan --clear",
    "start:tunnel": "expo start --tunnel --clear",
    "start:lan": "expo start --lan --clear",
    "dev": "expo start --lan --clear",
    "dev:tunnel": "expo start --tunnel --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "npx eas-cli build -p android --profile preview",
    "build:aab": "npx eas-cli build -p android --profile production",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "quran:build": "node scripts/fetch-quran-data.mjs",
    "sync:quran": "npm run quran:build"
  },
  "dependencies": {
