    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "typescript": "^5.7.2"
